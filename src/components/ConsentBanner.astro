---
import { getAnalyticsConfig, hasGa4, hasMetaPixel } from "../lib/analytics";

const config = getAnalyticsConfig();
const needsConsent = hasGa4(config) || hasMetaPixel(config);
---

{
  needsConsent && (
    <div class="consent" data-consent-banner hidden>
      <p class="consent__text">
        Usamos cookies de analítica y publicidad para mejorar la web.{" "}
        <a href="/privacidad">Privacidad</a>
      </p>
      <div class="consent__actions">
        <button type="button" class="consent__btn consent__btn--ghost" data-consent-reject>
          Rechazar
        </button>
        <button type="button" class="consent__btn consent__btn--primary" data-consent-accept>
          Aceptar
        </button>
      </div>
    </div>
  )
}

<script>
  import { registerAnalyticsClient, track } from "../lib/analytics/client";
  import { readConsent, writeConsent } from "../lib/analytics/consent";

  registerAnalyticsClient();

  const banner = document.querySelector("[data-consent-banner]");
  const accept = document.querySelector("[data-consent-accept]");
  const reject = document.querySelector("[data-consent-reject]");

  const sendPageView = () => {
    track({
      name: "page_view",
      payload: { path: window.location.pathname, title: document.title },
    });
  };

  const hideBanner = () => {
    banner?.setAttribute("hidden", "");
  };

  const showBanner = () => {
    banner?.removeAttribute("hidden");
  };

  if (readConsent() === "analytics") {
    hideBanner();
    sendPageView();
  } else if (banner) {
    showBanner();
  }

  accept?.addEventListener("click", () => {
    writeConsent("analytics");
    hideBanner();
    sendPageView();
  });

  reject?.addEventListener("click", () => {
    writeConsent("none");
    hideBanner();
  });

  document.addEventListener("astro:page-load", () => {
    if (readConsent() === "analytics") sendPageView();
  });
</script>

<style>
  .consent {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 60;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgb(201 169 98 / 0.25);
    background: rgb(8 8 10 / 0.94);
    backdrop-filter: blur(12px);
    box-shadow: var(--shadow);
  }

  @media (min-width: 640px) {
    .consent {
      left: auto;
      max-width: 36rem;
    }
  }

  .consent__text {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .consent__text a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .consent__text a:hover {
    text-decoration: underline;
  }

  .consent__actions {
    display: flex;
    gap: 0.5rem;
  }

  .consent__btn {
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius);
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .consent__btn--ghost {
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-muted);
  }

  .consent__btn--ghost:hover {
    color: var(--color-fg);
    border-color: var(--color-fg);
  }

  .consent__btn--primary {
    border: 1px solid rgb(201 169 98 / 0.35);
    background: var(--color-accent-light);
    color: var(--color-accent);
  }

  .consent__btn--primary:hover {
    background: rgb(201 169 98 / 0.2);
  }
</style>