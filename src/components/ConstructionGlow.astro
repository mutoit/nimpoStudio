---
type Props = {
  text?: string;
};

const { text = "En construcción" } = Astro.props;
---

<div class="glow" data-construction-glow aria-hidden="true">
  <canvas class="glow__canvas" data-construction-canvas></canvas>
  <p class="glow__fallback">{text}</p>
</div>

<script define:vars={{ text }}>
  const root = document.querySelector("[data-construction-glow]");
  const canvas = document.querySelector("[data-construction-canvas]");
  if (!root || !(canvas instanceof HTMLCanvasElement)) {
    /* component not mounted */
  } else {
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (reducedMotion) {
    root.classList.add("glow--static");
    canvas.remove();
  } else {

  const ctx = canvas.getContext("2d");
  if (!ctx) {
    /* no canvas support */
  } else {

  const ACCENT = "#c9a962";
  const ACCENT_SOFT = "rgba(201, 169, 98, 0.45)";
  const PARTICLE_COUNT = 120;
  const TRAIL_COUNT = 36;

  let width = 0;
  let height = 0;
  let dpr = 1;
  let frameId = 0;

  const textPos = { x: 0, y: 0, vx: 0, vy: 0 };
  const textTarget = { x: 0, y: 0 };
  let textAngle = 0;

  const particles = [];
  const trail = [];

  const rand = (min, max) => min + Math.random() * (max - min);

  const pickTarget = () => {
    const padX = Math.min(180, width * 0.15);
    const padY = Math.min(120, height * 0.12);
    textTarget.x = rand(padX, width - padX);
    textTarget.y = rand(padY, height - padY);
  };

  const resize = () => {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = Math.floor(width * dpr);
    canvas.height = Math.floor(height * dpr);
    canvas.style.width = `${width}px`;
    canvas.style.height = `${height}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    if (textPos.x === 0 && textPos.y === 0) {
      textPos.x = width * 0.5;
      textPos.y = height * 0.45;
    }
    pickTarget();
  };

  const initParticles = () => {
    particles.length = 0;
    trail.length = 0;
    for (let i = 0; i < PARTICLE_COUNT; i += 1) {
      particles.push({
        x: rand(0, width),
        y: rand(0, height),
        vx: rand(-0.25, 0.25),
        vy: rand(-0.35, 0.35),
        size: rand(0.6, 2.2),
        alpha: rand(0.15, 0.65),
        twinkle: rand(0, Math.PI * 2),
        trail: false,
      });
    }
    for (let i = 0; i < TRAIL_COUNT; i += 1) {
      trail.push({
        x: textPos.x,
        y: textPos.y,
        vx: 0,
        vy: 0,
        size: rand(1, 3),
        alpha: 0,
        twinkle: 0,
        trail: true,
      });
    }
  };

  const drawGlowText = (time) => {
    const fontSize = Math.max(28, Math.min(72, width * 0.055));
    const font = `600 ${fontSize}px "Cormorant Garamond", Georgia, serif`;
    ctx.font = font;
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";

    const wobbleX = Math.sin(time * 0.0012) * 8;
    const wobbleY = Math.cos(time * 0.0015) * 6;
    const x = textPos.x + wobbleX;
    const y = textPos.y + wobbleY;

    textAngle += (Math.random() - 0.5) * 0.002;
    textAngle *= 0.995;

    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(textAngle);

    ctx.shadowColor = ACCENT;
    ctx.shadowBlur = 42;
    ctx.fillStyle = "rgba(201, 169, 98, 0.12)";
    ctx.fillText(text, 0, 0);

    ctx.shadowBlur = 28;
    ctx.fillStyle = ACCENT_SOFT;
    ctx.fillText(text, 0, 0);

    ctx.shadowBlur = 14;
    ctx.fillStyle = "#f4e4bc";
    ctx.fillText(text, 0, 0);

    ctx.shadowBlur = 0;
    ctx.fillStyle = ACCENT;
    ctx.globalAlpha = 0.92;
    ctx.fillText(text, 0, 0);
    ctx.globalAlpha = 1;
    ctx.restore();

    return { x, y };
  };

  const updateText = () => {
    const dx = textTarget.x - textPos.x;
    const dy = textTarget.y - textPos.y;
    const dist = Math.hypot(dx, dy);

    if (dist < 24) pickTarget();

    const speed = 0.35 + Math.random() * 0.15;
    textPos.x += dx * 0.004 * speed;
    textPos.y += dy * 0.004 * speed;
  };

  const updateParticles = (lightX, lightY, time) => {
    for (const p of particles) {
      p.x += p.vx;
      p.y += p.vy;
      p.twinkle += 0.03;

      const toLightX = lightX - p.x;
      const toLightY = lightY - p.y;
      const lightDist = Math.hypot(toLightX, toLightY);
      if (lightDist < 220) {
        p.vx += (toLightX / lightDist) * 0.012;
        p.vy += (toLightY / lightDist) * 0.012;
      }

      p.vx *= 0.995;
      p.vy *= 0.995;

      if (p.x < -10) p.x = width + 10;
      if (p.x > width + 10) p.x = -10;
      if (p.y < -10) p.y = height + 10;
      if (p.y > height + 10) p.y = -10;
    }

    for (let i = 0; i < trail.length; i += 1) {
      const t = trail[i];
      const lag = (i + 1) * 0.035;
      t.x += (lightX - t.x) * (0.08 - lag * 0.001);
      t.y += (lightY - t.y) * (0.08 - lag * 0.001);
      t.alpha = Math.max(0, 0.55 - i * 0.015);
      t.size = Math.max(0.5, 3.2 - i * 0.06);
      t.twinkle = time * 0.01 + i;
    }
  };

  const drawParticles = () => {
    for (const p of particles) {
      const flicker = 0.55 + Math.sin(p.twinkle) * 0.45;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(201, 169, 98, ${p.alpha * flicker})`;
      ctx.fill();
    }

    for (const t of trail) {
      if (t.alpha <= 0) continue;
      ctx.beginPath();
      ctx.arc(t.x, t.y, t.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(244, 228, 188, ${t.alpha})`;
      ctx.fill();
    }
  };

  const drawVignette = () => {
    const gradient = ctx.createRadialGradient(
      width * 0.5,
      height * 0.45,
      Math.min(width, height) * 0.1,
      width * 0.5,
      height * 0.5,
      Math.max(width, height) * 0.75,
    );
    gradient.addColorStop(0, "rgba(8, 8, 10, 0)");
    gradient.addColorStop(1, "rgba(8, 8, 10, 0.55)");
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, width, height);
  };

  const tick = (time) => {
    ctx.clearRect(0, 0, width, height);
    updateText();
    const light = drawGlowText(time);
    updateParticles(light.x, light.y, time);
    drawParticles();
    drawVignette();
    frameId = requestAnimationFrame(tick);
  };

  const start = async () => {
    resize();
    initParticles();
    try {
      await document.fonts.ready;
    } catch {
      /* ignore */
    }
    frameId = requestAnimationFrame(tick);
  };

  window.addEventListener("resize", () => {
    resize();
  });

  document.addEventListener("visibilitychange", () => {
    if (document.hidden) {
      cancelAnimationFrame(frameId);
    } else {
      frameId = requestAnimationFrame(tick);
    }
  });

  start();
  }
  }
  }
</script>

<style>
  .glow {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .glow__canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .glow__fallback {
    display: none;
  }

  .glow--static {
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(
      ellipse at center,
      rgb(201 169 98 / 0.08) 0%,
      transparent 65%
    );
  }

  .glow--static .glow__fallback {
    display: block;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-shadow:
      0 0 24px rgb(201 169 98 / 0.5),
      0 0 48px rgb(201 169 98 / 0.25);
  }
</style>