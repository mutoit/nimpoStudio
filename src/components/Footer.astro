---
import { site } from "../lib/site";
import type { Locale } from "../i18n/translations";
import { useTranslations, localizePath } from "../lib/locale";

type Props = {
  lang?: Locale;
};

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);
---

<footer class="footer">
  <div class="container footer__inner">
    <div>
      <p class="footer__brand">{site.name}</p>
      <p class="footer__tagline">{site.tagline}</p>
    </div>
    <nav class="footer__nav" aria-label="Legal">
      <a href={localizePath("/biblioteca", lang)}>{t("navLibrary")}</a>
      <a href={localizePath("/privacidad", lang)}>{t("privacyTitle")}</a>
      <a href={localizePath("/terminos", lang)}>{t("termsTitle")}</a>
      <a href={localizePath("/contacto", lang)}>{t("navContact")}</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    padding-block: 2.5rem;
    padding-bottom: max(2.5rem, env(safe-area-inset-bottom, 0px));
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (max-width: 639px) {
    .footer {
      padding-block: 1.5rem;
      padding-bottom: max(1.5rem, env(safe-area-inset-bottom, 0px));
    }

    .footer__nav {
      gap: 0.65rem 1rem;
    }

    .footer__nav a {
      min-height: 2.5rem;
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0;
    }
  }

  @media (min-width: 640px) {
    .footer__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .footer__brand {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .footer__tagline {
    margin: 0.35rem 0 0;
    font-size: 0.8rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    color: var(--color-muted);
  }

  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .footer__nav a {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer__nav a:hover {
    color: var(--color-accent);
  }
</style>