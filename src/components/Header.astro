---
import { site } from "../lib/site";
import LanguageSelector from "./LanguageSelector.astro";
import UiSizeSelector from "./UiSizeSelector.astro";
import type { Locale } from "../i18n/translations";
import { useTranslations, localizePath } from "../lib/locale";

type Props = {
  lang?: Locale;
};

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;

const nav = [
  { href: "/biblioteca", label: t("navLibrary") },
  { href: "/sobre", label: t("navAbout") },
  { href: "/contacto", label: t("navContact") },
];
---

<header class="header" data-header>
  <div class="container header__inner">
    <a href={localizePath("/", lang)} class="logo">
      <span class="logo__mark" aria-hidden="true"></span>
      <span class="logo__name">{site.name}</span>
      <span class="logo__status" aria-label={t("construction")}>{t("construction")}</span>
    </a>

    <div class="header__tools">
      <UiSizeSelector lang={lang} />
      <LanguageSelector lang={lang} currentPath={currentPath} />
      <button
        type="button"
        class="header__menu-btn"
        data-menu-toggle
        data-label-open={t("navMenuOpen")}
        data-label-close={t("navMenuClose")}
        aria-expanded="false"
        aria-controls="site-nav"
        aria-label={t("navMenuOpen")}
      >
        <span class="header__menu-icon" aria-hidden="true"></span>
      </button>
    </div>

    <nav class="nav" id="site-nav" data-nav aria-label="Principal">
      {
        nav.map((item) => {
          const href = localizePath(item.href, lang);
          const isActive = currentPath.includes(item.href);
          return (
            <a
              href={href}
              class:list={["nav__link", { "nav__link--active": isActive }]}
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
      <span class="nav__soon" title={t("navStoreSoon")}>{t("navStoreSoon")}</span>
    </nav>
  </div>
</header>

<script>
  function bindHeaderMenu() {
    const header = document.querySelector<HTMLElement>("[data-header]");
    if (!header || header.dataset.bound === "1") return;
    header.dataset.bound = "1";

    const btn = header.querySelector<HTMLButtonElement>("[data-menu-toggle]");
    const nav = header.querySelector<HTMLElement>("[data-nav]");
    if (!btn || !nav) return;

    const openLabel = btn.dataset.labelOpen || "Menu";
    const closeLabel = btn.dataset.labelClose || openLabel;

    const setOpen = (open: boolean) => {
      header.classList.toggle("is-nav-open", open);
      btn.setAttribute("aria-expanded", open ? "true" : "false");
      btn.setAttribute("aria-label", open ? closeLabel : openLabel);
      document.body.classList.toggle("nav-open", open);
    };

    btn.addEventListener("click", () => {
      setOpen(!header.classList.contains("is-nav-open"));
    });

    nav.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });

    window.addEventListener("resize", () => {
      if (window.matchMedia("(min-width: 768px)").matches) setOpen(false);
    });
  }

  document.addEventListener("DOMContentLoaded", bindHeaderMenu);
  document.addEventListener("astro:page-load", bindHeaderMenu);
</script>

<style is:global>
  body.nav-open {
    overflow: hidden;
  }
</style>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background: rgb(8 8 10 / 0.92);
    backdrop-filter: blur(16px);
    padding-top: env(safe-area-inset-top, 0px);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    min-height: 3.75rem;
    position: relative;
  }

  @media (min-width: 768px) {
    .header__inner {
      min-height: 4.25rem;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-fg);
    min-width: 0;
    flex: 1;
  }

  .logo__name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .logo__status {
    position: relative;
    flex-shrink: 0;
    padding: 0.18rem 0.45rem;
    font-family: var(--font-body);
    font-size: 0.52rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff3d4;
    border-radius: 999px;
    border: 1px solid rgb(201 169 98 / 0.45);
    background: rgb(201 169 98 / 0.08);
    animation: status-glow 4s ease-in-out infinite;
  }

  .logo__status::before {
    content: "";
    position: absolute;
    inset: -6px -10px;
    border-radius: 999px;
    background: radial-gradient(
      ellipse at center,
      rgb(201 169 98 / 0.35) 0%,
      rgb(201 169 98 / 0.08) 45%,
      transparent 72%
    );
    z-index: -1;
    animation: status-halo 4s ease-in-out infinite;
  }

  @keyframes status-glow {
    0%,
    100% {
      opacity: 0.45;
      border-color: rgb(201 169 98 / 0.25);
      box-shadow:
        0 0 6px rgb(201 169 98 / 0.2),
        0 0 14px rgb(201 169 98 / 0.12),
        inset 0 0 8px rgb(201 169 98 / 0.06);
      text-shadow:
        0 0 6px rgb(201 169 98 / 0.35),
        0 0 14px rgb(201 169 98 / 0.2);
    }

    50% {
      opacity: 1;
      border-color: rgb(255 236 180 / 0.7);
      box-shadow:
        0 0 8px rgb(255 248 220 / 0.55),
        0 0 18px rgb(201 169 98 / 0.65),
        0 0 36px rgb(201 169 98 / 0.4),
        0 0 56px rgb(201 169 98 / 0.18),
        inset 0 0 12px rgb(255 236 180 / 0.15);
      text-shadow:
        0 0 8px rgb(255 248 220 / 0.9),
        0 0 16px rgb(201 169 98 / 0.95),
        0 0 28px rgb(201 169 98 / 0.65),
        0 0 42px rgb(201 169 98 / 0.35);
    }
  }

  @keyframes status-halo {
    0%,
    100% {
      opacity: 0.35;
      transform: scale(0.92);
    }

    50% {
      opacity: 1;
      transform: scale(1.08);
    }
  }

  @media (max-width: 400px) {
    .logo__status {
      display: none;
    }
  }

  @media (min-width: 768px) {
    .logo__name {
      font-size: 1.4rem;
    }

    .logo__status {
      font-size: 0.58rem;
      letter-spacing: 0.16em;
      padding: 0.2rem 0.55rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo__status,
    .logo__status::before {
      animation: none;
      opacity: 0.85;
      box-shadow:
        0 0 12px rgb(201 169 98 / 0.4),
        0 0 24px rgb(201 169 98 / 0.2);
      text-shadow: 0 0 10px rgb(201 169 98 / 0.6);
    }
  }

  .logo__mark {
    width: 6px;
    height: 6px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent);
  }

  .header__tools {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .header__menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-fg);
    cursor: pointer;
    touch-action: manipulation;
  }

  .header__menu-icon {
    display: block;
    width: 1.1rem;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    box-shadow:
      0 -6px 0 currentColor,
      0 6px 0 currentColor;
    transition: box-shadow 0.2s, transform 0.2s, background 0.2s;
  }

  .header.is-nav-open .header__menu-icon {
    background: transparent;
    box-shadow: none;
    transform: rotate(45deg);
  }

  .header.is-nav-open .header__menu-icon::before,
  .header.is-nav-open .header__menu-icon::after {
    content: "";
    position: absolute;
    width: 1.1rem;
    height: 2px;
    background: var(--color-fg);
    border-radius: 1px;
  }

  .header.is-nav-open .header__menu-icon {
    position: relative;
  }

  .header.is-nav-open .header__menu-icon::before {
    transform: rotate(0deg);
  }

  .header.is-nav-open .header__menu-icon::after {
    transform: rotate(90deg);
  }

  .nav {
    display: none;
    align-items: center;
    gap: 0.2rem;
  }

  .header.is-nav-open .nav {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 60;
    margin: 0;
    padding: 0.75rem max(0.9rem, env(safe-area-inset-left)) 1rem
      max(0.9rem, env(safe-area-inset-right));
    border-bottom: 1px solid var(--color-border);
    background: rgb(8 8 10 / 0.98);
    backdrop-filter: blur(16px);
    box-shadow: 0 16px 40px rgb(0 0 0 / 0.45);
    gap: 0.25rem;
  }

  .header.is-nav-open .nav .nav__link,
  .header.is-nav-open .nav .nav__soon {
    padding: 0.85rem 1rem;
    font-size: 0.95rem;
    min-height: 2.75rem;
    display: flex;
    align-items: center;
  }

  .header.is-nav-open .nav .nav__soon {
    display: flex;
    opacity: 0.45;
  }

  @media (min-width: 768px) {
    .header__menu-btn {
      display: none;
    }

    .nav {
      display: flex;
      flex-direction: row;
      position: static;
      margin: 0;
      padding: 0;
      border: none;
      background: transparent;
      box-shadow: none;
      gap: 0.2rem;
    }

    .header__tools {
      order: 3;
    }

    .nav {
      order: 2;
    }

    .header__inner {
      display: grid;
      grid-template-columns: 1fr auto auto;
      align-items: center;
      gap: 1rem;
    }
  }

  .nav__link {
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-muted);
    transition:
      color 0.2s,
      background 0.2s,
      box-shadow 0.2s;
  }

  .nav__link:hover {
    color: var(--color-fg);
    background: var(--color-surface);
  }

  .nav__link--active {
    color: var(--color-accent);
    background: var(--color-accent-light);
    box-shadow: inset 0 0 0 1px rgb(201 169 98 / 0.2);
  }

  .nav__soon {
    display: none;
    padding: 0.45rem 0.9rem;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
    opacity: 0.4;
    cursor: not-allowed;
  }

  @media (min-width: 768px) {
    .nav__soon {
      display: inline-block;
    }
  }
</style>
