---
import { site } from "../lib/site";
import LanguageSelector from "./LanguageSelector.astro";
import type { Locale } from "../i18n/translations";
import { useTranslations, localizePath } from "../lib/locale";

type Props = {
  lang?: Locale;
};

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;

const nav = [
  { href: "/biblioteca", label: t("navLibrary") },
  { href: "/musica", label: t("navMusic") },
  { href: "/catalogo", label: t("navCatalog") },
  { href: "/sobre", label: t("navAbout") },
  { href: "/contacto", label: t("navContact") },
];
---

<header class="header">
  <div class="container header__inner">
    <a href={localizePath("/", lang)} class="logo">
      <span class="logo__mark" aria-hidden="true"></span>
      <span class="logo__name">{site.name}</span>
      <span class="logo__status" aria-label={t("construction")}>{t("construction")}</span>
    </a>
    <nav class="nav" aria-label="Principal">
      {
        nav.map((item) => {
          const href = localizePath(item.href, lang);
          const isActive = currentPath.includes(item.href);
          return (
            <a
              href={href}
              class:list={["nav__link", { "nav__link--active": isActive }]}
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
      <span class="nav__soon" title={t("navStoreSoon")}>{t("navStoreSoon")}</span>
      <LanguageSelector lang={lang} currentPath={currentPath} />
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background: rgb(8 8 10 / 0.88);
    backdrop-filter: blur(16px);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.25rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--color-fg);
    min-width: 0;
  }

  .logo__name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .logo__status {
    position: relative;
    flex-shrink: 0;
    padding: 0.2rem 0.55rem;
    font-family: var(--font-body);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #fff3d4;
    border-radius: 999px;
    border: 1px solid rgb(201 169 98 / 0.45);
    background: rgb(201 169 98 / 0.08);
    animation: status-glow 4s ease-in-out infinite;
  }

  .logo__status::before {
    content: "";
    position: absolute;
    inset: -6px -10px;
    border-radius: 999px;
    background: radial-gradient(
      ellipse at center,
      rgb(201 169 98 / 0.35) 0%,
      rgb(201 169 98 / 0.08) 45%,
      transparent 72%
    );
    z-index: -1;
    animation: status-halo 4s ease-in-out infinite;
  }

  @keyframes status-glow {
    0%,
    100% {
      opacity: 0.45;
      border-color: rgb(201 169 98 / 0.25);
      box-shadow:
        0 0 6px rgb(201 169 98 / 0.2),
        0 0 14px rgb(201 169 98 / 0.12),
        inset 0 0 8px rgb(201 169 98 / 0.06);
      text-shadow:
        0 0 6px rgb(201 169 98 / 0.35),
        0 0 14px rgb(201 169 98 / 0.2);
    }

    50% {
      opacity: 1;
      border-color: rgb(255 236 180 / 0.7);
      box-shadow:
        0 0 8px rgb(255 248 220 / 0.55),
        0 0 18px rgb(201 169 98 / 0.65),
        0 0 36px rgb(201 169 98 / 0.4),
        0 0 56px rgb(201 169 98 / 0.18),
        inset 0 0 12px rgb(255 236 180 / 0.15);
      text-shadow:
        0 0 8px rgb(255 248 220 / 0.9),
        0 0 16px rgb(201 169 98 / 0.95),
        0 0 28px rgb(201 169 98 / 0.65),
        0 0 42px rgb(201 169 98 / 0.35);
    }
  }

  @keyframes status-halo {
    0%,
    100% {
      opacity: 0.35;
      transform: scale(0.92);
    }

    50% {
      opacity: 1;
      transform: scale(1.08);
    }
  }

  @media (max-width: 640px) {
    .logo__name {
      font-size: 1.15rem;
    }

    .logo__status {
      font-size: 0.5rem;
      letter-spacing: 0.12em;
      padding: 0.15rem 0.4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo__status,
    .logo__status::before {
      animation: none;
      opacity: 0.85;
      box-shadow:
        0 0 12px rgb(201 169 98 / 0.4),
        0 0 24px rgb(201 169 98 / 0.2);
      text-shadow: 0 0 10px rgb(201 169 98 / 0.6);
    }
  }

  .logo__mark {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    flex-wrap: wrap;
  }

  .nav__link {
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-muted);
    transition: color 0.2s, background 0.2s, box-shadow 0.2s;
  }

  .nav__link:hover {
    color: var(--color-fg);
    background: var(--color-surface);
  }

  .nav__link--active {
    color: var(--color-accent);
    background: var(--color-accent-light);
    box-shadow: inset 0 0 0 1px rgb(201 169 98 / 0.2);
  }

  .nav__soon {
    display: none;
    padding: 0.45rem 0.9rem;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
    opacity: 0.4;
    cursor: not-allowed;
  }

  @media (min-width: 640px) {
    .nav__soon {
      display: inline-block;
    }
  }
</style>