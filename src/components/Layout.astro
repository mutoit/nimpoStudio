---
import "../styles/global.css";
import { site } from "../lib/site";
import AnalyticsHead from "./AnalyticsHead.astro";
import ConsentBanner from "./ConsentBanner.astro";
import StructuredData from "./StructuredData.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { getLangFromUrl } from "../lib/locale";
import type { Locale } from "../i18n/translations";

type Props = {
  title: string;
  description?: string;
  image?: string;
  lang?: Locale;
};

const { title, description = site.description, image, lang } = Astro.props;
const currentLang = lang ?? getLangFromUrl(Astro.url);
const pageTitle = title === site.name ? title : `${title} · ${site.name}`;
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL(image ?? "/favicon.svg", site.url).href;

const localeMap: Record<Locale, string> = {
  es: "es_ES",
  en: "en_US",
  fr: "fr_FR",
};
const ogLocale = localeMap[currentLang] ?? "es_ES";
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <meta name="theme-color" content="#08080a" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    {/* Evita flash de tamaño: aplica S/M/L antes del paint */}
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem("nimpo-ui-size");
          if (s === "s" || s === "m" || s === "l") {
            document.documentElement.setAttribute("data-ui-size", s);
          } else {
            document.documentElement.setAttribute("data-ui-size", "m");
          }
        } catch (e) {
          document.documentElement.setAttribute("data-ui-size", "m");
        }
      })();
    </script>
    <AnalyticsHead />
    <StructuredData lang={currentLang} />
  </head>
  <body>
    <Header lang={currentLang} />
    <main class="main">
      <slot />
    </main>
    <Footer lang={currentLang} />
    <ConsentBanner lang={currentLang} />
  </body>
</html>

<style>
  .main {
    flex: 1;
    padding-block: 2.5rem 4rem;
  }
</style>