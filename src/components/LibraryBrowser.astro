---
/**
 * Biblioteca: miniaturas en frame 1:1 + modal overlay (detalle, stems, licencia completa).
 * CSS is:global (HTML del grid vía JS).
 * Plan: docs/licencias/PLAN-BIBLIOTECA-Y-PRECIOS.md
 */
import type { LibraryItem } from "../lib/library";
import { getLibraryMoods } from "../lib/library";
import type { Locale } from "../i18n/translations";
import { useTranslations } from "../lib/locale";
import { LICENSE_PRICES, USAGE_CATALOG } from "../lib/license-quote";

interface Props {
  items: LibraryItem[];
  lang: Locale;
}

const { items, lang } = Astro.props;
const t = useTranslations(lang);
const allMoods = getLibraryMoods();

const usageLabelMap: Record<string, string> = {
  personal_private: t("usagePersonalPrivate"),
  film_short: t("usageFilmShort"),
  film_feature: t("usageFilmFeature"),
  series_one: t("usageSeriesOne"),
  series_multi: t("usageSeriesMulti"),
  brand_video: t("usageBrandVideo"),
  social_brand: t("usageSocialBrand"),
  podcast_one: t("usagePodcastOne"),
  ads_paid: t("usageAdsPaid"),
  game_indie: t("usageGameIndie"),
  game_liveops: t("usageGameLiveops"),
  app_one: t("usageAppOne"),
  app_saas: t("usageAppSaas"),
  install_one: t("usageInstallOne"),
  tour_event: t("usageTourEvent"),
  exclusive_scope: t("usageExclusive"),
  buyout: t("usageBuyout"),
  other: t("usageOther"),
};

const usageGroups = [
  { id: "personal", label: t("usageGroupPersonal") },
  { id: "audiovisual", label: t("usageGroupAudiovisual") },
  { id: "ads", label: t("usageGroupAds") },
  { id: "interactive", label: t("usageGroupInteractive") },
  { id: "live", label: t("usageGroupLive") },
  { id: "special", label: t("usageGroupSpecial") },
];

const P = LICENSE_PRICES;
const turnstileSiteKey = (import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "").trim();

const payload = {
  items,
  lang,
  moods: allMoods,
  labels: {
    all: t("libFilterAll"),
    video11: t("libFilter11"),
    video916: t("libFilter916"),
    stems: t("libFilterStems"),
    license: t("musicLicenseOpen"),
    provisional: t("badgeProvisionalShort"),
    empty: t("libEmpty"),
    play: t("libPlay"),
    stop: "❚❚",
    close: t("libClose"),
    from: t("musicLicensePriceFrom"),
    review: t("musicLicensePriceOnRequest"),
    select: t("quoteSelect"),
    unavailable: t("libUnavailable"),
    noLicense: t("libNoLicense"),
  },
};
---

<div class="lb" data-library-root data-payload={JSON.stringify(payload)}>
  <div class="lb__bar" role="toolbar" aria-label={t("libFilters")}>
    <div class="lb__chips lb__chips--row" data-lb-types>
      <button type="button" class="lb__chip is-on" data-type="all">{t("libFilterAll")}</button>
      <button type="button" class="lb__chip" data-type="stems">{t("libFilterStems")}</button>
    </div>
    <div class="lb__filter-block">
      <span class="lb__filter-label">{t("libMoods")}</span>
      <div class="lb__chips lb__chips--wrap" data-lb-moods></div>
    </div>
    <div class="lb__filter-block">
      <span class="lb__filter-label">{t("libTags")}</span>
      <div class="lb__chips lb__chips--wrap" data-lb-tags></div>
    </div>
    <span class="lb__count" data-lb-count></span>
  </div>

  <div class="lb__grid" data-lb-grid></div>

  <!-- Modal encima del catálogo -->
  <div class="lb__overlay" data-lb-overlay hidden>
    <div class="lb__modal" role="dialog" aria-modal="true" data-lb-modal>
      <button type="button" class="lb__x" data-lb-close aria-label={t("libClose")}>×</button>

      <div class="lb__modal-grid">
        <div class="lb__modal-left">
          <p class="lb__kicker" data-lb-kicker></p>
          <h2 class="lb__ptitle" data-lb-title></h2>
          <p class="lb__prov-badge" data-lb-prov hidden></p>
          <div class="lb__media" data-lb-media></div>
          <div class="lb__transport" data-lb-transport>
            <button type="button" class="lb__btn" data-lb-preview-play>{t("libPlay")}</button>
            <div class="lb__progress" data-lb-progress>
              <input
                type="range"
                class="lb__seek"
                data-lb-seek
                min="0"
                max="1000"
                value="0"
                step="1"
                aria-label="Progreso"
              />
              <span class="lb__time" data-lb-time>0:00 / --:--</span>
            </div>
          </div>
          <p class="lb__protect" role="note">{t("libPreviewProtect")}</p>

          <p class="lb__label">{t("libDescription")}</p>
          <p class="lb__text" data-lb-desc></p>
          <p class="lb__label">{t("libNotes")}</p>
          <p class="lb__text" data-lb-notes></p>
          <p class="lb__label">{t("libMoods")}</p>
          <ul class="lb__pills" data-lb-mood-pills></ul>
          <p class="lb__label">Tags</p>
          <ul class="lb__pills" data-lb-tag-pills></ul>
          <div data-lb-stems-wrap hidden>
            <p class="lb__label">{t("libStemsTitle")}</p>
            <div class="lb__mixer" data-lb-mixer></div>
          </div>
        </div>

        <div class="lb__modal-right" data-lb-lic-wrap hidden>
          <h3 class="lb__form-title">{t("quoteFormTitle")}</h3>
          <p class="lb__form-lead">{t("quoteFormLead")}</p>
          <p class="lb__protect lb__protect--lic" role="note">{t("musicLicensePreviewNote")}</p>

          <form class="lb__form" data-lb-form>
            <input type="hidden" name="workSlug" />
            <input type="hidden" name="workName" />

            <div class="lb__form-row">
              <label
                >{t("quoteName")}<input name="name" required autocomplete="name" /></label
              >
              <label
                >{t("quoteEmail")}<input
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                /></label
              >
            </div>

            <label>
              {t("quoteUsageType")}
              <select name="usage" required data-lb-usage>
                <option value="">{t("quoteSelect")}</option>
                {
                  usageGroups.map((g) => (
                    <optgroup label={g.label}>
                      {USAGE_CATALOG.filter((u) => u.group === g.id).map((u) => (
                        <option value={u.code}>{usageLabelMap[u.code]}</option>
                      ))}
                    </optgroup>
                  ))
                }
              </select>
            </label>

            <div class="lb__form-row">
              <label
                >{t("quoteTerritory")}<input
                  name="territory"
                  required
                  placeholder="ES / EU / mundial"
                /></label
              >
              <label>
                {t("quoteTerm")}
                <select name="term">
                  <option value="single">{t("quoteTermSingle")}</option>
                  <option value="1y">{t("quoteTerm1y")}</option>
                  <option value="project">{t("quoteTermProject")}</option>
                  <option value="2y" selected>{t("quoteTerm2y")}</option>
                  <option value="custom">{t("quoteTermCustom")}</option>
                </select>
              </label>
            </div>

            <label>
              {t("quoteProject")}
              <textarea name="project" rows="3" required placeholder={t("quoteProjectPh")}
              ></textarea>
            </label>

            <fieldset class="lb__fieldset">
              <legend>{t("quoteExtras")}</legend>
              <label class="lb__check"
                ><input type="checkbox" name="stems" value="1" data-lb-flag />
                {t("quoteStems")} (+{P.stems} €)</label
              >
              <label class="lb__check"
                ><input type="checkbox" name="editShort" value="1" data-lb-flag />
                {t("quoteEdit")} (+{P.editShort} €)</label
              >
              <label class="lb__check"
                ><input type="checkbox" name="termPlus1y" value="1" data-lb-flag />
                Extensión +1 año (+{P.termPlus1yCommercial} € / +{P.termPlus1yExclusive} € si
                exclusiva)</label
              >
              <label class="lb__check"
                ><input type="checkbox" name="territoryExpand" value="1" data-lb-flag />
                Ampliar territorio / medios (+{P.territoryExpand} €)</label
              >
              <label class="lb__check"
                ><input type="checkbox" name="moreComposition" value="1" data-lb-flag />
                Más composición / custom ½ día (+{P.moreComposition} €)</label
              >
              <label class="lb__check"
                ><input type="checkbox" name="exclusive" value="1" data-lb-flag />
                {t("quoteExclusive")} (desde {P.exclusiveFrom} €)</label
              >
              <label class="lb__check"
                ><input type="checkbox" name="removeFromCatalog" value="1" data-lb-flag />
                No disponible / retirar del catálogo público (+{P.removeFromCatalog} €, con
                exclusiva)</label
              >
              <label class="lb__check"
                ><input type="checkbox" name="buyout" value="1" data-lb-flag />
                {t("quoteBuyout")} (desde {P.buyoutFrom} €)</label
              >
            </fieldset>

            <fieldset class="lb__fieldset lb__fieldset--special">
              <legend>{t("quoteSpecialLegend")}</legend>
              <p class="lb__help">{t("quoteSpecialHelp")}</p>
              <label class="lb__check"
                ><input type="checkbox" name="needSpecialReview" value="1" data-lb-flag />
                {t("quoteSpecialCheck")}</label
              >
              <label>
                {t("quoteSpecialNotes")}
                <textarea name="specialNotes" rows="2" placeholder={t("quoteSpecialNotesPh")}
                ></textarea>
              </label>
            </fieldset>

            <div class="lb__live">
              <p class="lb__live-label">{t("quoteLiveLabel")}</p>
              <p class="lb__live-total" data-lb-live-total>—</p>
              <ul class="lb__live-lines" data-lb-live-lines></ul>
              <p class="lb__live-hint" data-lb-live-hint></p>
            </div>

            {
              turnstileSiteKey ? (
                <div
                  class="cf-turnstile"
                  data-sitekey={turnstileSiteKey}
                  data-theme="dark"
                  data-size="flexible"
                />
              ) : null
            }

            <button type="submit" class="lb__btn lb__btn--solid">{t("quoteSubmit")}</button>
            <p class="lb__msg" data-lb-msg hidden></p>
          </form>
        </div>
        <p class="lb__text" data-lb-no-lic hidden>{t("libNoLicense")}</p>
      </div>
    </div>
  </div>
</div>

{
  turnstileSiteKey ? (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  ) : null
}

<script>
  import { bindLibraryBrowser } from "../lib/library-browser/bind";
  document.addEventListener("DOMContentLoaded", bindLibraryBrowser);
  document.addEventListener("astro:page-load", bindLibraryBrowser);
</script>

<style is:global>
  .lb__bar {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .lb__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .lb__chips--row {
    align-items: center;
  }
  .lb__chips--wrap {
    /* 2 filas naturales con wrap; crece si hay muchos moods/tags */
    max-width: 100%;
  }
  .lb__filter-block {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .lb__filter-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(201 169 98 / 0.85);
  }
  .lb__chip {
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    border: 1px solid rgb(255 255 255 / 0.12);
    background: rgb(20 20 24);
    color: rgb(180 180 190);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
  }
  .lb__chip.is-on {
    border-color: rgb(201 169 98 / 0.55);
    color: #e8c97a;
    background: rgb(201 169 98 / 0.12);
  }
  .lb__chip-empty {
    font-size: 0.78rem;
    color: rgb(120 120 130);
  }
  .lb__count {
    font-size: 0.8rem;
    color: rgb(140 140 150);
  }

  .lb__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10.5rem, 1fr));
    gap: 1.15rem 0.9rem;
    align-items: start;
  }

  .lb__card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
    background: transparent;
  }
  .lb__card.is-on .lb__thumb {
    border-color: rgb(201 169 98 / 0.65);
    box-shadow: 0 0 0 1px rgb(201 169 98 / 0.3);
  }

  .lb__thumb-wrap {
    position: relative;
  }

  .lb__thumb {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    margin: 0;
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: 10px;
    overflow: hidden;
    background: #0c0c10;
    cursor: pointer;
    color: inherit;
  }

  .lb__frame {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #0c0c10;
  }
  .lb__frame img,
  .lb__frame video,
  .lb__frame .lb__ph {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .lb__ph {
    width: 100%;
    height: 100%;
    min-height: 4rem;
    background: linear-gradient(145deg, #1c1c22, #0a0a0c);
  }

  .lb__play-fab {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    border: none;
    background: rgb(201 169 98 / 0.92);
    color: #0a0a0c;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.45);
  }
  .lb__play-fab:hover {
    filter: brightness(1.08);
  }
  .lb__play-fab[aria-pressed="true"] {
    background: rgb(240 220 160 / 0.98);
  }

  .lb__thumb-progress {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 5;
    height: 12px;
    background: rgb(0 0 0 / 0.45);
    pointer-events: auto;
    cursor: pointer;
    touch-action: none;
    border-radius: 0 0 9px 9px;
  }
  .lb__thumb-progress:hover {
    background: rgb(0 0 0 / 0.55);
  }
  .lb__thumb-progress::after {
    content: "";
    display: block;
    height: 100%;
    width: var(--p, 0%);
    background: var(--color-accent, #c9a962);
    box-shadow: 0 0 10px rgb(201 169 98 / 0.45);
    pointer-events: none;
  }

  .lb__protect {
    margin: 0.55rem 0 0.85rem;
    padding: 0.65rem 0.75rem;
    border-radius: 8px;
    border: 1px solid rgb(201 169 98 / 0.35);
    background: rgb(201 169 98 / 0.1);
    box-shadow: 0 0 20px rgb(201 169 98 / 0.15);
    font-size: 0.8rem;
    line-height: 1.45;
    color: #e8d5a0;
    max-width: 100%;
    box-sizing: border-box;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .lb__protect--lic {
    margin: 0 0 1rem;
  }
  .lb__transport {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin: 0.65rem 0 0.25rem;
  }
  .lb__progress {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .lb__seek {
    flex: 1;
    min-width: 0;
    height: 1.35rem;
    accent-color: var(--color-accent, #c9a962);
    cursor: pointer;
    touch-action: none;
  }
  .lb__seek:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .lb__time {
    flex-shrink: 0;
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    color: rgb(150 150 160);
    min-width: 5.5rem;
    text-align: right;
  }

  .lb__badge {
    position: absolute;
    top: 0.45rem;
    left: 0.45rem;
    z-index: 2;
    padding: 0.2rem 0.45rem;
    border-radius: 5px;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffb38a;
    background: rgb(40 18 10 / 0.92);
    border: 1px solid rgb(255 140 80 / 0.45);
  }
  .lb__badge--stem {
    left: auto;
    right: 0.45rem;
    color: #9dcea8;
    background: rgb(12 32 22 / 0.92);
    border-color: rgb(100 180 120 / 0.4);
  }
  .lb__badge--sold {
    top: auto;
    bottom: 0.45rem;
    left: 0.45rem;
    color: #ddd;
    background: rgb(30 30 35 / 0.92);
    border-color: rgb(120 120 130 / 0.5);
  }
  .lb__ratio {
    position: absolute;
    right: 0.4rem;
    bottom: 0.4rem;
    z-index: 2;
    font-size: 0.58rem;
    font-weight: 600;
    padding: 0.12rem 0.35rem;
    border-radius: 4px;
    background: rgb(0 0 0 / 0.7);
    color: rgb(160 160 170);
  }

  .lb__cap {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }
  .lb__cap strong {
    font-size: 0.88rem;
    font-weight: 600;
    color: #f0f0f2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .lb__cap span {
    font-size: 0.72rem;
    color: rgb(140 140 150);
  }
  .lb__card-lic {
    align-self: flex-start;
    margin-top: 0.25rem;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgb(201 169 98 / 0.45);
    background: transparent;
    color: #e8c97a;
    font: inherit;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .lb__card-lic:hover {
    background: rgb(201 169 98 / 0.12);
  }
  .lb__empty {
    grid-column: 1 / -1;
    color: rgb(140 140 150);
  }

  /* —— Modal overlay —— */
  .lb__overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 4vh 1rem 2rem;
    overflow: auto;
    background: rgb(0 0 0 / 0.72);
    backdrop-filter: blur(6px);
  }
  .lb__overlay[hidden] {
    display: none !important;
  }

  .lb__modal {
    position: relative;
    width: min(68rem, 100%);
    max-width: 100%;
    margin: auto;
    padding: 1.35rem 1.25rem 1.75rem;
    border-radius: 14px;
    border: 1px solid rgb(201 169 98 / 0.3);
    background: #121216;
    color: #e8e8ec;
    box-shadow: 0 24px 64px rgb(0 0 0 / 0.55);
    overflow-x: clip;
    box-sizing: border-box;
  }

  .lb__x {
    position: absolute;
    top: 0.65rem;
    right: 0.85rem;
    z-index: 2;
    border: none;
    background: transparent;
    color: rgb(150 150 160);
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
  }

  .lb__modal-grid {
    display: grid;
    gap: 1.75rem;
    padding-top: 0.5rem;
    min-width: 0;
    max-width: 100%;
  }
  .lb__modal-left,
  .lb__modal-right {
    min-width: 0;
    max-width: 100%;
  }
  @media (min-width: 900px) {
    .lb__modal-grid {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.15fr);
      align-items: start;
    }
  }

  .lb__kicker {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c9a962;
  }
  .lb__ptitle {
    margin: 0.35rem 2rem 0 0;
    font-family: var(--font-display, Georgia, serif);
    font-size: clamp(1.4rem, 2.5vw, 1.85rem);
    font-weight: 500;
    color: #f5f5f7;
  }
  .lb__prov-badge {
    display: inline-block;
    margin: 0.5rem 0 0;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #ffb38a;
    border: 1px solid rgb(255 140 80 / 0.4);
    background: rgb(50 22 12 / 0.9);
  }

  .lb__media {
    margin: 0.85rem 0 0.65rem;
  }
  .lb__panel-frame {
    width: 100%;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid rgb(255 255 255 / 0.08);
    background: #0a0a0c;
  }
  .lb__panel-frame--11 {
    aspect-ratio: 1 / 1;
    max-width: 280px;
  }
  .lb__panel-frame--916 {
    aspect-ratio: 9 / 16;
    max-width: 180px;
    max-height: 320px;
  }
  .lb__panel-frame--169 {
    aspect-ratio: 16 / 9;
    max-height: 200px;
  }
  .lb__panel-frame video,
  .lb__panel-frame img,
  .lb__panel-frame .lb__ph {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .lb__ph {
    width: 100%;
    height: 100%;
    min-height: 4rem;
    background: linear-gradient(145deg, #1c1c22, #0a0a0c);
  }

  .lb__label {
    margin: 0.75rem 0 0.3rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(130 130 140);
  }
  .lb__text {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: rgb(170 170 180);
  }
  .lb__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .lb__pills li {
    padding: 0.18rem 0.45rem;
    border-radius: 6px;
    font-size: 0.7rem;
    color: #c9a962;
    background: rgb(201 169 98 / 0.1);
  }
  .lb__mixer {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid rgb(255 255 255 / 0.08);
    background: #0a0a0c;
  }
  .lb__mix-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .lb__preview-mix {
    margin-top: 0.75rem;
