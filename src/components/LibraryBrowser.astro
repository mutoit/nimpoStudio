---
/**
 * Biblioteca: miniaturas en frame 1:1 + modal overlay (detalle, stems, licencia completa).
 * CSS is:global (HTML del grid vía JS).
 * Plan: docs/licencias/PLAN-BIBLIOTECA-Y-PRECIOS.md
 */
import type { LibraryItem } from "../lib/library";
import { getLibraryMoods } from "../lib/library";
import type { Locale } from "../i18n/translations";
import { useTranslations } from "../lib/locale";
import { LICENSE_PRICES, USAGE_CATALOG } from "../lib/license-quote";

interface Props {
  items: LibraryItem[];
  lang: Locale;
}

const { items, lang } = Astro.props;
const t = useTranslations(lang);
const allMoods = getLibraryMoods();

const usageLabelMap: Record<string, string> = {
  personal_private: t("usagePersonalPrivate"),
  film_short: t("usageFilmShort"),
  film_feature: t("usageFilmFeature"),
  series_one: t("usageSeriesOne"),
  series_multi: t("usageSeriesMulti"),
  brand_video: t("usageBrandVideo"),
  social_brand: t("usageSocialBrand"),
  podcast_one: t("usagePodcastOne"),
  ads_paid: t("usageAdsPaid"),
  game_indie: t("usageGameIndie"),
  game_liveops: t("usageGameLiveops"),
  app_one: t("usageAppOne"),
  app_saas: t("usageAppSaas"),
  install_one: t("usageInstallOne"),
  tour_event: t("usageTourEvent"),
  exclusive_scope: t("usageExclusive"),
  buyout: t("usageBuyout"),
  other: t("usageOther"),
};

const usageGroups = [
  { id: "personal", label: t("usageGroupPersonal") },
  { id: "audiovisual", label: t("usageGroupAudiovisual") },
  { id: "ads", label: t("usageGroupAds") },
  { id: "interactive", label: t("usageGroupInteractive") },
  { id: "live", label: t("usageGroupLive") },
  { id: "special", label: t("usageGroupSpecial") },
];

const P = LICENSE_PRICES;
const turnstileSiteKey = (import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "").trim();

/** Extras del cotizador: título + hint (hover/title) + precio */
const licenseExtras: {
  name: string;
  title: string;
  hint: string;
  price: string;
}[] = [
  { name: "stems", title: t("quoteStems"), hint: t("quoteStemsHint"), price: `+${P.stems} €` },
  { name: "editShort", title: t("quoteEdit"), hint: t("quoteEditHint"), price: `+${P.editShort} €` },
  {
    name: "termPlus1y",
    title: t("quoteTermPlus1y"),
    hint: t("quoteTermPlus1yHint"),
    price: `+${P.termPlus1yCommercial} / +${P.termPlus1yExclusive} €`,
  },
  {
    name: "territoryExpand",
    title: t("quoteTerritoryExpand"),
    hint: t("quoteTerritoryExpandHint"),
    price: `+${P.territoryExpand} €`,
  },
  {
    name: "moreComposition",
    title: t("quoteMoreComposition"),
    hint: t("quoteMoreCompositionHint"),
    price: `+${P.moreComposition} €`,
  },
  {
    name: "exclusive",
    title: t("quoteExclusive"),
    hint: t("quoteExclusiveHint"),
    price: `${t("musicLicensePriceFrom")} ${P.exclusiveFrom} €`,
  },
  {
    name: "exclusiveStrong",
    title: t("quoteExclusiveStrong"),
    hint: t("quoteExclusiveStrongHint"),
    price: `${t("musicLicensePriceFrom")} ${P.exclusiveStrongFrom} €`,
  },
  {
    name: "removeFromCatalog",
    title: t("quoteRemoveFromCatalog"),
    hint: t("quoteRemoveFromCatalogHint"),
    price: `+${P.removeFromCatalog} €`,
  },
  {
    name: "buyout",
    title: t("quoteBuyout"),
    hint: t("quoteBuyoutHint"),
    price: `${t("musicLicensePriceFrom")} ${P.buyoutFrom} €`,
  },
  {
    name: "buyoutHigh",
    title: t("quoteBuyoutHigh"),
    hint: t("quoteBuyoutHighHint"),
    price: `${t("musicLicensePriceFrom")} ${P.buyoutHighFrom} €`,
  },
];

const payload = {
  items,
  lang,
  moods: allMoods,
  labels: {
    all: t("libFilterAll"),
    video11: t("libFilter11"),
    video916: t("libFilter916"),
    stems: t("libFilterStems"),
    license: t("musicLicenseOpen"),
    provisional: t("badgeProvisionalShort"),
    empty: t("libEmpty"),
    play: t("libPlay"),
    stop: "❚❚",
    close: t("libClose"),
    from: t("musicLicensePriceFrom"),
    review: t("musicLicensePriceOnRequest"),
    select: t("quoteSelect"),
    unavailable: t("libUnavailable"),
    noLicense: t("libNoLicense"),
    reviewsTitle: t("reviewsTitle"),
    reviewsCount: t("reviewsCount"),
    reviewsEmpty: t("reviewsEmpty"),
    reviewsYourRating: t("reviewsYourRating"),
    reviewsNamePh: t("reviewsNamePh"),
    reviewsCommentPh: t("reviewsCommentPh"),
    reviewsSubmit: t("reviewsSubmit"),
    reviewsSubmitNote: t("reviewsSubmitNote"),
  },
};
---

<div class="lb" data-library-root data-payload={JSON.stringify(payload)}>
  <div class="lb__bar" role="toolbar" aria-label={t("libFilters")}>
    <div class="lb__chips lb__chips--row" data-lb-types>
      <button type="button" class="lb__chip is-on" data-type="all">{t("libFilterAll")}</button>
      <button type="button" class="lb__chip" data-type="stems">{t("libFilterStems")}</button>
    </div>
    <div class="lb__filter-block">
      <span class="lb__filter-label">{t("libMoods")}</span>
      <div class="lb__chips lb__chips--wrap" data-lb-moods></div>
    </div>
    <span class="lb__count" data-lb-count></span>
  </div>

  <div class="lb__grid" data-lb-grid></div>

  <!-- Modal encima del catálogo -->
  <div class="lb__overlay" data-lb-overlay hidden>
    <div class="lb__modal" role="dialog" aria-modal="true" data-lb-modal>
      <button type="button" class="lb__x" data-lb-close aria-label={t("libClose")}>×</button>

      <div class="lb__modal-grid">
        <div class="lb__modal-left">
          <p class="lb__kicker" data-lb-kicker></p>
          <h2 class="lb__ptitle" data-lb-title></h2>
          <p class="lb__prov-badge" data-lb-prov hidden></p>
          <div class="lb__media" data-lb-media></div>
          <div class="lb__transport" data-lb-transport>
            <button type="button" class="lb__btn" data-lb-preview-play>{t("libPlay")}</button>
            <div class="lb__progress" data-lb-progress>
              <input
                type="range"
                class="lb__seek"
                data-lb-seek
                min="0"
                max="1000"
                value="0"
                step="1"
                aria-label="Progreso"
              />
              <span class="lb__time" data-lb-time>0:00 / --:--</span>
            </div>
          </div>
          <p class="lb__protect" role="note">{t("libPreviewProtect")}</p>

          {/* Valoraciones: UI es/en/fr; lista de comentarios 1 sola (común, sin fakes) */}
          <section class="lb__reviews" data-lb-reviews aria-label={t("reviewsTitle")}>
            <div class="lb__reviews-head">
              <p class="lb__label lb__label--tight">{t("reviewsTitle")}</p>
              <div class="lb__reviews-score" data-lb-reviews-score>
                <span class="lb__reviews-num" data-lb-reviews-avg>—</span>
                <span class="lb__reviews-stars" data-lb-reviews-stars aria-hidden="true">☆☆☆☆☆</span>
                <span class="lb__reviews-count" data-lb-reviews-count>{t("reviewsCount").replace("{n}", "0")}</span>
              </div>
            </div>
            <div class="lb__reviews-rate" data-lb-reviews-rate role="group" aria-label={t("reviewsYourRating")}>
              <button type="button" class="lb__star-btn" data-rate="1" aria-label="1">★</button>
              <button type="button" class="lb__star-btn" data-rate="2" aria-label="2">★</button>
              <button type="button" class="lb__star-btn" data-rate="3" aria-label="3">★</button>
              <button type="button" class="lb__star-btn" data-rate="4" aria-label="4">★</button>
              <button type="button" class="lb__star-btn" data-rate="5" aria-label="5">★</button>
            </div>
            <div class="lb__reviews-scroll" data-lb-reviews-list tabindex="0">
              <p class="lb__reviews-empty">{t("reviewsEmpty")}</p>
            </div>
            <form class="lb__reviews-form" data-lb-reviews-form>
              <input type="hidden" name="rating" value="" data-lb-reviews-rating />
              <input type="text" name="name" maxlength="40" placeholder={t("reviewsNamePh")} autocomplete="nickname" />
              <textarea name="comment" rows="2" maxlength="280" placeholder={t("reviewsCommentPh")}></textarea>
              <button type="submit" class="lb__btn lb__btn--ghost" disabled>{t("reviewsSubmit")}</button>
              <p class="lb__reviews-note">{t("reviewsSubmitNote")}</p>
            </form>
          </section>

          <p class="lb__label">{t("libDescription")}</p>
          <p class="lb__text" data-lb-desc></p>
          <p class="lb__label">{t("libNotes")}</p>
          <p class="lb__text" data-lb-notes></p>
          <p class="lb__label">{t("libMoods")}</p>
          <ul class="lb__pills" data-lb-mood-pills></ul>
          <div data-lb-stems-wrap hidden>
            <p class="lb__label">{t("libStemsTitle")}</p>
            <div class="lb__mixer" data-lb-mixer></div>
          </div>
        </div>

        <div class="lb__modal-right" data-lb-lic-wrap hidden>
          <h3 class="lb__form-title">{t("quoteFormTitle")}</h3>
          <p class="lb__form-lead">{t("quoteFormLead")}</p>
          <p class="lb__protect lb__protect--lic" role="note">{t("musicLicensePreviewNote")}</p>

          <form class="lb__form" data-lb-form>
            <input type="hidden" name="workSlug" />
            <input type="hidden" name="workName" />

            <div class="lb__form-row">
              <label
                >{t("quoteName")}<input name="name" required autocomplete="name" /></label
              >
              <label
                >{t("quoteEmail")}<input
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                /></label
              >
            </div>
            <label
              >{t("quoteCompany")}<input
                name="company"
                autocomplete="organization"
                placeholder={t("quoteCompanyPh")}
              /></label
            >

            <div class="lb__usage" data-lb-usage-dd>
              <span class="lb__usage-label" id="lb-usage-label">{t("quoteUsageType")}</span>
              {/* Escritorio: select nativo. Móvil: se oculta y manda el valor del desplegable */}
              <select name="usage" required data-lb-usage class="lb__usage-select">
                <option value="">{t("quoteSelect")}</option>
                {
                  usageGroups.map((g) => (
                    <optgroup label={g.label}>
                      {USAGE_CATALOG.filter((u) => u.group === g.id).map((u) => (
                        <option value={u.code}>{usageLabelMap[u.code]}</option>
                      ))}
                    </optgroup>
                  ))
                }
              </select>
              {/* Móvil: menú plegable (como el select de plazo) + lista densa al abrir */}
              <button
                type="button"
                class="lb__usage-trigger"
                data-lb-usage-trigger
                aria-expanded="false"
                aria-controls="lb-usage-panel"
                aria-labelledby="lb-usage-label"
              >
                <span class="lb__usage-trigger-text" data-lb-usage-value>{t("quoteSelect")}</span>
                <span class="lb__usage-trigger-price" data-lb-usage-price hidden></span>
                <span class="lb__usage-chevron" aria-hidden="true">▾</span>
              </button>
              <div
                class="lb__usage-panel"
                id="lb-usage-panel"
                data-lb-usage-list
                hidden
                role="listbox"
                aria-labelledby="lb-usage-label"
              >
                {
                  usageGroups.map((g) => (
                    <div class="lb__usage-group">
                      <p class="lb__usage-group-title">{g.label}</p>
                      {USAGE_CATALOG.filter((u) => u.group === g.id).map((u) => {
                        const full = usageLabelMap[u.code] || u.code;
                        const title = full.split("—")[0].split(" - ")[0].trim();
                        const priceMatch = full.match(
                          /(?:desde|from|dès)\s*[\d.,\s]+\s*€[^)]*|micro\s*[\d.,]+\s*€|según plazo|by term|selon durée/i,
                        );
                        const price = priceMatch
                          ? priceMatch[0].trim()
                          : lang === "en"
                            ? "by term"
                            : lang === "fr"
                              ? "selon durée"
                              : "según plazo";
                        const hint =
                          u.code === "ads_paid" ? t("usageAdsPaidHint") : full;
                        return (
                          <button
                            type="button"
                            class="lb__usage-row"
                            role="option"
                            data-lb-usage-option
                            data-value={u.code}
                            data-title={title}
                            data-price={price}
                            title={hint}
                          >
                            <span class="lb__usage-row-title">{title}</span>
                            <span class="lb__usage-row-price">{price}</span>
                          </button>
                        );
                      })}
                    </div>
                  ))
                }
              </div>
            </div>

            <div class="lb__form-row">
              <label
                >{t("quoteTerritory")}<input
                  name="territory"
                  required
                  placeholder="ES / EU / mundial"
                /></label
              >
              <div class="lb__term" data-lb-term-dd>
                <span class="lb__term-label" id="lb-term-label">{t("quoteTerm")}</span>
                <select name="term" data-lb-term class="lb__term-select">
                  <option value="single">{t("quoteTermSingle")}</option>
                  <option value="1y">{t("quoteTerm1y")}</option>
                  <option value="project">{t("quoteTermProject")}</option>
                  <option value="2y" selected>{t("quoteTerm2y")}</option>
                  <option value="custom">{t("quoteTermCustom")}</option>
                </select>
                <button
                  type="button"
                  class="lb__term-trigger"
                  data-lb-term-trigger
                  aria-expanded="false"
                  aria-controls="lb-term-panel"
                  aria-labelledby="lb-term-label"
                >
                  <span class="lb__term-trigger-text" data-lb-term-value
                    >{t("quoteTerm2y").split("—")[0].trim()}</span
                  >
                  {
                    (() => {
                      const p = t("quoteTerm2y").match(/[\d.,\s]+\s*€|€\s*[\d.,]+/i);
                      return p ? (
                        <span class="lb__term-trigger-price" data-lb-term-price>
                          {p[0].trim()}
                        </span>
                      ) : (
                        <span class="lb__term-trigger-price" data-lb-term-price hidden></span>
                      );
                    })()
                  }
                  <span class="lb__term-chevron" aria-hidden="true">▾</span>
                </button>
                <div
                  class="lb__term-panel"
                  id="lb-term-panel"
                  data-lb-term-list
                  hidden
                  role="listbox"
                  aria-labelledby="lb-term-label"
                >
                  {
                    (
                      [
                        { value: "single", full: t("quoteTermSingle") },
                        { value: "1y", full: t("quoteTerm1y") },
                        { value: "project", full: t("quoteTermProject") },
                        { value: "2y", full: t("quoteTerm2y") },
                        { value: "custom", full: t("quoteTermCustom") },
                      ] as const
                    ).map((opt) => {
                      const title = opt.full.split("—")[0].split(" - ")[0].trim();
                      const priceMatch = opt.full.match(/[\d.,\s]+\s*€|€\s*[\d.,]+/i);
                      const price = priceMatch ? priceMatch[0].trim() : "";
                      return (
                        <button
                          type="button"
                          class:list={["lb__term-row", { "is-on": opt.value === "2y" }]}
                          role="option"
                          data-lb-term-option
                          data-value={opt.value}
                          data-title={title}
                          data-price={price}
                        >
                          <span class="lb__term-row-title">{title}</span>
                          {price ? <span class="lb__term-row-price">{price}</span> : null}
                        </button>
                      );
                    })
                  }
                </div>
              </div>
            </div>

            <label>
              {t("quoteProject")}
              <textarea name="project" rows="2" required placeholder={t("quoteProjectPh")}
              ></textarea>
            </label>

            <fieldset class="lb__fieldset lb__optlist">
              <legend>{t("quoteExtras")}</legend>
              {
                licenseExtras.map((ex) => (
                  <label class="lb__opt">
                    <input type="checkbox" name={ex.name} value="1" data-lb-flag />
                    <span class="lb__opt-title">
                      {ex.title}
                      <span
                        class="lb__opt-help"
                        data-tip={ex.hint}
                        role="img"
                        aria-label={ex.hint}
                      >
                        ?
                      </span>
                    </span>
                    <span class="lb__opt-price">{ex.price}</span>
                  </label>
                ))
              }
            </fieldset>

            <fieldset class="lb__fieldset lb__fieldset--special lb__optlist">
              <legend>{t("quoteSpecialLegend")}</legend>
              <p class="lb__help">{t("quoteSpecialHelp")}</p>
              <label class="lb__opt">
                <input type="checkbox" name="needSpecialReview" value="1" data-lb-flag />
                <span class="lb__opt-title">{t("quoteSpecialCheck")}</span>
              </label>
              <label class="lb__opt-notes">
                {t("quoteSpecialNotes")}
                <textarea name="specialNotes" rows="2" placeholder={t("quoteSpecialNotesPh")}
                ></textarea>
              </label>
            </fieldset>

            <div class="lb__live">
              <p class="lb__live-label">{t("quoteLiveLabel")}</p>
              <p class="lb__live-total" data-lb-live-total>—</p>
              <ul class="lb__live-lines" data-lb-live-lines></ul>
              <p class="lb__live-hint" data-lb-live-hint></p>
            </div>

            {
              turnstileSiteKey ? (
                <div
                  class="cf-turnstile"
                  data-sitekey={turnstileSiteKey}
                  data-theme="dark"
                  data-size="flexible"
                />
              ) : null
            }

            <button type="submit" class="lb__btn lb__btn--solid">{t("quoteSubmit")}</button>
            <p class="lb__msg" data-lb-msg hidden></p>
          </form>
        </div>
        <p class="lb__text" data-lb-no-lic hidden>{t("libNoLicense")}</p>
      </div>
    </div>
  </div>
</div>

{
  turnstileSiteKey ? (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  ) : null
}

<script>
  import { bindLibraryBrowser } from "../lib/library-browser/bind";
  document.addEventListener("DOMContentLoaded", bindLibraryBrowser);
  document.addEventListener("astro:page-load", bindLibraryBrowser);
</script>

<style is:global>
  .lb__bar {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .lb__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .lb__chips--row {
    align-items: center;
  }
  .lb__chips--wrap {
    /* 2 filas naturales con wrap; crece si hay muchos moods/tags */
    max-width: 100%;
  }
  .lb__filter-block {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .lb__filter-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(201 169 98 / 0.85);
  }
  .lb__chip {
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    border: 1px solid rgb(255 255 255 / 0.12);
    background: rgb(20 20 24);
    color: rgb(180 180 190);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
  }
  .lb__chip.is-on {
    border-color: rgb(201 169 98 / 0.55);
    color: #e8c97a;
    background: rgb(201 169 98 / 0.12);
  }
  .lb__chip-empty {
    font-size: 0.78rem;
    color: rgb(120 120 130);
  }
  .lb__count {
    font-size: 0.8rem;
    color: rgb(140 140 150);
  }

  .lb__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10.5rem, 1fr));
    gap: 1.15rem 0.9rem;
    align-items: start;
  }

  .lb__card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
    background: transparent;
  }
  .lb__card.is-on .lb__thumb {
    border-color: rgb(201 169 98 / 0.65);
    box-shadow: 0 0 0 1px rgb(201 169 98 / 0.3);
  }

  .lb__thumb-wrap {
    position: relative;
  }

  .lb__thumb {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    margin: 0;
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: 10px;
    overflow: hidden;
    background: #0c0c10;
    cursor: pointer;
    color: inherit;
  }

  .lb__frame {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #0c0c10;
  }
  .lb__frame img,
  .lb__frame video,
  .lb__frame .lb__ph {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .lb__ph {
    width: 100%;
    height: 100%;
    min-height: 4rem;
    background: linear-gradient(145deg, #1c1c22, #0a0a0c);
  }

  .lb__play-fab {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    border: none;
    background: rgb(201 169 98 / 0.92);
    color: #0a0a0c;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.45);
  }
  .lb__play-fab:hover {
    filter: brightness(1.08);
  }
  .lb__play-fab[aria-pressed="true"] {
    background: rgb(240 220 160 / 0.98);
  }

  .lb__thumb-progress {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 5;
    height: 12px;
    background: rgb(0 0 0 / 0.45);
    pointer-events: auto;
    cursor: pointer;
    touch-action: none;
    border-radius: 0 0 9px 9px;
  }
  .lb__thumb-progress:hover {
    background: rgb(0 0 0 / 0.55);
  }
  .lb__thumb-progress::after {
    content: "";
    display: block;
    height: 100%;
    width: var(--p, 0%);
    background: var(--color-accent, #c9a962);
    box-shadow: 0 0 10px rgb(201 169 98 / 0.45);
    pointer-events: none;
  }

  .lb__protect {
    margin: 0.55rem 0 0.85rem;
    padding: 0.65rem 0.75rem;
    border-radius: 8px;
    border: 1px solid rgb(201 169 98 / 0.35);
    background: rgb(201 169 98 / 0.1);
    box-shadow: 0 0 20px rgb(201 169 98 / 0.15);
    font-size: 0.8rem;
    line-height: 1.45;
    color: #e8d5a0;
    max-width: 100%;
    box-sizing: border-box;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .lb__protect--lic {
    margin: 0 0 1rem;
  }
  .lb__transport {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin: 0.65rem 0 0.25rem;
  }
  .lb__progress {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .lb__seek {
    flex: 1;
    min-width: 0;
    height: 1.35rem;
    accent-color: var(--color-accent, #c9a962);
    cursor: pointer;
    touch-action: none;
  }
  .lb__seek:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .lb__time {
    flex-shrink: 0;
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    color: rgb(150 150 160);
    min-width: 5.5rem;
    text-align: right;
  }

  .lb__badge {
    position: absolute;
    top: 0.45rem;
    left: 0.45rem;
    z-index: 2;
    padding: 0.2rem 0.45rem;
    border-radius: 5px;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffb38a;
    background: rgb(40 18 10 / 0.92);
    border: 1px solid rgb(255 140 80 / 0.45);
  }
  .lb__badge--stem {
    left: auto;
    right: 0.45rem;
    color: #9dcea8;
    background: rgb(12 32 22 / 0.92);
    border-color: rgb(100 180 120 / 0.4);
  }
  .lb__badge--sold {
    top: auto;
    bottom: 0.45rem;
    left: 0.45rem;
    color: #ddd;
    background: rgb(30 30 35 / 0.92);
    border-color: rgb(120 120 130 / 0.5);
  }
  .lb__ratio {
    position: absolute;
    right: 0.4rem;
    bottom: 0.4rem;
    z-index: 2;
    font-size: 0.58rem;
    font-weight: 600;
    padding: 0.12rem 0.35rem;
    border-radius: 4px;
    background: rgb(0 0 0 / 0.7);
    color: rgb(160 160 170);
  }

  .lb__cap {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }
  .lb__cap strong {
    font-size: 0.88rem;
    font-weight: 600;
    color: #f0f0f2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .lb__cap span {
    font-size: 0.72rem;
    color: rgb(140 140 150);
  }
  .lb__card-lic {
    align-self: flex-start;
    margin-top: 0.25rem;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgb(201 169 98 / 0.45);
    background: transparent;
    color: #e8c97a;
    font: inherit;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .lb__card-lic:hover {
    background: rgb(201 169 98 / 0.12);
  }
  .lb__empty {
    grid-column: 1 / -1;
    color: rgb(140 140 150);
  }

  /* —— Modal overlay —— */
  .lb__overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 4vh 1rem 2rem;
    overflow: auto;
    background: rgb(0 0 0 / 0.72);
    backdrop-filter: blur(6px);
  }
  .lb__overlay[hidden] {
    display: none !important;
  }

  .lb__modal {
    position: relative;
    width: min(68rem, 100%);
    max-width: 100%;
    margin: auto;
    padding: 1.35rem 1.25rem 1.75rem;
    border-radius: 14px;
    border: 1px solid rgb(201 169 98 / 0.3);
    background: #121216;
    color: #e8e8ec;
    box-shadow: 0 24px 64px rgb(0 0 0 / 0.55);
    overflow-x: clip;
    box-sizing: border-box;
  }

  .lb__x {
    position: absolute;
    top: 0.65rem;
    right: 0.85rem;
    z-index: 2;
    border: none;
    background: transparent;
    color: rgb(150 150 160);
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
  }

  .lb__modal-grid {
    display: grid;
    gap: 1.75rem;
    padding-top: 0.5rem;
    min-width: 0;
    max-width: 100%;
  }
  .lb__modal-left,
  .lb__modal-right {
    min-width: 0;
    max-width: 100%;
  }
  @media (min-width: 900px) {
    .lb__modal-grid {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.15fr);
      align-items: start;
    }
  }

  .lb__kicker {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c9a962;
  }
  .lb__ptitle {
    margin: 0.35rem 2rem 0 0;
    font-family: var(--font-display, Georgia, serif);
    font-size: clamp(1.4rem, 2.5vw, 1.85rem);
    font-weight: 500;
    color: #f5f5f7;
  }
  .lb__prov-badge {
    display: inline-block;
    margin: 0.5rem 0 0;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #ffb38a;
    border: 1px solid rgb(255 140 80 / 0.4);
    background: rgb(50 22 12 / 0.9);
  }

  /* Valoraciones dentro del modal del sonido */
  .lb__reviews {
    margin: 1rem 0 0;
    padding: 0.85rem 0.9rem 0.95rem;
    border-radius: 10px;
    border: 1px solid rgb(201 169 98 / 0.28);
    background: linear-gradient(165deg, rgb(201 169 98 / 0.07) 0%, rgb(18 18 22 / 0.95) 50%);
  }
  .lb__reviews-head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.65rem 1rem;
    margin-bottom: 0.55rem;
  }
  .lb__label--tight {
    margin-bottom: 0.25rem;
  }
  .lb__reviews-empty {
    margin: 0;
    padding: 0.5rem 0.15rem;
    font-size: 0.8rem;
    color: rgb(120 120 130);
    line-height: 1.4;
  }
  .lb__reviews-score {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.45rem;
    text-align: right;
  }
  .lb__reviews-num {
    font-family: var(--font-display, Georgia, serif);
    font-size: 1.65rem;
    font-weight: 500;
    line-height: 1;
    color: #f5f5f7;
  }
  .lb__reviews-stars {
    color: #c9a962;
    letter-spacing: 0.04em;
    font-size: 0.95rem;
  }
  .lb__reviews-count {
    width: 100%;
    font-size: 0.72rem;
    color: rgb(140 140 150);
  }
  .lb__reviews-rate {
    display: flex;
    gap: 0.15rem;
    margin-bottom: 0.65rem;
  }
  .lb__star-btn {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0.1rem 0.15rem;
    color: rgb(70 70 78);
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.12s, transform 0.12s;
  }
  .lb__star-btn:hover,
  .lb__star-btn.is-on {
    color: #c9a962;
  }
  .lb__star-btn:hover {
    transform: scale(1.08);
  }
  .lb__reviews-scroll {
    max-height: 9.5rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    margin-bottom: 0.7rem;
    padding-right: 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    scrollbar-width: thin;
    scrollbar-color: rgb(201 169 98 / 0.4) transparent;
  }
  .lb__review-item {
    padding: 0.55rem 0.65rem;
    border-radius: 8px;
    border: 1px solid rgb(255 255 255 / 0.08);
    background: rgb(10 10 12 / 0.65);
  }
  .lb__review-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem 0.5rem;
    font-size: 0.78rem;
  }
  .lb__review-name {
    font-weight: 600;
    color: #eeeef2;
  }
  .lb__review-stars {
    color: #c9a962;
    letter-spacing: 0.03em;
    font-size: 0.75rem;
  }
  .lb__review-use {
    padding: 0.08rem 0.35rem;
    border-radius: 999px;
    background: rgb(201 169 98 / 0.12);
    color: #9a7d3c;
    font-size: 0.62rem;
    font-weight: 700;
  }
  .lb__review-text {
    margin: 0.3rem 0 0;
    font-size: 0.8rem;
    line-height: 1.45;
    color: rgb(160 160 170);
  }
  .lb__reviews-form {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .lb__reviews-form input,
  .lb__reviews-form textarea {
    width: 100%;
    padding: 0.45rem 0.55rem;
    border-radius: 6px;
    border: 1px solid rgb(255 255 255 / 0.1);
    background: #0a0a0c;
    color: #e8e8ec;
    font: inherit;
    font-size: 0.82rem;
  }
  .lb__reviews-form textarea {
    resize: vertical;
    min-height: 2.8rem;
    line-height: 1.4;
  }
  .lb__btn--ghost {
    opacity: 0.75;
    cursor: not-allowed;
  }
  .lb__reviews-note {
    margin: 0;
    font-size: 0.65rem;
    color: rgb(120 120 130);
    line-height: 1.35;
  }

  .lb__media {
    margin: 0.85rem 0 0.65rem;
  }
  .lb__panel-frame {
    width: 100%;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid rgb(255 255 255 / 0.08);
    background: #0a0a0c;
  }
  .lb__panel-frame--11 {
    aspect-ratio: 1 / 1;
    max-width: 280px;
  }
  .lb__panel-frame--916 {
    aspect-ratio: 9 / 16;
    max-width: 180px;
    max-height: 320px;
  }
  .lb__panel-frame--169 {
    aspect-ratio: 16 / 9;
    max-height: 200px;
  }
  .lb__panel-frame video,
  .lb__panel-frame img,
  .lb__panel-frame .lb__ph {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .lb__ph {
    width: 100%;
    height: 100%;
    min-height: 4rem;
    background: linear-gradient(145deg, #1c1c22, #0a0a0c);
  }

  .lb__label {
    margin: 0.75rem 0 0.3rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(130 130 140);
  }
  .lb__text {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: rgb(170 170 180);
  }
  .lb__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .lb__pills li {
    padding: 0.18rem 0.45rem;
    border-radius: 6px;
    font-size: 0.7rem;
    color: #c9a962;
    background: rgb(201 169 98 / 0.1);
  }
  .lb__mixer {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid rgb(255 255 255 / 0.08);
    background: #0a0a0c;
  }
  .lb__mix-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    cursor: pointer;
    padding: 0.2rem 0.35rem;
    border-radius: 6px;
    user-select: none;
    transition: background 0.12s, box-shadow 0.12s;
  }
  .lb__mix-row:hover {
    background: rgb(255 255 255 / 0.04);
  }
  .lb__mix-row.is-solo {
    background: rgb(201 169 98 / 0.12);
    box-shadow: inset 0 0 0 1px rgb(201 169 98 / 0.35);
  }
  .lb__mix-row.is-solo .lb__mix-label {
    color: #e8c97a;
    font-weight: 600;
  }
  .lb__mix-label {
    min-width: 0;
  }
  .lb__mix-hint {
    margin: 0.55rem 0 0;
    padding: 0.4rem 0.5rem;
    border-radius: 6px;
    border: 1px solid rgb(255 255 255 / 0.08);
    background: rgb(255 255 255 / 0.03);
    font-size: 0.72rem;
    line-height: 1.4;
    color: rgb(150 150 160);
  }
  .lb__preview-mix {
    margin-top: 0.75rem;
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid rgb(201 169 98 / 0.22);
    background: rgb(201 169 98 / 0.06);
  }
  .lb__help-mini {
    margin: 0 0 0.55rem;
    font-size: 0.72rem;
    line-height: 1.4;
    color: rgb(150 150 160);
  }
  .lb__mix-slider {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.45rem;
    font-size: 0.8rem;
    color: #c8c8d0;
  }
  .lb__mix-slider span {
    display: flex;
    justify-content: space-between;
  }
  .lb__mix-slider em {
    font-style: normal;
    color: #c9a962;
    font-variant-numeric: tabular-nums;
  }
  .lb__mix-slider input[type="range"] {
    width: 100%;
    accent-color: #c9a962;
    height: 0.45rem;
  }
  .lb__btn {
    margin-top: 0.55rem;
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
    border: 1px solid rgb(201 169 98 / 0.4);
    background: transparent;
    color: #e8c97a;
    font: inherit;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
  }
  .lb__btn--solid {
    background: #c9a962;
    color: #0a0a0c;
    border-color: transparent;
    width: auto;
    min-width: 11rem;
    max-width: 100%;
    padding: 0.45rem 1rem;
    font-size: 0.8rem;
  }

  .lb__modal-right {
    padding: 1.15rem 1.2rem 1.35rem;
    border-radius: 12px;
    border: 1px solid rgb(201 169 98 / 0.3);
    background: rgb(8 8 10 / 0.75);
    overflow-x: clip;
    box-sizing: border-box;
  }
  .lb__form-title {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 600;
  }
  .lb__form-lead {
    margin: 0.45rem 0 1rem;
    font-size: 0.88rem;
    line-height: 1.55;
    color: rgb(160 160 170);
  }
  .lb__form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
    max-width: 100%;
  }
  .lb__form-row {
    display: grid;
    gap: 0.75rem;
    min-width: 0;
    grid-template-columns: 1fr;
  }
  /* Dos columnas solo si hay sitio real (no solo min-width de viewport con UI L) */
  @media (min-width: 720px) {
    .lb__form-row {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
  }
  .lb__form label {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
    max-width: 100%;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgb(150 150 160);
  }
  .lb__form input,
  .lb__form select,
  .lb__form textarea {
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    font: inherit;
    font-weight: 400;
    font-size: 0.9rem;
    color: #f0f0f2;
    padding: 0.55rem 0.65rem;
    border-radius: 8px;
    border: 1px solid rgb(255 255 255 / 0.12);
    background: #0a0a0c;
  }
  .lb__form select {
    /* Texto largo en plazos/uso: no reventar el frame en M/L */
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }

  /* Uso / plazo: desplegable estilo formulario + precio en etiqueta dorada (desktop y móvil) */
  .lb__usage,
  .lb__term {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
    position: relative;
  }
  .lb__usage-label,
  .lb__term-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgb(150 150 160);
  }
  /* Select nativo solo para valor del form (accesible / submit) */
  .lb__usage-select,
  .lb__term-select {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    opacity: 0;
    pointer-events: none;
  }
  .lb__usage-trigger,
  .lb__term-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    min-height: 2.5rem;
    margin: 0;
    padding: 0.45rem 0.65rem;
    border-radius: 8px;
    border: 1px solid rgb(255 255 255 / 0.12);
    background: #0a0a0c;
    color: #f0f0f2;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 400;
    text-align: left;
    cursor: pointer;
  }
  .lb__usage-trigger:hover,
  .lb__term-trigger:hover {
    border-color: rgb(201 169 98 / 0.35);
  }
  .lb__usage-trigger-text,
  .lb__term-trigger-text {
    min-width: 0;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .lb__usage-trigger-price,
  .lb__term-trigger-price {
    flex-shrink: 0;
    font-size: 0.68rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    color: #e8c97a;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    background: rgb(201 169 98 / 0.14);
    border: 1px solid rgb(201 169 98 / 0.35);
    box-shadow: 0 0 12px rgb(201 169 98 / 0.12);
  }
  .lb__usage-trigger-price[hidden],
  .lb__term-trigger-price[hidden] {
    display: none !important;
  }
  .lb__usage-chevron,
  .lb__term-chevron {
    flex-shrink: 0;
    font-size: 0.7rem;
    color: rgb(150 150 160);
    transition: transform 0.15s;
  }
  .lb__usage.is-open .lb__usage-chevron,
  .lb__term.is-open .lb__term-chevron {
    transform: rotate(180deg);
    color: #c9a962;
  }
  .lb__usage.is-open .lb__usage-trigger,
  .lb__term.is-open .lb__term-trigger {
    border-color: rgb(201 169 98 / 0.45);
  }
  .lb__usage-panel,
  .lb__term-panel {
    display: none;
    flex-direction: column;
    margin-top: 0.35rem;
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: 8px;
    overflow: hidden;
    background: #0a0a0c;
    max-height: 16rem;
    overflow-y: auto;
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.45);
  }
  .lb__usage-panel:not([hidden]),
  .lb__term-panel:not([hidden]) {
    display: flex;
  }
  .lb__usage-group {
    margin: 0;
  }
  .lb__usage-group-title {
    margin: 0;
    padding: 0.4rem 0.65rem 0.25rem;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(201 169 98 / 0.9);
    background: rgb(201 169 98 / 0.08);
    border-bottom: 1px solid rgb(255 255 255 / 0.05);
  }
  .lb__usage-row,
  .lb__term-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 0.65rem;
    width: 100%;
    margin: 0;
    padding: 0.55rem 0.7rem;
    border: none;
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
    border-radius: 0;
    background: transparent;
    font: inherit;
    font-size: 0.85rem;
    font-weight: 400;
    color: #e8e8ec;
    text-align: left;
    cursor: pointer;
    line-height: 1.3;
    min-height: 2.5rem;
  }
  .lb__usage-group:last-child .lb__usage-row:last-child,
  .lb__term-row:last-child {
    border-bottom: none;
  }
  .lb__usage-row:hover,
  .lb__usage-row.is-on,
  .lb__term-row:hover,
  .lb__term-row.is-on {
    background: rgb(201 169 98 / 0.1);
  }
  .lb__usage-row-title,
  .lb__term-row-title {
    min-width: 0;
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.3;
  }
  .lb__usage-row-price,
  .lb__term-row-price {
    justify-self: end;
    flex-shrink: 0;
    font-size: 0.68rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    color: #e8c97a;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    background: rgb(201 169 98 / 0.14);
    border: 1px solid rgb(201 169 98 / 0.35);
    box-shadow: 0 0 12px rgb(201 169 98 / 0.12);
  }
  .lb__fieldset {
    margin: 0;
    padding: 0.85rem 1rem;
    border-radius: 10px;
    border: 1px solid rgb(255 255 255 / 0.1);
  }
  .lb__fieldset--special {
    border-color: rgb(201 120 80 / 0.35);
    background: rgb(201 120 80 / 0.06);
  }
  .lb__fieldset legend {
    padding: 0 0.35rem;
    font-size: 0.72rem;
    font-weight: 700;
    color: rgb(150 150 160);
  }

  /* Lista de extras: fila compacta [check | título | precio] */
  .lb__optlist {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.55rem 0.65rem 0.65rem;
  }
  .lb__opt {
    display: grid !important;
    grid-template-columns: 1.15rem minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 0.55rem;
    row-gap: 0;
    margin: 0 !important;
    padding: 0.4rem 0.35rem;
    border-radius: 6px;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    font-size: 0.82rem !important;
    font-weight: 400 !important;
    color: #e0e0e6 !important;
