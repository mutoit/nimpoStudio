---
/**
 * Mock visual de valoraciones + comentarios (sin backend).
 * Quitar demoBadge y conectar API cuando se implemente de verdad.
 */
import type { Locale } from "../i18n/translations";
import { useTranslations } from "../lib/locale";

type Props = {
  releaseName: string;
  releaseSlug: string;
  lang?: Locale;
};

const { releaseName, releaseSlug, lang = "es" } = Astro.props;
const t = useTranslations(lang);

/** Datos de ejemplo solo para el mock visual */
const mock = {
  average: 4.6,
  count: 11,
  distribution: [
    { stars: 5, pct: 64 },
    { stars: 4, pct: 27 },
    { stars: 3, pct: 9 },
    { stars: 2, pct: 0 },
    { stars: 1, pct: 0 },
  ],
  comments: [
    {
      id: "1",
      name: "Marta V.",
      stars: 5,
      date: "2026-03-12",
      use: "proyecto",
      text:
        lang === "en"
          ? "Dense atmosphere without mud. Perfect under a nature short; stems made the mix easy."
          : lang === "fr"
            ? "Atmosphère dense sans boue. Parfait sous un court nature ; les stems ont simplifié le mix."
            : "Atmósfera densa sin empastar. Ideal bajo un short de naturaleza; los stems facilitaron el mix.",
    },
    {
      id: "2",
      name: "Leo K.",
      stars: 5,
      date: "2026-02-28",
      use: "cliente",
      text:
        lang === "en"
          ? "Licensed for a brand film. Clear terms and a master that sits well under VO."
          : lang === "fr"
            ? "Licencié pour un brand film. Conditions claires et un master qui se place bien sous la VO."
            : "Licenciado para un brand film. Condiciones claras y un master que se asienta bien bajo la VO.",
    },
    {
      id: "3",
      name: "Ana R.",
      stars: 4,
      date: "2026-02-10",
      use: "personal",
      text:
        lang === "en"
          ? "Preview is protected (noise) but the structure and mood come through. Would buy the full piece."
          : lang === "fr"
            ? "Le preview est protégé (bruit) mais structure et mood passent. J’achèterais la pièce complète."
            : "El preview va protegido (ruido) pero se nota la estructura y el mood. Compraría la pieza completa.",
    },
    {
      id: "4",
      name: "Studio North",
      stars: 5,
      date: "2026-01-22",
      use: "cliente",
      text:
        lang === "en"
          ? "Organic layers, no AI sheen. Clients asked where the score was from."
          : lang === "fr"
            ? "Couches organiques, sans vernis IA. Les clients ont demandé d’où venait la partition."
            : "Capas orgánicas, sin barniz de IA. Los clientes preguntaron de dónde era la partitura.",
    },
    {
      id: "5",
      name: "Diego P.",
      stars: 4,
      date: "2026-01-05",
      use: "proyecto",
      text:
        lang === "en"
          ? "Great for long takes. A tad long for reels; stems help trim it."
          : lang === "fr"
            ? "Très bien pour plans longs. Un peu long pour reels ; les stems aident à couper."
            : "Muy bien para planos largos. Un poco largo para reels; los stems ayudan a recortar.",
    },
  ],
};

const useLabels: Record<string, string> = {
  personal: t("reviewsUsePersonal"),
  proyecto: t("reviewsUseProject"),
  cliente: t("reviewsUseClient"),
};

function starsAria(n: number) {
  return t("reviewsStarsAria").replace("{n}", String(n));
}

function formatDate(iso: string) {
  try {
    return new Intl.DateTimeFormat(lang, { year: "numeric", month: "short", day: "numeric" }).format(
      new Date(iso + "T12:00:00"),
    );
  } catch {
    return iso;
  }
}

const fullStars = Math.floor(mock.average);
const hasHalf = mock.average - fullStars >= 0.3 && mock.average - fullStars < 0.8;
---

<section
  class="reviews"
  id="valoraciones"
  aria-labelledby="reviews-heading"
  data-release-slug={releaseSlug}
  data-mock="true"
>
  <div class="reviews__head">
    <div class="reviews__head-text">
      <p class="reviews__eyebrow">{t("reviewsEyebrow")}</p>
      <h2 class="reviews__title" id="reviews-heading">{t("reviewsTitle")}</h2>
      <p class="reviews__demo" role="status">{t("reviewsDemoNote")}</p>
    </div>
    <div class="reviews__score" aria-label={t("reviewsScoreAria").replace("{avg}", String(mock.average)).replace("{n}", String(mock.count))}>
      <p class="reviews__score-num">{mock.average.toFixed(1)}</p>
      <div class="reviews__stars" aria-hidden="true">
        {
          [1, 2, 3, 4, 5].map((i) => (
            <span
              class:list={[
                "star",
                {
                  "star--on": i <= fullStars,
                  "star--half": hasHalf && i === fullStars + 1,
                },
              ]}
            >
              ★
            </span>
          ))
        }
      </div>
      <p class="reviews__count">{t("reviewsCount").replace("{n}", String(mock.count))}</p>
    </div>
  </div>

  <div class="reviews__layout">
    <div class="reviews__summary">
      <ul class="reviews__bars" aria-label={t("reviewsDistribution")}>
        {
          mock.distribution.map((row) => (
            <li class="reviews__bar-row">
              <span class="reviews__bar-label">{row.stars}★</span>
              <div class="reviews__bar-track" role="presentation">
                <div class="reviews__bar-fill" style={`width: ${row.pct}%`} />
              </div>
              <span class="reviews__bar-pct">{row.pct}%</span>
            </li>
          ))
        }
      </ul>

      <form class="reviews__form" data-reviews-form>
        <p class="reviews__form-title">{t("reviewsFormTitle")}</p>
        <p class="reviews__form-hint">{t("reviewsFormHint").replace("{name}", releaseName)}</p>

        <fieldset class="reviews__rate">
          <legend class="visually-hidden">{t("reviewsYourRating")}</legend>
          <div class="reviews__rate-stars" data-rate-stars>
            {
              [1, 2, 3, 4, 5].map((n) => (
                <button
                  type="button"
                  class="reviews__rate-btn"
                  data-rate={n}
                  aria-label={starsAria(n)}
                  aria-pressed="false"
                >
                  ★
                </button>
              ))
            }
          </div>
          <input type="hidden" name="rating" value="" data-rate-input />
        </fieldset>

        <label class="reviews__field">
          <span>{t("reviewsName")}</span>
          <input type="text" name="name" maxlength="40" placeholder={t("reviewsNamePh")} autocomplete="nickname" />
        </label>

        <label class="reviews__field">
          <span>{t("reviewsUse")}</span>
          <select name="use">
            <option value="">{t("reviewsUseAny")}</option>
            <option value="personal">{t("reviewsUsePersonal")}</option>
            <option value="proyecto">{t("reviewsUseProject")}</option>
            <option value="cliente">{t("reviewsUseClient")}</option>
          </select>
        </label>

        <label class="reviews__field">
          <span>{t("reviewsComment")}</span>
          <textarea
            name="comment"
            rows="3"
            maxlength="280"
            placeholder={t("reviewsCommentPh")}
          ></textarea>
        </label>

        <button type="submit" class="reviews__submit" disabled>
          {t("reviewsSubmit")}
        </button>
        <p class="reviews__form-note">{t("reviewsSubmitNote")}</p>
      </form>
    </div>

    <div class="reviews__feed">
      <div class="reviews__feed-head">
        <h3 class="reviews__feed-title">{t("reviewsComments")}</h3>
        <span class="reviews__feed-meta">{t("reviewsShowing").replace("{n}", String(mock.comments.length))}</span>
      </div>
      <div class="reviews__scroll" tabindex="0" role="region" aria-label={t("reviewsComments")}>
        <ul class="reviews__list">
          {
            mock.comments.map((c) => (
              <li class="reviews__item">
                <div class="reviews__item-top">
                  <span class="reviews__item-name">{c.name}</span>
                  <span class="reviews__item-stars" aria-label={starsAria(c.stars)}>
                    {[1, 2, 3, 4, 5].map((i) => (
                      <span class:list={["star", "star--sm", { "star--on": i <= c.stars }]}>★</span>
                    ))}
                  </span>
                  <time class="reviews__item-date" datetime={c.date}>
                    {formatDate(c.date)}
                  </time>
                </div>
                {c.use && (
                  <span class="reviews__item-use">{useLabels[c.use] ?? c.use}</span>
                )}
                <p class="reviews__item-text">{c.text}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.currentScript?.previousElementSibling?.closest?.(".reviews")
    ?? document.querySelector(".reviews[data-mock]");
  // Prefer section containing this script's form
  document.querySelectorAll(".reviews[data-mock]").forEach((section) => {
    const form = section.querySelector("[data-reviews-form]");
    if (!(form instanceof HTMLFormElement)) return;
    if (form.dataset.bound === "1") return;
    form.dataset.bound = "1";

    const buttons = form.querySelectorAll("[data-rate]");
    const input = form.querySelector("[data-rate-input]");
    const submit = form.querySelector(".reviews__submit");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const n = Number((btn as HTMLElement).dataset.rate || 0);
        if (input instanceof HTMLInputElement) input.value = String(n);
        buttons.forEach((b) => {
          const v = Number((b as HTMLElement).dataset.rate || 0);
          const on = v <= n;
          b.classList.toggle("is-on", on);
          b.setAttribute("aria-pressed", v === n ? "true" : "false");
        });
        if (submit instanceof HTMLButtonElement) {
          // Mock: keep disabled (no backend) but show ready state
          submit.disabled = true;
          submit.title = "Mock — sin envío real";
        }
      });
    });

    form.addEventListener("submit", (e) => {
      e.preventDefault();
    });
  });
</script>

<style>
  .reviews {
    margin: 2.5rem 0 3rem;
    padding: 1.5rem 1.35rem 1.6rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background:
      linear-gradient(165deg, rgb(201 169 98 / 0.06) 0%, transparent 42%),
      var(--color-bg-elevated);
    box-shadow: var(--glow);
  }

  .reviews__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.25rem 2rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .reviews__eyebrow {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dim);
  }

  .reviews__title {
    margin: 0.35rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 1.85rem);
    font-weight: 500;
    line-height: 1.15;
  }

  .reviews__demo {
    margin: 0.55rem 0 0;
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    border: 1px dashed rgb(201 169 98 / 0.45);
    background: rgb(201 169 98 / 0.08);
    color: var(--color-accent);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .reviews__score {
    text-align: right;
    min-width: 7.5rem;
  }

  .reviews__score-num {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2.75rem;
    font-weight: 500;
    line-height: 1;
    color: var(--color-fg);
  }

  .reviews__stars {
    display: flex;
    justify-content: flex-end;
    gap: 0.12rem;
    margin-top: 0.35rem;
  }

  .star {
    color: var(--color-border);
    font-size: 1.05rem;
    line-height: 1;
  }

  .star--on {
    color: var(--color-accent);
  }

  .star--half {
    background: linear-gradient(90deg, var(--color-accent) 50%, var(--color-border) 50%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .star--sm {
    font-size: 0.85rem;
  }

  .reviews__count {
    margin: 0.4rem 0 0;
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .reviews__layout {
    display: grid;
    gap: 1.75rem;
  }

  @media (min-width: 860px) {
    .reviews__layout {
      grid-template-columns: minmax(14rem, 17.5rem) 1fr;
      gap: 2rem;
      align-items: start;
    }
  }

  .reviews__bars {
    margin: 0 0 1.35rem;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .reviews__bar-row {
    display: grid;
    grid-template-columns: 1.6rem 1fr 2.2rem;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .reviews__bar-track {
    height: 0.35rem;
    border-radius: 999px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .reviews__bar-fill {
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--color-accent-dim), var(--color-accent));
  }

  .reviews__bar-pct {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .reviews__form {
    padding: 1rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .reviews__form-title {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .reviews__form-hint {
    margin: 0.35rem 0 0.9rem;
    font-size: 0.8rem;
    color: var(--color-muted);
    line-height: 1.45;
  }

  .reviews__rate {
    margin: 0 0 0.9rem;
    padding: 0;
    border: 0;
  }

  .reviews__rate-stars {
    display: flex;
    gap: 0.2rem;
  }

  .reviews__rate-btn {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0.15rem 0.2rem;
    color: var(--color-border);
    font-size: 1.45rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.15s, transform 0.15s;
  }

  .reviews__rate-btn:hover,
  .reviews__rate-btn:focus-visible,
  .reviews__rate-btn.is-on {
    color: var(--color-accent);
  }

  .reviews__rate-btn:hover {
    transform: scale(1.08);
  }

  .reviews__rate-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .reviews__field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-muted);
  }

  .reviews__field input,
  .reviews__field select,
  .reviews__field textarea {
    appearance: none;
    width: 100%;
    padding: 0.55rem 0.65rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-fg);
    font: inherit;
    font-weight: 400;
    font-size: 0.9rem;
  }

  .reviews__field textarea {
    resize: vertical;
    min-height: 4.5rem;
    line-height: 1.5;
  }

  .reviews__field input:focus-visible,
  .reviews__field select:focus-visible,
  .reviews__field textarea:focus-visible {
    outline: 2px solid rgb(201 169 98 / 0.55);
    outline-offset: 1px;
  }

  .reviews__submit {
    width: 100%;
    margin-top: 0.25rem;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    border: 1px solid rgb(201 169 98 / 0.45);
    background: rgb(201 169 98 / 0.16);
    color: var(--color-accent);
    font: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: not-allowed;
    opacity: 0.75;
  }

  .reviews__form-note {
    margin: 0.55rem 0 0;
    font-size: 0.72rem;
    color: var(--color-muted);
    line-height: 1.4;
  }

  .reviews__feed-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.65rem;
  }

  .reviews__feed-title {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-dim);
  }

  .reviews__feed-meta {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .reviews__scroll {
    max-height: 18rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 0.15rem 0.35rem 0.15rem 0;
    border-radius: var(--radius);
    scrollbar-width: thin;
    scrollbar-color: rgb(201 169 98 / 0.45) var(--color-surface);
  }

  .reviews__scroll:focus-visible {
    outline: 2px solid rgb(201 169 98 / 0.5);
    outline-offset: 2px;
  }

  .reviews__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .reviews__item {
    padding: 0.85rem 0.95rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .reviews__item-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.65rem;
  }

  .reviews__item-name {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .reviews__item-stars {
    display: inline-flex;
    gap: 0.05rem;
  }

  .reviews__item-date {
    margin-left: auto;
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  .reviews__item-use {
    display: inline-block;
    margin-top: 0.4rem;
    padding: 0.12rem 0.45rem;
    border-radius: 999px;
    background: var(--color-accent-light);
    color: var(--color-accent-dim);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .reviews__item-text {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-muted);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 520px) {
    .reviews {
      padding: 1.15rem 1rem 1.25rem;
    }

    .reviews__score {
      text-align: left;
    }

    .reviews__stars {
      justify-content: flex-start;
    }

    .reviews__item-date {
      margin-left: 0;
      width: 100%;
    }
  }
</style>
