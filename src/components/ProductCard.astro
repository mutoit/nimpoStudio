---
import {
  getCategoryLabels,
  getLicenseLabels,
  isProvisionalProduct,
  type Product,
} from "../lib/products";
import type { Locale } from "../i18n/translations";
import { useTranslations, localizePath } from "../lib/locale";

type Props = { product: Product; lang?: Locale };

const { product, lang = "es" } = Astro.props;
const t = useTranslations(lang);
const categoryLabels = getCategoryLabels(lang);
const licenseLabels = getLicenseLabels(lang);
const provisional = isProvisionalProduct(product);

const detailHref = localizePath(`/catalogo/${product.slug}`, lang);
---

<article class:list={["card", { "card--provisional": provisional }]} data-category={product.category}>
  <a href={detailHref} class="card__media">
    <img
      src={product.images[0]}
      alt={`Portada de ${product.name}`}
      width={400}
      height={500}
      loading="lazy"
    />
    <span class="card__overlay" aria-hidden="true"></span>
    {provisional && (
      <span class="card__badge card__badge--provisional">{t("badgeProvisional")}</span>
    )}
    {!provisional && product.status === "coming-soon" && (
      <span class="card__badge">{t("badgeComingSoon")}</span>
    )}
    {!provisional && product.featured && product.status !== "coming-soon" && (
      <span class="card__badge card__badge--featured">{t("badgeFeatured")}</span>
    )}
  </a>
  <div class="card__body">
    <p class="card__category">{categoryLabels[product.category]}</p>
    <h2 class="card__title">
      <a href={detailHref}>{product.name}</a>
    </h2>
    <p class="card__desc">{product.shortDescription}</p>
    <p class="card__license">{licenseLabels[product.licenseType]}</p>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
  }

  .card__media {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--glow);
    border: 1px solid var(--color-border);
    aspect-ratio: 4 / 5;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .card__media:hover {
    border-color: rgb(201 169 98 / 0.35);
    box-shadow: var(--glow), 0 0 24px rgb(201 169 98 / 0.08);
  }

  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease, opacity 0.3s;
    opacity: 0.92;
  }

  .card__media:hover img {
    transform: scale(1.04);
    opacity: 1;
  }

  .card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgb(8 8 10 / 0.75) 0%,
      transparent 50%
    );
    pointer-events: none;
  }

  .card--provisional .card__media {
    border-color: rgb(220 120 80 / 0.45);
  }

  .card--provisional .card__media img {
    filter: saturate(0.75) brightness(0.92);
  }

  .card__badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 1;
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius);
    background: rgb(8 8 10 / 0.85);
    border: 1px solid var(--color-border-shine);
    color: var(--color-muted);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    backdrop-filter: blur(8px);
    max-width: calc(100% - 1.5rem);
    line-height: 1.3;
  }

  .card__badge--featured {
    color: var(--color-accent);
    border-color: rgb(201 169 98 / 0.3);
  }

  .card__badge--provisional {
    color: #ffb38a;
    border-color: rgb(255 140 80 / 0.55);
    background: rgb(60 28 12 / 0.92);
    box-shadow: 0 0 0 1px rgb(255 140 80 / 0.15);
  }

  .card__body {
    padding: 1.15rem 0.15rem 0;
  }

  .card__category {
    margin: 0;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent-dim);
  }

  .card__title {
    margin: 0.4rem 0 0;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  .card__title a {
    text-decoration: none;
    transition: color 0.2s;
  }

  .card__title a:hover {
    color: var(--color-accent);
  }

  .card__desc {
    margin: 0.55rem 0 0;
    font-size: 0.875rem;
    font-weight: 300;
    color: var(--color-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__license {
    margin: 0.65rem 0 0;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    opacity: 0.7;
  }
</style>