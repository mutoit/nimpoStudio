---
interface Stem {
  id: string;
  label: string;
  src: string;
}

type Props = {
  title: string;
  stems: Stem[];
  /** Optional: duration in seconds if known (used for initial display; overridden by actual audio buffer duration) */
  duration?: number;
  /** Optional video to display and sync with the stems playback (replaces static image feel) */
  visualVideo?: string;
  /** For richer analytics */
  releaseSlug?: string;
};

const { title, stems, duration, visualVideo, releaseSlug } = Astro.props;
const playerId = `stem-player-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="stem-player" id={playerId} data-stems={JSON.stringify(stems)} data-duration="0" data-title={title} data-release={releaseSlug || ""}>
  <div class="player-header">
    <div class="player-title">
      <h3>{title}</h3>
      <span class="player-badge">STEMS</span>
    </div>

    <div class="master-controls">
      <button class="play-btn" aria-label="Play/Pause">
        <span class="play-icon">▶</span>
        <span class="pause-icon" hidden>❚❚</span>
      </button>

      <div class="timeline">
        <input type="range" class="seek" min="0" max="100" step="0.1" value="0" />
        <div class="time">
          <span class="current">0:00</span>
          <span class="total">--:--</span>
        </div>
      </div>

      <button class="master-mute" aria-label="Mute all">🔊</button>
    </div>
  </div>

  {visualVideo && (
    <div class="player-visual">
      <video
        class="visual-video"
        src={visualVideo}
        loop
        muted
        playsinline
        preload="metadata"
      ></video>
    </div>
  )}

  <div class="layers">
    {stems.map((stem, index) => (
      <div class="layer" data-stem-id={stem.id}>
        <div class="layer-label">
          <span class="layer-name">{stem.label}</span>
          <div class="layer-visual" aria-hidden="true">
            <canvas class="waveform" width="100" height="18"></canvas>
          </div>
        </div>

        <div class="layer-controls">
          <button class="btn mute-btn" data-action="mute" aria-label={`Silenciar ${stem.label}`}>
            Mute
          </button>
          <button class="btn solo-btn" data-action="solo" aria-label={`Solo ${stem.label}`}>
            Solo
          </button>

          <div class="volume-wrap">
            <input 
              type="range" 
              class="volume" 
              min="0" 
              max="1" 
              step="0.01" 
              value="1" 
              aria-label={`Volumen ${stem.label}`}
            />
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="player-footer">
    <small>Capas sincronizadas • Silencia o aisla cada una</small>
  </div>
</div>

<style>
  .stem-player {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }

  .player-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .player-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .player-title h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 500;
  }

  .player-badge {
    font-size: 0.6rem;
    padding: 0.1rem 0.4rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-radius: 3px;
    letter-spacing: 0.5px;
    font-weight: 600;
  }

  .master-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 260px;
  }

  .play-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--color-accent-light);
    border: 1px solid rgb(201 169 98 / 0.3);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .play-btn:hover {
    background: rgb(201 169 98 / 0.2);
  }

  .timeline {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .seek {
    flex: 1;
    accent-color: var(--color-accent);
  }

  .time {
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    color: var(--color-muted);
    white-space: nowrap;
    min-width: 70px;
    text-align: right;
  }

  .layers {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .layer {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    background: var(--color-bg-elevated);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    user-select: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .layer.is-solo {
    border-color: rgb(201 169 98 / 0.45);
    box-shadow: inset 0 0 0 1px rgb(201 169 98 / 0.2);
  }

  .layer.is-solo .layer-name {
    color: var(--color-accent);
  }

  .layer-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .layer-name {
    font-weight: 500;
    font-size: 0.9rem;
    min-width: 90px;
  }

  .layer-visual {
    flex: 1;
    height: 18px;
    background: #1a1a1f;
    border-radius: 3px;
    overflow: hidden;
    position: relative;
  }

  .waveform {
    width: 100%;
    height: 100%;
    display: block;
  }

  .layer-controls {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .btn {
    font-size: 0.7rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: all 0.15s;
  }

  .btn:hover {
    color: var(--color-fg);
    border-color: var(--color-fg);
  }

  .mute-btn.active {
    background: #3a2a2a;
    color: #ff9b9b;
    border-color: #ff9b9b33;
  }

  .solo-btn.active {
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-color: rgb(201 169 98 / 0.4);
  }

  .volume {
    width: 80px;
    accent-color: var(--color-accent);
  }

  .player-footer {
    margin-top: 0.75rem;
    text-align: center;
    font-size: 0.7rem;
    color: var(--color-muted);
    opacity: 0.7;
  }

  .stem-mix-hint {
    margin: 0.55rem 0 0;
    padding: 0.4rem 0.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: rgb(255 255 255 / 0.03);
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--color-muted);
  }

  .player-visual {
    margin: 0.75rem 0 1rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: #111;
    aspect-ratio: 16 / 9;
    max-height: 320px;
  }

  .visual-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @keyframes layer-pulse {
    0%, 100% { height: 25%; }
    50% { height: 85%; }
  }

  @media (max-width: 720px) {
    .stem-player {
      padding: 0.75rem 0.85rem;
      margin: 1rem 0;
    }

    .player-header {
      flex-direction: column;
      align-items: stretch;
      gap: 0.65rem;
      margin-bottom: 0.75rem;
    }

    .master-controls {
      min-width: 0;
      width: 100%;
      gap: 0.5rem;
    }

    .play-btn {
      width: 2.75rem;
      height: 2.75rem;
      flex-shrink: 0;
    }

    .master-mute {
      min-width: 2.5rem;
      min-height: 2.5rem;
      touch-action: manipulation;
    }

    .layer {
      grid-template-columns: 1fr;
      gap: 0.45rem;
      padding: 0.45rem 0.55rem;
    }

    .layer-name {
      min-width: 0;
      font-size: 0.82rem;
    }

    .layer-controls {
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    .btn {
      min-height: 2.25rem;
      padding: 0.35rem 0.65rem;
      font-size: 0.72rem;
      touch-action: manipulation;
    }

    .volume {
      width: min(7rem, 40vw);
    }

    .player-visual {
      max-height: 200px;
      margin: 0.5rem 0 0.75rem;
    }
  }
</style>

<script define:vars={{ playerId }}>
(function() {
  const container = document.getElementById(playerId);
  if (!container) return;

  const stems = JSON.parse(container.dataset.stems || '[]');
  const playBtn = container.querySelector('.play-btn');
  const seek = container.querySelector('.seek');
  const currentTimeEl = container.querySelector('.current');
  const masterMuteBtn = container.querySelector('.master-mute');
  const visualVideoEl = container.querySelector('.visual-video');

  const totalEl = container.querySelector('.total');

  // Get real duration from the audio file metadata (fast probe, before full decode)
  // This gives the actual track length directly from the file header (the real one)
  if (stems.length > 0) {
    const firstSrc = stems[0].src;
    const probe = new Audio();
    probe.preload = 'metadata';
    probe.src = firstSrc;
    probe.addEventListener('loadedmetadata', () => {
      if (probe.duration && isFinite(probe.duration) && probe.duration > 0) {
        trackDuration = probe.duration;
        container.dataset.duration = trackDuration;
        if (totalEl) totalEl.textContent = formatTime(trackDuration);
      }
    });
    // Fallback if metadata fails: will be set from buffer on play
    probe.addEventListener('error', () => {});
  }

  let audioContext;
  let tracks = {};
  let isPlaying = false;
  let startTime = 0;
  let pauseTime = 0;
  let animationFrame;
  let masterGain;
  let trackDuration = 0;

  function formatTime(sec) {
    if (!sec || sec <= 0) return '--:--';
    const m = Math.floor(sec / 60);
    const s = Math.floor(sec % 60);
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  function generateWaveform(buffer, points = 80) {
    const data = buffer.getChannelData(0);
    const len = data.length;
    const step = Math.max(1, Math.floor(len / points));
    const wave = [];
    for (let i = 0; i < points; i++) {
      let min = 1, max = -1;
      const start = i * step;
      for (let j = 0; j < step && (start + j) < len; j++) {
        const v = data[start + j];
        if (v < min) min = v;
        if (v > max) max = v;
      }
      wave.push({ min, max });
    }
    return wave;
  }

  function drawWaveform(canvas, waveData, progress = 0) {
    if (!canvas || !waveData) return;
    const ctx = canvas.getContext('2d', { alpha: true });
    if (!ctx) return;
    const w = canvas.width;
    const h = canvas.height;
    ctx.clearRect(0, 0, w, h);

    const center = h / 2;
    const scale = center * 0.85;
    const stepX = w / waveData.length;

    // background line
    ctx.strokeStyle = '#444';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, center);
    ctx.lineTo(w, center);
    ctx.stroke();

    // waveform
    ctx.strokeStyle = '#888';
    ctx.lineWidth = 1.5;
    for (let i = 0; i < waveData.length; i++) {
      const x = i * stepX + 0.5;
      const { min, max } = waveData[i];
      const y1 = center - max * scale;
      const y2 = center - min * scale;
      ctx.beginPath();
      ctx.moveTo(x, y1);
      ctx.lineTo(x, y2);
      ctx.stroke();
    }

    // played portion
    if (progress > 0) {
      const progX = Math.min(w, progress * w);
      ctx.fillStyle = 'rgba(201, 169, 98, 0.35)';
      ctx.fillRect(0, 0, progX, h);

      // accent line
      ctx.strokeStyle = '#c9a962';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(progX, 0);
      ctx.lineTo(progX, h);
      ctx.stroke();
    }
  }

  function updateAllWaveforms(progress) {
    Object.entries(tracks).forEach(([id, t]) => {
      const layerEl = container.querySelector(`[data-stem-id="${id}"]`);
      if (!layerEl || !t.waveform) return;
      const canvas = layerEl.querySelector('.waveform');
      if (canvas) {
        drawWaveform(canvas, t.waveform, progress);
      }
    });
  }

  // Initialize AudioContext on first user gesture
  function getAudioContext() {
    if (!audioContext) {
      audioContext = new (window.AudioContext || window.webkitAudioContext)();
      masterGain = audioContext.createGain();
      masterGain.connect(audioContext.destination);
    }
    return audioContext;
  }

  async function loadTrack(stem) {
    const ctx = getAudioContext();
    const res = await fetch(stem.src);
    const arrayBuffer = await res.arrayBuffer();
    const audioBuffer = await ctx.decodeAudioData(arrayBuffer);

    const source = ctx.createBufferSource();
    source.buffer = audioBuffer;

    const gain = ctx.createGain();
    const analyser = ctx.createAnalyser();
    analyser.fftSize = 32;

    source.connect(gain);
    gain.connect(analyser);
    analyser.connect(masterGain);

    const waveform = generateWaveform(audioBuffer);

    return {
      source,
      gain,
      analyser,
      buffer: audioBuffer,
      waveform,
      volume: 1,
      muted: false,
      solo: false
    };
  }

  async function initTracks() {
    const ctx = getAudioContext();
    tracks = {};

    for (const stem of stems) {
      try {
        tracks[stem.id] = await loadTrack(stem);
      } catch (e) {
        console.warn('Could not load stem', stem.src, e);
      }
    }

    // Refine with actual decoded buffer duration (most accurate for these files)
    let bufferDur = 0;
    Object.values(tracks).forEach(t => {
      if (t.buffer && t.buffer.duration > bufferDur) {
        bufferDur = t.buffer.duration;
      }
    });
    if (bufferDur > 0) {
      trackDuration = bufferDur;
      container.dataset.duration = trackDuration;
      if (totalEl) totalEl.textContent = formatTime(trackDuration);
    }

    // draw initial waveforms (progress 0)
    updateAllWaveforms(0);
  }

  function startAll(offset = 0) {
    const ctx = getAudioContext();
    Object.keys(tracks).forEach(id => {
      const t = tracks[id];
      if (t.source) {
        try { t.source.stop(); } catch (e) {}
      }

      const newSource = ctx.createBufferSource();
      newSource.buffer = t.buffer;

      const gain = t.gain;
      const analyser = t.analyser;

      newSource.connect(gain);

      // reconnect
      gain.disconnect();
      gain.connect(analyser);
      analyser.connect(masterGain);

      t.source = newSource;
      newSource.start(0, offset);
    });
  }

  function stopAll() {
    Object.values(tracks).forEach(t => {
      if (t.source) {
        try { t.source.stop(); } catch (e) {}
      }
    });
  }

  function playVisual(offset = 0) {
    if (!visualVideoEl) return;
    try {
      visualVideoEl.currentTime = offset;
      const playPromise = visualVideoEl.play();
      if (playPromise && typeof playPromise.catch === 'function') {
        playPromise.catch(() => {});
      }
    } catch (e) {}
  }

  function pauseVisual() {
    if (!visualVideoEl) return;
    try { visualVideoEl.pause(); } catch (e) {}
  }

  function seekVisual(time) {
    if (!visualVideoEl) return;
    try { visualVideoEl.currentTime = time; } catch (e) {}
  }

  function updateVolumes() {
    const isAnySolo = Object.values(tracks).some(t => t.solo);

    Object.entries(tracks).forEach(([id, t]) => {
      let vol = t.volume;
      if (t.muted) vol = 0;
      if (isAnySolo && !t.solo) vol = 0;
      t.gain.gain.value = vol;
    });
  }

  function updateVisuals() {
    Object.entries(tracks).forEach(([id, t]) => {
      const layerEl = container.querySelector(`[data-stem-id="${id}"]`);
      if (!layerEl) return;

      const bars = layerEl.querySelectorAll('.bar');
      if (!bars.length || !t.analyser) return;

      const data = new Uint8Array(t.analyser.frequencyBinCount);
      t.analyser.getByteFrequencyData(data);

      const avg = data.reduce((a, b) => a + b, 0) / data.length;
      const scale = Math.max(0.15, Math.min(1, avg / 80));

      bars.forEach((bar, i) => {
        const h = scale * (60 + (i % 2) * 30);
        bar.style.height = `${h}%`;
      });
    });
  }

  function updateTime() {
    if (!isPlaying) return;

    const elapsed = (audioContext.currentTime - startTime) + pauseTime;
    const totalDur = trackDuration || parseFloat(container.dataset.duration) || 0;
    if (totalDur > 0) {
      const pct = Math.min(100, (elapsed / totalDur) * 100);
      seek.value = pct;
    }

    const mins = Math.floor(elapsed / 60);
    const secs = Math.floor(elapsed % 60);
    currentTimeEl.textContent = `${mins}:${secs.toString().padStart(2, '0')}`;

    updateVisuals();

    const progress = totalDur > 0 ? Math.min(1, elapsed / totalDur) : 0;
    updateAllWaveforms(progress);

    animationFrame = requestAnimationFrame(updateTime);
  }

  async function togglePlay() {
    const ctx = getAudioContext();
    if (ctx.state === 'suspended') await ctx.resume();

    if (!Object.keys(tracks).length) {
      await initTracks();
    }

    if (isPlaying) {
      stopAll();
      pauseVisual();
      pauseTime = (audioContext.currentTime - startTime) + pauseTime;
      isPlaying = false;
      cancelAnimationFrame(animationFrame);
      playBtn.querySelector('.play-icon').hidden = false;
      playBtn.querySelector('.pause-icon').hidden = true;
      container.querySelectorAll('.layer').forEach(l => l.classList.remove('playing'));
    } else {
      const offset = pauseTime;
      startAll(offset);
      playVisual(offset);
      startTime = audioContext.currentTime;
      isPlaying = true;
      playBtn.querySelector('.play-icon').hidden = true;
      playBtn.querySelector('.pause-icon').hidden = false;
      container.querySelectorAll('.layer').forEach(l => l.classList.add('playing'));
      updateTime();

      // Track stem player usage (always goes to first-party collector)
      const playerTitle = container.dataset.title || "unknown";
      const release = container.dataset.release || undefined;
      window.nimpoTrack?.({
        name: "music_stem_play",
        payload: { title: playerTitle, stemsCount: stems.length, release },
      });
    }
  }

  // Event listeners
  playBtn.addEventListener('click', togglePlay);

  // Click on visual video also toggles playback
  if (visualVideoEl) {
    visualVideoEl.addEventListener('click', (e) => {
      e.preventDefault();
      togglePlay();
    });
    // Visual hint
    visualVideoEl.style.cursor = 'pointer';
  }

  seek.addEventListener('input', () => {
    if (!audioContext) return;
    const pct = parseFloat(seek.value);
    const totalDur = trackDuration || parseFloat(container.dataset.duration) || 0;
    const newTime = (pct / 100) * totalDur;

    pauseTime = newTime;

    if (isPlaying) {
      stopAll();
      pauseVisual();
      startTime = audioContext.currentTime;
      startAll(newTime);
      seekVisual(newTime);
      playVisual(newTime);
    } else {
      // Update current time display while paused
      currentTimeEl.textContent = formatTime(newTime);
    }

    const totalDurForWave = trackDuration || parseFloat(container.dataset.duration) || 0;
    const progress = totalDurForWave > 0 ? Math.min(1, newTime / totalDurForWave) : 0;
    updateAllWaveforms(progress);
  });

  masterMuteBtn.addEventListener('click', () => {
    const current = masterGain.gain.value;
    masterGain.gain.value = current > 0.01 ? 0 : 1;
    masterMuteBtn.textContent = masterGain.gain.value === 0 ? '🔇' : '🔊';
  });

  // Per-layer controls
  container.querySelectorAll('.layer').forEach(layerEl => {
    const id = layerEl.dataset.stemId;
    const layerName = layerEl.querySelector('.layer-name')?.textContent?.trim() || id;
    const muteBtn = layerEl.querySelector('.mute-btn');
    const soloBtn = layerEl.querySelector('.solo-btn');
    const volSlider = layerEl.querySelector('.volume');

    const playerTitle = container.dataset.title || "unknown";

    muteBtn.addEventListener('click', () => {
      if (!tracks[id]) return;
      tracks[id].muted = !tracks[id].muted;
      muteBtn.classList.toggle('active', tracks[id].muted);
      updateVolumes();

      window.nimpoTrack?.({
        name: "music_stem_interaction",
        payload: {
          title: playerTitle,
          action: tracks[id].muted ? "mute" : "unmute",
          layer: layerName,
          release: container.dataset.release || undefined,
        },
      });
    });

    const toggleSolo = () => {
      if (!tracks[id]) return;
      const currentlySolo = tracks[id].solo;

      // clear all solos
      Object.values(tracks).forEach(t => t.solo = false);
      container.querySelectorAll('.solo-btn').forEach(b => b.classList.remove('active'));
      container.querySelectorAll('.layer').forEach(l => l.classList.remove('is-solo'));

      tracks[id].solo = !currentlySolo;
      if (tracks[id].solo) {
        soloBtn.classList.add('active');
        layerEl.classList.add('is-solo');
      }

      updateVolumes();

      window.nimpoTrack?.({
        name: "music_stem_interaction",
        payload: {
          title: playerTitle,
          action: tracks[id].solo ? "solo" : "unsolo",
          layer: layerName,
          release: container.dataset.release || undefined,
        },
      });
    };

    soloBtn.addEventListener('click', toggleSolo);

    // Clic derecho en la fila: solo esta capa / restaurar todas
    layerEl.title = layerEl.title || "Clic derecho: solo esta capa · otra vez: todas";
    layerEl.addEventListener('contextmenu', (e) => {
      if (e.target instanceof Element && e.target.closest('button, input')) return;
      e.preventDefault();
      toggleSolo();
    });

    volSlider.addEventListener('input', (e) => {
      if (!tracks[id]) return;
      tracks[id].volume = parseFloat(e.target.value);
      updateVolumes();
    });
  });

  // Keyboard support
  document.addEventListener('keydown', (e) => {
    if (e.target.tagName === 'INPUT') return;
    if (e.key === ' ' || e.key === 'k') {
      e.preventDefault();
      togglePlay();
    }
  });

  // Cleanup
  window.addEventListener('beforeunload', () => {
    if (isPlaying) stopAll();
  });
})();
</script>