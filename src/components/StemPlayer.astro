---
interface Stem {
  id: string;
  label: string;
  src: string;
}

type Props = {
  title: string;
  stems: Stem[];
  /** Optional: duration in seconds if known */
  duration?: number;
};

const { title, stems, duration } = Astro.props;
const playerId = `stem-player-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="stem-player" id={playerId} data-stems={JSON.stringify(stems)} data-duration={duration || 0}>
  <div class="player-header">
    <div class="player-title">
      <h3>{title}</h3>
      <span class="player-badge">STEMS</span>
    </div>

    <div class="master-controls">
      <button class="play-btn" aria-label="Play/Pause">
        <span class="play-icon">▶</span>
        <span class="pause-icon" hidden>❚❚</span>
      </button>

      <div class="timeline">
        <input type="range" class="seek" min="0" max="100" step="0.1" value="0" />
        <div class="time">
          <span class="current">0:00</span>
          <span class="total">{duration ? `${Math.floor(duration / 60)}:${String(duration % 60).padStart(2, '0')}` : '--:--'}</span>
        </div>
      </div>

      <button class="master-mute" aria-label="Mute all">🔊</button>
    </div>
  </div>

  <div class="layers">
    {stems.map((stem, index) => (
      <div class="layer" data-stem-id={stem.id}>
        <div class="layer-label">
          <span class="layer-name">{stem.label}</span>
          <div class="layer-visual" aria-hidden="true">
            <div class="bars">
              <div class="bar"></div>
              <div class="bar"></div>
              <div class="bar"></div>
              <div class="bar"></div>
            </div>
          </div>
        </div>

        <div class="layer-controls">
          <button class="btn mute-btn" data-action="mute" aria-label={`Silenciar ${stem.label}`}>
            Mute
          </button>
          <button class="btn solo-btn" data-action="solo" aria-label={`Solo ${stem.label}`}>
            Solo
          </button>

          <div class="volume-wrap">
            <input 
              type="range" 
              class="volume" 
              min="0" 
              max="1" 
              step="0.01" 
              value="1" 
              aria-label={`Volumen ${stem.label}`}
            />
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="player-footer">
    <small>Capas sincronizadas • Silencia o aisla cada una</small>
  </div>
</div>

<style>
  .stem-player {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }

  .player-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .player-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .player-title h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 500;
  }

  .player-badge {
    font-size: 0.6rem;
    padding: 0.1rem 0.4rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-radius: 3px;
    letter-spacing: 0.5px;
    font-weight: 600;
  }

  .master-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 260px;
  }

  .play-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--color-accent-light);
    border: 1px solid rgb(201 169 98 / 0.3);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .play-btn:hover {
    background: rgb(201 169 98 / 0.2);
  }

  .timeline {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .seek {
    flex: 1;
    accent-color: var(--color-accent);
  }

  .time {
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    color: var(--color-muted);
    white-space: nowrap;
    min-width: 70px;
    text-align: right;
  }

  .layers {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .layer {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    background: var(--color-bg-elevated);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .layer-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .layer-name {
    font-weight: 500;
    font-size: 0.9rem;
    min-width: 90px;
  }

  .layer-visual {
    flex: 1;
    height: 18px;
    background: #1a1a1f;
    border-radius: 3px;
    overflow: hidden;
    position: relative;
  }

  .bars {
    display: flex;
    align-items: flex-end;
    height: 100%;
    gap: 2px;
    padding: 2px;
  }

  .bar {
    flex: 1;
    background: var(--color-accent);
    height: 20%;
    transition: height 0.08s ease;
    opacity: 0.6;
  }

  .layer.playing .bar {
    opacity: 1;
    animation: layer-pulse 1.2s infinite ease-in-out;
  }

  .layer-controls {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .btn {
    font-size: 0.7rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: all 0.15s;
  }

  .btn:hover {
    color: var(--color-fg);
    border-color: var(--color-fg);
  }

  .mute-btn.active {
    background: #3a2a2a;
    color: #ff9b9b;
    border-color: #ff9b9b33;
  }

  .solo-btn.active {
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-color: rgb(201 169 98 / 0.4);
  }

  .volume {
    width: 80px;
    accent-color: var(--color-accent);
  }

  .player-footer {
    margin-top: 0.75rem;
    text-align: center;
    font-size: 0.7rem;
    color: var(--color-muted);
    opacity: 0.7;
  }

  @keyframes layer-pulse {
    0%, 100% { height: 25%; }
    50% { height: 85%; }
  }

  @media (max-width: 640px) {
    .layer {
      grid-template-columns: 1fr;
    }
    .layer-controls {
      justify-content: flex-start;
    }
  }
</style>

<script define:vars={{ playerId }}>
(function() {
  const container = document.getElementById(playerId);
  if (!container) return;

  const stems = JSON.parse(container.dataset.stems || '[]');
  const playBtn = container.querySelector('.play-btn');
  const seek = container.querySelector('.seek');
  const currentTimeEl = container.querySelector('.current');
  const masterMuteBtn = container.querySelector('.master-mute');

  let audioContext;
  let tracks = {};
  let isPlaying = false;
  let startTime = 0;
  let pauseTime = 0;
  let animationFrame;
  let masterGain;

  // Initialize AudioContext on first user gesture
  function getAudioContext() {
    if (!audioContext) {
      audioContext = new (window.AudioContext || window.webkitAudioContext)();
      masterGain = audioContext.createGain();
      masterGain.connect(audioContext.destination);
    }
    return audioContext;
  }

  async function loadTrack(stem) {
    const ctx = getAudioContext();
    const res = await fetch(stem.src);
    const arrayBuffer = await res.arrayBuffer();
    const audioBuffer = await ctx.decodeAudioData(arrayBuffer);

    const source = ctx.createBufferSource();
    source.buffer = audioBuffer;

    const gain = ctx.createGain();
    const analyser = ctx.createAnalyser();
    analyser.fftSize = 32;

    source.connect(gain);
    gain.connect(analyser);
    analyser.connect(masterGain);

    return {
      source,
      gain,
      analyser,
      buffer: audioBuffer,
      volume: 1,
      muted: false,
      solo: false
    };
  }

  async function initTracks() {
    const ctx = getAudioContext();
    tracks = {};

    for (const stem of stems) {
      try {
        tracks[stem.id] = await loadTrack(stem);
      } catch (e) {
        console.warn('Could not load stem', stem.src, e);
      }
    }
  }

  function startAll(offset = 0) {
    const ctx = getAudioContext();
    Object.keys(tracks).forEach(id => {
      const t = tracks[id];
      if (t.source) {
        try { t.source.stop(); } catch (e) {}
      }

      const newSource = ctx.createBufferSource();
      newSource.buffer = t.buffer;

      const gain = t.gain;
      const analyser = t.analyser;

      newSource.connect(gain);

      // reconnect
      gain.disconnect();
      gain.connect(analyser);
      analyser.connect(masterGain);

      t.source = newSource;
      newSource.start(0, offset);
    });
  }

  function stopAll() {
    Object.values(tracks).forEach(t => {
      if (t.source) {
        try { t.source.stop(); } catch (e) {}
      }
    });
  }

  function updateVolumes() {
    const isAnySolo = Object.values(tracks).some(t => t.solo);

    Object.entries(tracks).forEach(([id, t]) => {
      let vol = t.volume;
      if (t.muted) vol = 0;
      if (isAnySolo && !t.solo) vol = 0;
      t.gain.gain.value = vol;
    });
  }

  function updateVisuals() {
    Object.entries(tracks).forEach(([id, t]) => {
      const layerEl = container.querySelector(`[data-stem-id="${id}"]`);
      if (!layerEl) return;

      const bars = layerEl.querySelectorAll('.bar');
      if (!bars.length || !t.analyser) return;

      const data = new Uint8Array(t.analyser.frequencyBinCount);
      t.analyser.getByteFrequencyData(data);

      const avg = data.reduce((a, b) => a + b, 0) / data.length;
      const scale = Math.max(0.15, Math.min(1, avg / 80));

      bars.forEach((bar, i) => {
        const h = scale * (60 + (i % 2) * 30);
        bar.style.height = `${h}%`;
      });
    });
  }

  function updateTime() {
    if (!isPlaying) return;

    const elapsed = (audioContext.currentTime - startTime) + pauseTime;
    const totalDur = parseFloat(container.dataset.duration) || 240;
    const pct = Math.min(100, (elapsed / totalDur) * 100);

    seek.value = pct;

    const mins = Math.floor(elapsed / 60);
    const secs = Math.floor(elapsed % 60);
    currentTimeEl.textContent = `${mins}:${secs.toString().padStart(2, '0')}`;

    updateVisuals();

    animationFrame = requestAnimationFrame(updateTime);
  }

  async function togglePlay() {
    const ctx = getAudioContext();
    if (ctx.state === 'suspended') await ctx.resume();

    if (!Object.keys(tracks).length) {
      await initTracks();
    }

    if (isPlaying) {
      stopAll();
      pauseTime = (audioContext.currentTime - startTime) + pauseTime;
      isPlaying = false;
      cancelAnimationFrame(animationFrame);
      playBtn.querySelector('.play-icon').hidden = false;
      playBtn.querySelector('.pause-icon').hidden = true;
      container.querySelectorAll('.layer').forEach(l => l.classList.remove('playing'));
    } else {
      const offset = pauseTime;
      startAll(offset);
      startTime = audioContext.currentTime;
      isPlaying = true;
      playBtn.querySelector('.play-icon').hidden = true;
      playBtn.querySelector('.pause-icon').hidden = false;
      container.querySelectorAll('.layer').forEach(l => l.classList.add('playing'));
      updateTime();
    }
  }

  // Event listeners
  playBtn.addEventListener('click', togglePlay);

  seek.addEventListener('input', () => {
    if (!isPlaying || !audioContext) return;
    const pct = parseFloat(seek.value);
    const newTime = (pct / 100) * (duration || 240);

    stopAll();
    pauseTime = newTime;
    startTime = audioContext.currentTime;
    startAll(newTime);
  });

  masterMuteBtn.addEventListener('click', () => {
    const current = masterGain.gain.value;
    masterGain.gain.value = current > 0.01 ? 0 : 1;
    masterMuteBtn.textContent = masterGain.gain.value === 0 ? '🔇' : '🔊';
  });

  // Per-layer controls
  container.querySelectorAll('.layer').forEach(layerEl => {
    const id = layerEl.dataset.stemId;
    const muteBtn = layerEl.querySelector('.mute-btn');
    const soloBtn = layerEl.querySelector('.solo-btn');
    const volSlider = layerEl.querySelector('.volume');

    muteBtn.addEventListener('click', () => {
      if (!tracks[id]) return;
      tracks[id].muted = !tracks[id].muted;
      muteBtn.classList.toggle('active', tracks[id].muted);
      updateVolumes();
    });

    soloBtn.addEventListener('click', () => {
      if (!tracks[id]) return;
      const currentlySolo = tracks[id].solo;
      
      // clear all solos
      Object.values(tracks).forEach(t => t.solo = false);
      container.querySelectorAll('.solo-btn').forEach(b => b.classList.remove('active'));

      tracks[id].solo = !currentlySolo;
      if (tracks[id].solo) soloBtn.classList.add('active');

      updateVolumes();
    });

    volSlider.addEventListener('input', (e) => {
      if (!tracks[id]) return;
      tracks[id].volume = parseFloat(e.target.value);
      updateVolumes();
    });
  });

  // Keyboard support
  document.addEventListener('keydown', (e) => {
    if (e.target.tagName === 'INPUT') return;
    if (e.key === ' ' || e.key === 'k') {
      e.preventDefault();
      togglePlay();
    }
  });

  // Cleanup
  window.addEventListener('beforeunload', () => {
    if (isPlaying) stopAll();
  });
})();
</script>