---
import Layout from "../../../components/Layout.astro";
import LibraryBrowser from "../../../components/LibraryBrowser.astro";
import { getLibraryItems } from "../../../lib/library";
import type { Locale } from "../../../i18n/translations";
import { useTranslations } from "../../../lib/locale";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }, { params: { lang: "fr" } }];
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);
const items = getLibraryItems();
---

<Layout title={t("libTitle")} description={t("libDesc")} lang={lang}>
  <div class="container">
    <header class="hero">
      <p class="hero__eyebrow">{t("libEyebrow")}</p>
      <h1 class="hero__title">{t("libTitle")}</h1>
      <p class="hero__desc">{t("libDesc")}</p>
      <p class="hero__protect" role="note">
        <span class="hero__protect-tag">Preview protegido</span>
        {t("musicLicensePreviewNote")}
      </p>
    </header>
    <LibraryBrowser items={items} lang={lang} />
  </div>
</Layout>

<style>
  .hero {
    max-width: 40rem;
    margin-bottom: 2rem;
  }

  .hero__eyebrow {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-warm);
  }

  .hero__title {
    margin: 0.5rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 500;
  }

  .hero__desc {
    margin: 0.75rem 0 0;
    color: var(--color-muted);
    line-height: 1.65;
  }

  .hero__protect {
    margin: 1.15rem 0 0;
    max-width: 40rem;
    padding: 0.9rem 1.05rem;
    border-radius: 12px;
    border: 1px solid rgb(201 169 98 / 0.5);
    background:
      linear-gradient(145deg, rgb(201 169 98 / 0.2), rgb(201 169 98 / 0.06) 60%),
      var(--color-surface, #121018);
    box-shadow:
      0 0 0 1px rgb(201 169 98 / 0.15),
      0 0 32px rgb(201 169 98 / 0.28),
      0 0 64px rgb(201 169 98 / 0.12);
    font-size: 0.92rem;
    line-height: 1.55;
    color: #f2e4bc;
    text-shadow: 0 0 20px rgb(201 169 98 / 0.4);
  }

  .hero__protect-tag {
    display: inline-block;
    margin: 0 0.45rem 0.4rem 0;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0a0a0c;
    background: #c9a962;
    box-shadow: 0 0 18px rgb(201 169 98 / 0.65);
  }
</style>
