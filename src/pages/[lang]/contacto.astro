---
import Layout from "../../components/Layout.astro";
import { site } from "../../lib/site";
import {
  buildLicenseMailto,
  getPublishedReleases,
  getReleaseLicense,
} from "../../lib/music";
import type { Locale } from "../../i18n/translations";
import { useTranslations } from "../../lib/locale";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }, { params: { lang: "fr" } }];
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

/** Prefill maps for static hosting (query params read client-side). */
const licensePrefill: Record<
  string,
  { name: string; mailto: string; tiers: Record<string, string> }
> = {};

for (const release of getPublishedReleases()) {
  const tiers: Record<string, string> = {};
  for (const tier of getReleaseLicense(release).tiers) {
    tiers[tier.id] = buildLicenseMailto(site.email, release, lang, tier.id);
  }
  licensePrefill[release.slug] = {
    name: release.name,
    mailto: buildLicenseMailto(site.email, release, lang),
    tiers,
  };
}
---

<Layout title={t("contactTitle")} description={`Contacta con ${site.name}`} lang={lang}>
  <div class="container page">
    <p class="eyebrow">{t("contactEyebrow")}</p>
    <h1 class="title">{t("contactTitle")}</h1>

    <aside class="license-hint" id="license-hint" hidden role="note">
      <p>
        <strong>{t("musicLicenseTitle")}:</strong>
        <span id="license-hint-name"></span>
      </p>
      <a id="license-hint-cta" class="license-hint__cta" href={`mailto:${site.email}`}>
        {t("musicLicenseCta")}
      </a>
    </aside>

    <div class="cards">
      <section class="card">
        <h2>{t("contactEmail")}</h2>
        <p>
          <a id="contact-email" href={`mailto:${site.email}`}>{site.email}</a>
        </p>
      </section>

      {
        site.social.github && (
          <section class="card">
            <h2>{t("contactGithub")}</h2>
            <p>
              <a href={site.social.github} target="_blank" rel="noopener noreferrer">
                {site.social.github.replace("https://github.com/", "@")}
              </a>
            </p>
          </section>
        )
      }

      {
        site.social.instagram ? (
          <section class="card">
            <h2>{t("contactInstagram")}</h2>
            <p>
              <a href={site.social.instagram} target="_blank" rel="noopener noreferrer">
                Instagram
              </a>
            </p>
          </section>
        ) : (
          <section class="card card--muted">
            <h2>{t("contactNetworks")}</h2>
            <p>{t("contactAddNetworks")}</p>
          </section>
        )
      }
    </div>
  </div>
</Layout>

<script define:vars={{ licensePrefill }}>
  const applyLicensePrefill = () => {
    const params = new URLSearchParams(window.location.search);
    const work = (params.get("work") || "").trim();
    const tier = (params.get("tier") || "").trim();
    if (!work || !licensePrefill[work]) return;

    const entry = licensePrefill[work];
    const mailto = (tier && entry.tiers[tier]) || entry.mailto;
    const label = tier ? `${entry.name} · ${tier}` : entry.name;

    const hint = document.getElementById("license-hint");
    const nameEl = document.getElementById("license-hint-name");
    const cta = document.getElementById("license-hint-cta");
    const email = document.getElementById("contact-email");

    if (nameEl) nameEl.textContent = label;
    if (cta instanceof HTMLAnchorElement) cta.href = mailto;
    if (email instanceof HTMLAnchorElement) email.href = mailto;
    if (hint) hint.hidden = false;
  };

  document.addEventListener("DOMContentLoaded", applyLicensePrefill);
  document.addEventListener("astro:page-load", applyLicensePrefill);
</script>

<style>
  .page {
    max-width: 42rem;
  }

  .eyebrow {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-warm);
  }

  .title {
    margin: 0.5rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
  }

  .license-hint {
    margin-top: 1.5rem;
    padding: 1rem 1.15rem;
    border-radius: var(--radius);
    border: 1px solid rgb(201 169 98 / 0.28);
    background: var(--color-accent-light);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
  }

  .license-hint p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--color-accent);
  }

  .license-hint__cta {
    display: inline-flex;
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: #0a0a0c;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
  }

  .license-hint__cta:hover {
    filter: brightness(1.08);
  }

  .cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .card {
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .card h2 {
    margin: 0 0 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .card p {
    margin: 0;
    font-size: 1rem;
  }

  .card a {
    color: var(--color-accent);
    font-weight: 500;
    text-decoration: none;
  }

  .card a:hover {
    text-decoration: underline;
  }

  .card--muted p {
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  code {
    font-size: 0.85em;
    background: var(--color-accent-light);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }
</style>
