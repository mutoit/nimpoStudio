---
import Layout from "../../components/Layout.astro";
import PageFrame from "../../components/PageFrame.astro";
import { site } from "../../lib/site";
import type { Locale } from "../../i18n/translations";
import { useTranslations, localizePath } from "../../lib/locale";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }, { params: { lang: "fr" } }];
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const libraryHref = localizePath("/biblioteca", lang);
const contactHref = localizePath("/contacto", lang);
---

<Layout title={site.name} description={t("siteDescription")} lang={lang}>
  <PageFrame lang={lang}>
    <div class="page">
      <section class="section section--pad">
        <div class="container">
          <header class="hero prose">
            <p class="hero__eyebrow">{t("siteTagline")}</p>
            <h1 class="hero__title">{site.name}</h1>
            <p class="hero__lead">{t("siteDescription")}</p>
            <div class="hero__actions">
              <a href={libraryHref} class="btn btn--primary">{t("homeLibrary")}</a>
              <a href={contactHref} class="btn btn--ghost">{t("homeContact")}</a>
            </div>
          </header>
        </div>
      </section>

      <section class="section section--pad">
        <div class="container">
          <div class="note prose">
            <p>{t("homeStoreNote")}</p>
          </div>
        </div>
      </section>
    </div>
  </PageFrame>
</Layout>

<style>
  .page {
    padding-block: 0 4rem;
  }

  .hero__eyebrow {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
  }

  .hero__title {
    margin: 0.75rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: 0.02em;
  }

  .hero__lead {
    margin: 1.25rem 0 0;
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-muted);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.35rem;
    border-radius: var(--radius);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.2s, background 0.2s, border-color 0.2s;
  }

  .btn--primary {
    background: var(--color-accent-light);
    border: 1px solid rgb(201 169 98 / 0.35);
    color: var(--color-accent);
  }

  .btn--primary:hover {
    background: rgb(201 169 98 / 0.2);
  }

  .btn--ghost {
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    background: var(--color-surface);
  }

  .btn--ghost:hover {
    color: var(--color-fg);
    border-color: var(--color-fg);
  }

  .note {
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .note p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-muted);
  }
</style>
