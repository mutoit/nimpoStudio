---
import Layout from "../../../components/Layout.astro";
import MusicMidiBadge from "../../../components/MusicMidiBadge.astro";
import MusicLicense from "../../../components/MusicLicense.astro";
import MusicTracklist from "../../../components/MusicTracklist.astro";
import StemPlayer from "../../../components/StemPlayer.astro";
import ShareButton from "../../../components/ShareButton.astro";
import {
  getReleaseBySlug,
  getStaticMusicPaths,
  getTrackCount,
  getReleaseTypeLabels,
  isProvisionalRelease,
} from "../../../lib/music";
import type { Locale } from "../../../i18n/translations";
import { useTranslations, localizePath } from "../../../lib/locale";

export function getStaticPaths() {
  const langs: Locale[] = ["es", "en", "fr"];
  const paths: any[] = [];
  const musicPaths = getStaticMusicPaths();
  for (const lang of langs) {
    for (const m of musicPaths) {
      paths.push({ params: { lang, slug: m.params.slug } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params as { lang: Locale; slug: string };
const t = useTranslations(lang);
const releaseTypeLabels = getReleaseTypeLabels(lang);

const release = getReleaseBySlug(slug);

if (!release) {
  return Astro.redirect(localizePath("/musica", lang));
}

const musicHref = localizePath("/musica", lang);
const releaseHref = localizePath(`/musica/${release.slug}`, lang);

const firstTrack = release?.tracks?.[0];
const hasStems = !!(firstTrack?.stems && firstTrack.stems.length > 0);
const provisional = release ? isProvisionalRelease(release) : false;
const shareText = `${release.name} — ${release.shortDescription}`;
---

<Layout
  title={release.name}
  description={release.shortDescription}
  image={release.cover}
  lang={lang}
>
  <div class="container">
    <nav class="breadcrumb" aria-label={t("navMusic")}>
      <a href={musicHref}>{t("navMusic")}</a>
      <span aria-hidden="true">/</span>
      <span>{release.name}</span>
    </nav>

    <article class="release">
      <div class="release__visual">
        {release.video ? (
          <video
            src={release.video}
            poster={release.cover}
            class="release__cover release__video"
            autoplay
            loop
            muted
            playsinline
          ></video>
        ) : (
          <img
            src={release.cover}
            alt={`Portada de ${release.name}`}
            width={480}
            height={480}
            class="release__cover"
          />
        )}
        <dl class="release__meta">
          <div>
            <dt>{t("musicFormat")}</dt>
            <dd>{releaseTypeLabels[release.type]}</dd>
          </div>
          <div>
            <dt>{t("musicYear")}</dt>
            <dd>{release.year}</dd>
          </div>
          <div>
            <dt>{t("musicTracks")}</dt>
            <dd>{getTrackCount(release)}</dd>
          </div>
        </dl>
      </div>

      <div class="release__content">
        <MusicMidiBadge size="inline" lang={lang} />
        <h1 class="release__title">{release.name}</h1>
        {
          provisional && (
            <p class="release__badge release__badge--provisional">{t("badgeProvisional")}</p>
          )
        }
        {
          !provisional && release.status === "coming-soon" && (
            <p class="release__badge">{t("musicSoon")}</p>
          )
        }
        {
          provisional && (
            <p class="release__provisional-note" role="status">{t("provisionalNotice")}</p>
          )
        }
        <p class="release__lead">
          {t("musicOriginal")} {release.shortDescription}
        </p>
        <div class="release__presentation">
          <h2 class="release__presentation-title">{t("musicPresentation")}</h2>
          <p>{release.description}</p>
        </div>
        {
          release.tags.length > 0 && (
            <ul class="release__tags">
              {release.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          )
        }
        <div class="release__actions">
          <a href="#licencias" class="release__license-btn">
            {t("musicLicenseOpen")}
          </a>
          <ShareButton
            url={releaseHref}
            title={release.name}
            text={shareText}
            label={t("share")}
            copiedLabel={t("shareCopied")}
            failedLabel={t("shareFailed")}
            variant="ghost"
          />
        </div>
      </div>
    </article>

    {
      hasStems && (
        <div class="stems-section">
          <h2 class="stems-title">Reproductor por capas</h2>
          <p class="stems-desc">Silencia o aísla cada capa individualmente. Todo sincronizado.</p>
          <StemPlayer 
            title={firstTrack.title}
            stems={firstTrack.stems}
            releaseSlug={release.slug}
          />
          <small class="stems-note">* Demo usando archivos de preview. Reemplaza con tus stems reales (un archivo por capa).</small>
        </div>
      )
    }

    <MusicTracklist
      tracks={release.tracks}
      releaseName={release.name}
      releaseSlug={release.slug}
      lang={lang}
    />

    <MusicLicense release={release} lang={lang} />

    <p class="notice">
      {release.status === "coming-soon" ? t("musicSoon") : t("musicNotice")}
    </p>

    <a href={musicHref} class="back">{t("musicBack")}</a>
  </div>
</Layout>

<style>
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .breadcrumb a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-fg);
  }

  .release {
    display: grid;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 900px) {
    .release {
      grid-template-columns: minmax(16rem, 22rem) 1fr;
      gap: 3rem;
      align-items: start;
    }
  }

  .release__cover {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--glow);
    aspect-ratio: 1;
    object-fit: cover;
  }

  /* Portrait 9:16 video cover (portada en loop) */
  .release__video {
    aspect-ratio: 9 / 16;
    max-width: 280px;
    width: 100%;
    margin: 0;
    display: block;
    object-fit: cover;
    box-shadow: var(--glow);
  }

  .release__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    margin: 1rem 0 0;
    padding: 0.6rem 0.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    font-size: 0.8rem;
  }

  .release__meta > div {
    display: flex;
    flex-direction: column;
    min-width: 52px;
  }

  .release__meta dt {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .release__meta dd {
    margin: 0.25rem 0 0;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .release__title {
    margin: 0.85rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 500;
    line-height: 1.05;
  }

  .release__badge {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .release__badge--provisional {
    background: rgb(60 28 12 / 0.95);
    color: #ffb38a;
    border: 1px solid rgb(255 140 80 / 0.5);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.75rem;
  }

  .release__provisional-note {
    margin: 0.85rem 0 0;
    padding: 0.75rem 0.9rem;
    border-radius: var(--radius);
    border: 1px solid rgb(255 140 80 / 0.35);
    background: rgb(255 140 80 / 0.1);
    color: #ffc9a8;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .release__lead {
    margin: 1rem 0 0;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-muted);
  }

  .release__presentation {
    margin-top: 1.75rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
  }

  .release__presentation-title {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent-dim);
  }

  .release__presentation p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-muted);
  }

  .release__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .release__tags li {
    padding: 0.25rem 0.55rem;
    border-radius: var(--radius);
    background: var(--color-accent-light);
    color: var(--color-accent-dim);
    font-size: 0.75rem;
  }

  .release__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
    margin-top: 1.35rem;
  }

  .release__license-btn {
    display: inline-flex;
    padding: 0.65rem 1.15rem;
    border-radius: 999px;
    border: 1px solid rgb(201 169 98 / 0.45);
    background: rgb(201 169 98 / 0.12);
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
  }

  .release__license-btn:hover {
    background: rgb(201 169 98 / 0.2);
  }

  .notice {
    margin: 2rem 0 0;
    padding: 1rem 1.25rem;
    border-radius: var(--radius);
    border: 1px solid rgb(201 169 98 / 0.2);
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .stems-section {
    margin: 2rem 0 3rem;
  }

  .stems-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    color: var(--color-accent-dim);
  }

  .stems-desc {
    margin: 0 0 1rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .stems-note {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: var(--color-muted);
    opacity: 0.6;
  }

  .notice a {
    color: inherit;
    font-weight: 600;
  }

  .back {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-fg);
  }

  .back:hover {
    color: var(--color-accent);
  }
</style>