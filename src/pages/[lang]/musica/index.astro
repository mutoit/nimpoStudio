---
import Layout from "../../../components/Layout.astro";
import MusicCard from "../../../components/MusicCard.astro";
import MusicMidiBadge from "../../../components/MusicMidiBadge.astro";
import { getPublishedReleases } from "../../../lib/music";
import { site } from "../../../lib/site";
import type { Locale } from "../../../i18n/translations";
import { useTranslations, localizePath } from "../../../lib/locale";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }, { params: { lang: "fr" } }];
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const releases = getPublishedReleases();
const musicDetailBase = localizePath("/musica", lang);
---

<Layout
  title={`${t("musicTitle")} — ${t("musicSubtitle")}`}
  description={t("musicDesc")}
  lang={lang}
>
  <div class="container">
    <header class="hero">
      <MusicMidiBadge lang={lang} />
      <h1 class="hero__title">{t("musicTitle")}</h1>
      <p class="hero__desc">
        {t("musicDesc")}
      </p>
    </header>

    {
      releases.length === 0 ? (
        <div class="empty">
          <p class="empty__title">{t("musicEmptyTitle")}</p>
          <p class="empty__desc">{t("musicEmptyDesc")}</p>
        </div>
      ) : (
        <ul class="grid">
          {releases.map((release) => (
            <li>
              <MusicCard release={release} lang={lang} />
            </li>
          ))}
        </ul>
      )
    }

    <p class="hint">
      {t("musicHint")}
    </p>
  </div>
</Layout>

<style>
  .hero {
    max-width: 40rem;
    margin-bottom: 2.5rem;
  }

  .hero__title {
    margin: 1.15rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 500;
    line-height: 1.05;
  }

  .hero__desc {
    margin: 1rem 0 0;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .hero__desc strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .grid {
    display: grid;
    gap: 2.5rem 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .empty {
    padding: 4rem 2rem;
    text-align: center;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }

  .empty__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.5rem;
  }

  .empty__desc {
    margin: 0.5rem 0 0;
    color: var(--color-muted);
  }

  .hint {
    margin: 3rem 0 0;
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  code {
    font-size: 0.85em;
    background: var(--color-accent-light);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }
</style>