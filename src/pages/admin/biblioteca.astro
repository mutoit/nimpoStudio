---
/**
 * Panel de subida (solo estudio).
 * Protección real: functions/_middleware.ts + cookie firmada (ADMIN_LIBRARY_SECRET).
 * Opcional extra: Cloudflare Access delante de /admin/*.
 * No aparece en el menú público.
 */
import Layout from "../../components/Layout.astro";
---

<Layout title="Admin biblioteca" description="Panel privado de biblioteca" lang="es">
  <div class="container admin">
    <header class="head">
      <div>
        <p class="eyebrow">Privado · no indexar</p>
        <h1>Subida biblioteca</h1>
      </div>
      <button type="button" class="btn btn--ghost" data-logout>Cerrar sesión</button>
    </header>

    <p class="lead">
      Solo accesible con contraseña de servidor (y opcionalmente Cloudflare Access). Elige canal,
      rellena metadatos y genera el bloque JSON. Copia archivos a
      <code>public/library/</code> y pega el ítem en <code>src/data/library.json</code>.
    </p>

    <div class="workspace" data-workspace>
      <div class="channels">
        <button type="button" class="chip is-active" data-channel="video">
          Canal vídeo (1:1 / 9:16)
        </button>
        <button type="button" class="chip" data-channel="stems">Canal stems</button>
      </div>

      <form class="form" data-admin-form>
        <label>
          Título *
          <input name="title" required />
        </label>
        <label>
          Slug (url)
          <input name="slug" placeholder="auto-desde-titulo" />
        </label>

        <div data-video-fields>
          <label>
            Aspecto
            <select name="aspect">
              <option value="1:1">1:1</option>
              <option value="9:16">9:16</option>
              <option value="16:9">16:9</option>
            </select>
          </label>
          <label>
            Nombre archivo vídeo (en public/library/)
            <input name="videoFile" placeholder="mi-clip.mp4" />
          </label>
          <label>
            Cover / miniatura (opcional)
            <input name="coverFile" placeholder="mi-clip.jpg" />
          </label>
        </div>

        <div data-stems-fields hidden>
          <label>
            Cover
            <input name="stemsCover" placeholder="umbral.jpg" />
          </label>
          <label>
            Stems (una línea: id | etiqueta | archivo.mp3)
            <textarea
              name="stemsLines"
              rows="5"
              placeholder="pads | Pads & Ambiente | umbral-pads.mp3
bass | Bajo | umbral-bass.mp3"></textarea>
          </label>
        </div>

        <fieldset class="chips-field">
          <legend>Moods (elige)</legend>
          <div class="pick" data-mood-picks>
            {
              [
                "oscuro",
                "orgánico",
                "inmersivo",
                "nocturno",
                "lento",
                "energético",
                "etérea",
                "apertura",
                "cinematic",
                "minimal",
              ].map((m) => (
                <label class="pick-item">
                  <input type="checkbox" name="moodPick" value={m} />
                  {m}
                </label>
              ))
            }
          </div>
        </fieldset>

        <fieldset class="chips-field">
          <legend>Tags (elige)</legend>
          <div class="pick" data-tag-picks>
            {
              [
                "ambient",
                "cinematic",
                "forest",
                "immersive",
                "electronic",
                "groove",
                "pads",
                "nocturno",
                "strings",
                "synth",
              ].map((t) => (
                <label class="pick-item">
                  <input type="checkbox" name="tagPick" value={t} />
                  {t}
                </label>
              ))
            }
          </div>
        </fieldset>

        <label>
          Descripción
          <textarea name="description" rows="2"></textarea>
        </label>
        <label>
          Notas / comentarios (panel lateral público)
          <textarea name="notes" rows="2" placeholder="Lo que verá el cliente en el panel"></textarea>
        </label>
        <label class="check">
          <input type="checkbox" name="licenseEnabled" checked /> Licencia habilitada (formulario)
        </label>
        <label class="check">
          <input type="checkbox" name="provisional" checked /> Provisional / demo
        </label>
        <label>
          Año
          <input name="year" type="number" value="2026" />
        </label>

        <button type="submit" class="btn btn--gold">Generar JSON + instrucciones</button>
      </form>

      <pre class="out" data-out hidden></pre>
      <button type="button" class="btn" data-copy hidden>Copiar JSON</button>
    </div>
  </div>
</Layout>

<script>
  document.querySelector("[data-logout]")?.addEventListener("click", async () => {
    await fetch("/admin/session", { method: "DELETE", credentials: "same-origin" });
    location.href = "/admin/biblioteca/";
  });

  let channel: "video" | "stems" = "video";
  document.querySelectorAll("[data-channel]").forEach((btn) => {
    btn.addEventListener("click", () => {
      channel = ((btn as HTMLElement).dataset.channel as "video" | "stems") || "video";
      document.querySelectorAll("[data-channel]").forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      const vf = document.querySelector("[data-video-fields]");
      const sf = document.querySelector("[data-stems-fields]");
      if (vf instanceof HTMLElement) vf.hidden = channel !== "video";
      if (sf instanceof HTMLElement) sf.hidden = channel !== "stems";
    });
  });

  const slugify = (s: string) =>
    s
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/(^-|-$)/g, "");

  document.querySelector("[data-admin-form]")?.addEventListener("submit", (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);
    const title = String(fd.get("title") || "").trim();
    const slug = String(fd.get("slug") || "").trim() || slugify(title);
    const moods = fd.getAll("moodPick").map(String);
    const tags = fd.getAll("tagPick").map(String);

    const item: Record<string, unknown> = {
      id: `lib-${slug}`,
      slug,
      title,
      kind: channel === "stems" ? "stems" : "video",
      aspect: channel === "stems" ? "1:1" : String(fd.get("aspect") || "1:1"),
      tags,
      moods,
      description: String(fd.get("description") || "").trim(),
      notes: String(fd.get("notes") || "").trim(),
      year: Number(fd.get("year") || 2026),
      provisional: fd.get("provisional") === "on",
      licenseEnabled: fd.get("licenseEnabled") === "on",
    };

    if (channel === "video") {
      const vf = String(fd.get("videoFile") || "").trim();
      const cf = String(fd.get("coverFile") || "").trim();
      item.video = vf ? `/library/${vf}` : null;
      item.cover = cf ? `/library/${cf}` : null;
    } else {
      const sc = String(fd.get("stemsCover") || "").trim();
      item.cover = sc ? `/library/${sc}` : null;
      item.video = null;
      const lines = String(fd.get("stemsLines") || "")
        .split("\n")
        .map((l) => l.trim())
        .filter(Boolean);
      item.stems = lines.map((line) => {
        const [id, label, file] = line.split("|").map((x) => x.trim());
        return {
          id: id || "stem",
          label: label || id || "Stem",
          src: file ? `/library/${file}` : "",
        };
      });
    }

    const out = document.querySelector("[data-out]");
    const copy = document.querySelector("[data-copy]");
    const json = JSON.stringify(item, null, 2);
    const instructions = [
      "1) Copia los archivos a public/library/ (o public/previews/music/ si reutilizas previews).",
      "2) Pega este objeto (con coma) dentro del array de src/data/library.json",
      "3) npm run build && npm run deploy (o push a main)",
      "",
      json,
    ].join("\n");
    if (out instanceof HTMLElement) {
      out.hidden = false;
      out.textContent = instructions;
    }
    if (copy instanceof HTMLElement) copy.hidden = false;
  });

  document.querySelector("[data-copy]")?.addEventListener("click", async () => {
    const out = document.querySelector("[data-out]");
    const t = out?.textContent || "";
    const m = t.match(/\{[\s\S]*\}\s*$/);
    if (m) await navigator.clipboard.writeText(m[0]);
  });
</script>

<style>
  .admin {
    max-width: 40rem;
    padding-block: 2rem 4rem;
  }
  .head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .eyebrow {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  h1 {
    margin: 0.35rem 0 0;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 500;
  }
  .lead {
    margin: 1rem 0 1.5rem;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .lead code {
    font-size: 0.85em;
    color: var(--color-accent);
  }
  .channels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .chip {
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-muted);
    font: inherit;
    font-size: 0.8rem;
    cursor: pointer;
  }
  .chip.is-active {
    border-color: rgb(201 169 98 / 0.45);
    color: var(--color-accent);
    background: var(--color-accent-light);
  }
  .form {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .form label,
  .form fieldset {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--color-muted);
  }
  .form input,
  .form select,
  .form textarea {
    padding: 0.55rem 0.7rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    color: var(--color-fg);
    font: inherit;
  }
  .form .check {
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }
  .chips-field {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.75rem;
    margin: 0;
  }
  .chips-field legend {
    padding: 0 0.35rem;
    font-size: 0.75rem;
  }
  .pick {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .pick-item {
    flex-direction: row !important;
    align-items: center;
    gap: 0.3rem !important;
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    font-size: 0.75rem !important;
    cursor: pointer;
  }
  .btn {
    display: inline-flex;
    justify-content: center;
    padding: 0.65rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-fg);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }
  .btn--gold {
    background: var(--color-accent-light);
    border-color: rgb(201 169 98 / 0.4);
    color: var(--color-accent);
  }
  .btn--ghost {
    font-size: 0.8rem;
    font-weight: 500;
    opacity: 0.85;
  }
  .out {
    margin-top: 1.25rem;
    padding: 1rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: #0c0c10;
    font-size: 0.75rem;
    overflow: auto;
    white-space: pre-wrap;
  }
</style>
