---
/**
 * Panel de publicación (solo estudio).
 * Un clic: sube media a R2 + actualiza catálogo vivo → se ve en /es/biblioteca/
 */
import Layout from "../../components/Layout.astro";
---

<Layout title="Admin biblioteca" description="Panel privado de biblioteca" lang="es">
  <div class="container admin">
    <header class="head">
      <div>
        <p class="eyebrow">Privado · no indexar</p>
        <h1>Publicar en biblioteca</h1>
      </div>
      <button type="button" class="btn btn--ghost" data-logout>Cerrar sesión</button>
    </header>

    <p class="lead">
      Publica, edita o borra desde aquí. Miniaturas a la derecha. Biblioteca pública:
      <a href="/es/biblioteca/" target="_blank" rel="noopener">/es/biblioteca/</a>
    </p>

    <div class="admin-layout">
    <div class="workspace" data-workspace>
      <div class="edit-bar" data-edit-bar hidden>
        <span data-edit-label>Editando…</span>
        <button type="button" class="btn btn--sm" data-edit-cancel>Cancelar</button>
      </div>

      <div class="channels">
        <button type="button" class="chip is-active" data-channel="video">
          Canal vídeo
        </button>
        <button type="button" class="chip" data-channel="stems">Canal stems</button>
      </div>

      <form class="form" data-admin-form>
        <label>
          Título *
          <input name="title" required data-title />
        </label>
        <label>
         Slug (url)
          <input name="slug" placeholder="auto-desde-titulo" data-slug />
        </label>

        <label>
          Aspecto
          <select name="aspect">
            <option value="1:1">1:1</option>
            <option value="9:16">9:16</option>
            <option value="16:9">16:9</option>
          </select>
        </label>

        <div data-video-fields>
          <div class="media-status" data-status-video hidden role="status"></div>
          <label class="file-label">
            Vídeo (mp4 / webm) *
            <input type="file" accept="video/mp4,video/webm,video/*" data-video-file required />
          </label>
          <div class="preview" data-video-preview hidden></div>
          <label class="file-label">
            Miniatura imagen (opcional)
            <input type="file" accept="image/*" data-cover-file />
          </label>
          <p class="hint">
            No hace falta si subes vídeo: la tarjeta usa el vídeo (primer fotograma). La imagen solo
            ayuda a cargar más rápido o si quieres un still fijo.
          </p>
          <div class="preview preview--img" data-cover-preview hidden></div>
        </div>

        <div data-stems-fields hidden>
          <div class="media-status" data-status-stems-visual hidden role="status"></div>
          <label class="file-label">
            Vídeo de fondo / visual (opcional)
            <input type="file" accept="video/mp4,video/webm,video/*" data-stems-video />
          </label>
          <div class="preview" data-stems-video-preview hidden></div>
          <label class="file-label">
            Miniatura imagen (opcional)
            <input type="file" accept="image/*" data-stems-cover />
          </label>
          <p class="hint">
            Con vídeo basta para la miniatura. La imagen es opcional (poster / carga más ligera).
            Lo obligatorio son las capas de audio.
          </p>
          <div class="preview preview--img" data-stems-cover-preview hidden></div>
          <div class="stems-box">
            <div class="stems-head">
              <span>Capas (stems) *</span>
              <button type="button" class="btn btn--sm" data-add-stem>+ Fila vacía</button>
            </div>
            <div class="media-status" data-status-stems hidden role="status"></div>
            <div
              class="dropzone"
              data-stems-drop
              tabindex="0"
              role="button"
              aria-label="Arrastra stems de audio aquí"
            >
              <input
                type="file"
                accept="audio/*,.mp3,.wav,.m4a,.ogg,.aac"
                multiple
                hidden
                data-stems-pick
              />
              <p class="dropzone__title">Arrastra aquí los stems</p>
              <p class="dropzone__sub">mp3 / wav / m4a · varios a la vez · o haz clic</p>
            </div>
            <div class="stems-list" data-stems-list></div>
          </div>

        </div>

        <!-- Mezcla audible (vídeo o stems) → se incrusta al publicar stems -->
        <div class="mix-preview" data-mix-preview>
          <p class="mix-preview__title">Escuchar mezcla (audio + ruido)</p>
          <p class="mix-protect" role="note">
            El ruido se pone <strong>a propósito para proteger el audio</strong> en la web. El
            visitante oirá esa mezcla (no el master limpio). En <strong>stems</strong> se incrusta
            al publicar; en vídeo es solo referencia de escucha.
          </p>
          <p class="hint">
            Ajusta volúmenes y dale a play hasta que el balance te convenza, luego publica.
          </p>
          <label class="mix-slider">
            <span>Volumen audio <em data-music-pct>100%</em></span>
            <input
              type="range"
              min="0"
              max="100"
              value="100"
              step="1"
              data-music-level
              aria-label="Volumen de tu audio"
            />
          </label>
          <label class="mix-slider">
            <span>Volumen ruido <em data-noise-pct>12%</em></span>
            <input
              type="range"
              min="0"
              max="40"
              value="12"
              step="1"
              data-noise-level
              aria-label="Volumen de ruido de preview"
            />
          </label>
          <div class="mix-actions">
            <button type="button" class="btn btn--gold" data-mix-play>▶ Escuchar</button>
            <button type="button" class="btn btn--sm" data-mix-stop>Stop</button>
          </div>
          <p class="mix-msg" data-mix-msg hidden></p>
        </div>

        <fieldset class="chips-field">
          <legend>Moods</legend>
          <p class="hint">
            Marca el mood de la obra. El check <strong>filtro</strong> lo muestra en la biblioteca
            pública.
          </p>
          <div class="pick" data-mood-pick>
            {
              [
                "oscuro",
                "orgánico",
                "inmersivo",
                "nocturno",
                "lento",
                "energético",
                "etérea",
                "apertura",
                "cinematic",
                "minimal",
              ].map((m) => (
                <div class="pick-item">
                  <label class="pick-main">
                    <input type="checkbox" name="moodPick" value={m} data-chip-main />
                    {m}
                  </label>
                  <label class="pick-filter" title="Mostrar en filtros de biblioteca">
                    <input type="checkbox" name="moodFilter" value={m} data-chip-filter />
                    <span>F</span>
                  </label>
                </div>
              ))
            }
          </div>
          <div class="add-chip">
            <input type="text" placeholder="Nuevo mood…" data-mood-custom maxlength="40" />
            <button type="button" class="btn btn--sm" data-mood-add>Añadir</button>
          </div>
        </fieldset>

        <fieldset class="chips-field">
          <legend>Tags</legend>
          <p class="hint">
            Igual: tag de la obra + opcional <strong>filtro</strong> en la biblioteca.
          </p>
          <div class="pick" data-tag-pick>
            {
              [
                "ambient",
                "cinematic",
                "forest",
                "immersive",
                "electronic",
                "groove",
                "pads",
                "nocturno",
                "strings",
                "synth",
              ].map((t) => (
                <div class="pick-item">
                  <label class="pick-main">
                    <input type="checkbox" name="tagPick" value={t} data-chip-main />
                    {t}
                  </label>
                  <label class="pick-filter" title="Mostrar en filtros de biblioteca">
                    <input type="checkbox" name="tagFilter" value={t} data-chip-filter />
                    <span>F</span>
                  </label>
                </div>
              ))
            }
          </div>
          <div class="add-chip">
            <input type="text" placeholder="Nuevo tag…" data-tag-custom maxlength="40" />
            <button type="button" class="btn btn--sm" data-tag-add>Añadir</button>
          </div>
        </fieldset>

        <label>
          Descripción
          <textarea name="description" rows="2"></textarea>
        </label>
        <label>
          Notas
          <textarea name="notes" rows="2"></textarea>
        </label>
        <label class="check">
          <input type="checkbox" name="licenseEnabled" checked /> Licencia habilitada
        </label>
        <label class="check">
          <input type="checkbox" name="provisional" /> Provisional / demo
        </label>
        <label>
          Año
          <input name="year" type="number" value="2026" />
        </label>

        <p class="hint" data-edit-hint hidden>
          Guardar fusiona cambios: la media que no toques se mantiene. Puedes guardar varias
          veces seguidas.
        </p>
        <button type="submit" class="btn btn--gold" data-publish>
          Publicar en la web
        </button>
        <p class="status" data-status hidden></p>
      </form>
      <!-- Toast fijo de éxito (más tiempo visible) -->
      <div class="toast" data-toast hidden role="status"></div>

      <hr class="sep" />

      <section class="feed-block" data-feed-block>
        <h2 class="subhead">Feed · Novedades (home)</h2>
        <p class="lead lead--sm">
          Aparece en el panel lateral de la home (como en la captura). Título + descripción.
          Se guarda en R2 y se ve al recargar, sin redeploy.
        </p>
        <form class="form" data-feed-form>
          <label>
            Título del aviso *
            <input name="feedTitle" required maxlength="160" placeholder="Web en construcción" data-feed-title />
          </label>
          <label>
            Descripción *
            <textarea
              name="feedSummary"
              required
              maxlength="500"
              rows="3"
              placeholder="Estamos construyendo la web…"
              data-feed-summary
            ></textarea>
          </label>
          <div class="feed-row">
            <label>
              Etiqueta
              <select name="feedTag" data-feed-tag>
                <option value="nuevo">Nuevo</option>
                <option value="mejora">Mejora</option>
                <option value="fix">Fix</option>
                <option value="proximo" selected>Próximo</option>
              </select>
            </label>
            <label>
              Fecha
              <input name="feedDate" type="date" data-feed-date />
            </label>
          </div>
          <button type="submit" class="btn btn--gold" data-feed-publish>
            Publicar en el feed
          </button>
          <p class="status" data-feed-status hidden></p>
        </form>
      </section>

      <pre class="out" data-out hidden></pre>
    </div>

    <aside class="pub-rail" data-pub-rail>
      <div class="pub-rail__head">
        <h2 class="subhead">Publicaciones</h2>
        <button type="button" class="btn btn--sm" data-pub-refresh title="Actualizar">↻</button>
      </div>
      <p class="lead lead--sm">Catálogo vivo · miniaturas</p>
      <div class="pub-frame" data-pub-frame>
        <div class="pub-grid" data-pub-grid>
          <p class="pub-empty">Cargando…</p>
        </div>
        <div class="pub-pager" data-pub-pager hidden>
          <button type="button" class="btn btn--sm" data-pub-prev aria-label="Anterior">‹</button>
          <span class="pub-page" data-pub-page>1 / 1</span>
          <button type="button" class="btn btn--sm" data-pub-next aria-label="Siguiente">›</button>
        </div>
      </div>
    </aside>
    </div>
  </div>
</Layout>

<script>
  import { bakePreviewNoise } from "../../lib/preview-noise-bake";
  import { AdminMixPreview } from "../../lib/admin-mix-preview";

  type StemRow = { label: string; file: File | null };
  const mixPreview = new AdminMixPreview();

  document.querySelector("[data-logout]")?.addEventListener("click", async () => {
    await fetch("/admin/session", { method: "DELETE", credentials: "same-origin" });
    location.href = "/admin/biblioteca/";
  });

  // Fecha por defecto = hoy
  const feedDate = document.querySelector<HTMLInputElement>("[data-feed-date]");
  if (feedDate && !feedDate.value) {
    feedDate.value = new Date().toISOString().slice(0, 10);
  }

  document.querySelector("[data-feed-form]")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector("[data-feed-publish]");
    const status = document.querySelector("[data-feed-status]");
    if (btn instanceof HTMLButtonElement) btn.disabled = true;
    if (status instanceof HTMLElement) {
      status.hidden = false;
      status.textContent = "Publicando feed…";
      status.classList.remove("is-err");
    }
    try {
      const title = String(
        (form.querySelector("[data-feed-title]") as HTMLInputElement)?.value || "",
      ).trim();
      const summary = String(
        (form.querySelector("[data-feed-summary]") as HTMLTextAreaElement)?.value || "",
      ).trim();
      const tag = String(
        (form.querySelector("[data-feed-tag]") as HTMLSelectElement)?.value || "proximo",
      );
      const date = String(
        (form.querySelector("[data-feed-date]") as HTMLInputElement)?.value || "",
      );
      const res = await fetch("/admin/feed", {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ title, summary, tag, date }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) {
        throw new Error(data.message || data.error || `Error ${res.status}`);
      }
      if (status instanceof HTMLElement) {
        status.textContent = `✅ Feed: «${data.item?.title || title}». Abre la home y recarga.`;
      }
      form.reset();
      if (feedDate) feedDate.value = new Date().toISOString().slice(0, 10);
    } catch (err) {
      if (status instanceof HTMLElement) {
        status.textContent = err instanceof Error ? err.message : "Error feed";
        status.classList.add("is-err");
      }
    } finally {
      if (btn instanceof HTMLButtonElement) btn.disabled = false;
    }
  });

  let channel: "video" | "stems" = "video";
  let stemRows: StemRow[] = [];
  /** null = alta nueva; string = editando slug */
  let editingSlug: string | null = null;
  let editingItem: Record<string, unknown> | null = null;
  let publications: Record<string, unknown>[] = [];
  const PUB_PAGE_SIZE = 6;
  let pubPage = 0;

  const slugify = (s: string) =>
    s
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/(^-|-$)/g, "");

  document.querySelectorAll("[data-channel]").forEach((btn) => {
    btn.addEventListener("click", () => {
      setChannel(((btn as HTMLElement).dataset.channel as "video" | "stems") || "video");
    });
  });

  const bindPreview = (inputSel: string, previewSel: string, kind: "video" | "img") => {
    const input = document.querySelector(inputSel);
    const box = document.querySelector(previewSel);
    if (!(input instanceof HTMLInputElement) || !(box instanceof HTMLElement)) return;
    input.addEventListener("change", () => {
      const f = input.files?.[0];
      if (!f) {
        box.hidden = true;
        box.innerHTML = "";
        return;
      }
      const url = URL.createObjectURL(f);
      box.hidden = false;
      box.innerHTML =
        kind === "video"
          ? `<video src="${url}" controls playsinline></video><p class="fname">${f.name}</p>`
          : `<img src="${url}" alt="" /><p class="fname">${f.name}</p>`;
    });
  };
  bindPreview("[data-video-file]", "[data-video-preview]", "video");
  bindPreview("[data-cover-file]", "[data-cover-preview]", "img");
  bindPreview("[data-stems-video]", "[data-stems-video-preview]", "video");
  bindPreview("[data-stems-cover]", "[data-stems-cover-preview]", "img");

  let toastTimer = 0;
  const showToast = (msg: string, ms = 14000) => {
    const toast = document.querySelector("[data-toast]");
    if (!(toast instanceof HTMLElement)) return;
    toast.hidden = false;
    toast.textContent = msg;
    toast.classList.add("is-on");
    window.clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => {
      toast.classList.remove("is-on");
      toast.hidden = true;
    }, ms);
  };

  const setStatus = (msg: string, ok = true) => {
    const el = document.querySelector("[data-status]");
    if (!(el instanceof HTMLElement)) return;
    el.hidden = false;
    el.textContent = msg;
    el.classList.toggle("is-err", !ok);
    if (ok && (msg.startsWith("✅") || msg.includes("Publicado") || msg.includes("Guardado"))) {
      showToast(msg, 16000);
    }
  };

  const stemsList = document.querySelector("[data-stems-list]");
  const isAudioFile = (f: File) => {
    const n = f.name.toLowerCase();
    if (/\.(mp3|wav|m4a|ogg|aac|flac|aiff?)$/.test(n)) return true;
    return (f.type || "").startsWith("audio/");
  };

  const addStemFiles = (files: FileList | File[]) => {
    const list = [...files].filter(isAudioFile);
    if (!list.length) {
      setStatus("Suelta archivos de audio (mp3, wav…)", false);
      return;
    }
    stemRows = stemRows.filter((r) => r.file);
    for (const f of list) {
      stemRows.push({
        label: f.name.replace(/\.[^.]+$/, ""),
        file: f,
      });
    }
    renderStems();
    setStatus(`${list.length} stem(s) añadido(s). Puedes renombrar o quitar filas.`);
  };

  const renderStems = () => {
    if (!stemsList) return;
    if (!stemRows.length) {
      stemsList.innerHTML = `<p class="stems-empty">Aún no hay capas. Arrastra archivos arriba.</p>`;
      return;
    }
    stemsList.innerHTML = stemRows
      .map(
        (row, i) => `
      <div class="stem-row" data-stem-i="${i}">
        <input type="text" placeholder="Etiqueta" value="${(row.label || "").replace(/"/g, "&quot;")}" data-stem-label />
        <span class="stem-fname" title="${row.file ? row.file.name.replace(/"/g, "") : ""}">${row.file ? row.file.name : "sin archivo"}</span>
        <button type="button" class="btn btn--sm btn--danger" data-stem-remove aria-label="Quitar">×</button>
      </div>`,
      )
      .join("");
    stemsList.querySelectorAll(".stem-row").forEach((el) => {
      const i = Number((el as HTMLElement).dataset.stemI);
      el.querySelector("[data-stem-label]")?.addEventListener("input", (ev) => {
        if (stemRows[i]) stemRows[i]!.label = (ev.target as HTMLInputElement).value;
      });
      el.querySelector("[data-stem-remove]")?.addEventListener("click", () => {
        stemRows.splice(i, 1);
        renderStems();
      });
    });
  };

  const drop = document.querySelector("[data-stems-drop]");
  const pick = document.querySelector("[data-stems-pick]");
  if (drop instanceof HTMLElement) {
    const setDrag = (on: boolean) => drop.classList.toggle("is-drag", on);
    ["dragenter", "dragover"].forEach((ev) => {
      drop.addEventListener(ev, (e) => {
        e.preventDefault();
        e.stopPropagation();
        setDrag(true);
      });
    });
    ["dragleave", "drop"].forEach((ev) => {
      drop.addEventListener(ev, (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (ev === "dragleave") setDrag(false);
      });
    });
    drop.addEventListener("drop", (e) => {
      setDrag(false);
      const dt = (e as DragEvent).dataTransfer;
      if (dt?.files?.length) addStemFiles(dt.files);
    });
    drop.addEventListener("click", () => {
      if (pick instanceof HTMLInputElement) pick.click();
    });
    drop.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        if (pick instanceof HTMLInputElement) pick.click();
      }
    });
  }
  if (pick instanceof HTMLInputElement) {
    pick.addEventListener("change", () => {
      if (pick.files?.length) addStemFiles(pick.files);
      pick.value = "";
    });
  }

  document.querySelector("[data-add-stem]")?.addEventListener("click", () => {
    stemRows.push({ label: "", file: null });
    renderStems();
  });
  // Arranque: sin filas; solo drop zone
  stemRows = [];
  renderStems();

  // Mezcla preview: volúmenes audio / ruido
  const musicRange = document.querySelector<HTMLInputElement>("[data-music-level]");
  const noiseRange = document.querySelector<HTMLInputElement>("[data-noise-level]");
  const musicPct = document.querySelector("[data-music-pct]");
  const noisePct = document.querySelector("[data-noise-pct]");
  const mixMsg = document.querySelector("[data-mix-msg]");

  const readMixGains = () => ({
    music01: Number(musicRange?.value || 100) / 100,
    noise01: Number(noiseRange?.value || 12) / 100,
  });

  const syncMixLabels = () => {
    const { music01, noise01 } = readMixGains();
    if (musicPct) musicPct.textContent = `${Math.round(music01 * 100)}%`;
    if (noisePct) noisePct.textContent = `${Math.round(noise01 * 100)}%`;
    mixPreview.setGains(music01, noise01);
  };
  musicRange?.addEventListener("input", syncMixLabels);
  noiseRange?.addEventListener("input", syncMixLabels);
  syncMixLabels();

  const setMixMsg = (msg: string, err = false) => {
    if (!(mixMsg instanceof HTMLElement)) return;
    mixMsg.hidden = !msg;
    mixMsg.textContent = msg;
    mixMsg.classList.toggle("is-err", err);
  };

  document.querySelector("[data-mix-stop]")?.addEventListener("click", () => {
    mixPreview.stop();
    setMixMsg("Stop.");
  });

  document.querySelector("[data-mix-play]")?.addEventListener("click", async () => {
    const { music01, noise01 } = readMixGains();
    mixPreview.setGains(music01, noise01);
    setMixMsg("Cargando…");
    try {
      if (channel === "stems") {
        const files = stemRows.map((r) => r.file).filter((f): f is File => !!f);
        if (!files.length) {
          setMixMsg("Primero arrastra stems de audio.", true);
          return;
        }
        await mixPreview.playStems(files);
        setMixMsg(
          `Reproduciendo ${files.length} capa(s) · audio ${Math.round(music01 * 100)}% · ruido ${Math.round(noise01 * 100)}%`,
        );
      } else {
        const vInput = document.querySelector<HTMLInputElement>("[data-video-file]");
        const file = vInput?.files?.[0];
        const previewBox = document.querySelector("[data-video-preview]");
        let videoEl = previewBox?.querySelector("video") as HTMLVideoElement | null;
        if (!videoEl && file) {
          // Forzar preview si no hay
          const url = URL.createObjectURL(file);
          if (previewBox instanceof HTMLElement) {
            previewBox.hidden = false;
            previewBox.innerHTML = `<video src="${url}" controls playsinline></video><p class="fname">${file.name}</p>`;
            videoEl = previewBox.querySelector("video");
          }
        }
        if (!videoEl) {
          setMixMsg("Elige un vídeo primero.", true);
          return;
        }
        await mixPreview.playMediaElement(videoEl);
        setMixMsg(
          `Vídeo + ruido · audio ${Math.round(music01 * 100)}% · ruido ${Math.round(noise01 * 100)}% (solo escucha; el mp4 no se re-mezcla al publicar)`,
        );
      }
    } catch (e) {
      setMixMsg(e instanceof Error ? e.message : "No se pudo reproducir", true);
    }
  });

  // Moods / tags: chip principal + check “filtro” en biblioteca
  const makeChipRow = (
    name: "moodPick" | "tagPick",
    filterName: "moodFilter" | "tagFilter",
    value: string,
    opts?: { main?: boolean; filter?: boolean },
  ) => {
    const row = document.createElement("div");
    row.className = "pick-item";
    const mainLab = document.createElement("label");
    mainLab.className = "pick-main";
    const mainCb = document.createElement("input");
    mainCb.type = "checkbox";
    mainCb.name = name;
    mainCb.value = value;
    mainCb.dataset.chipMain = "1";
    mainCb.checked = opts?.main ?? true;
    mainLab.appendChild(mainCb);
    mainLab.appendChild(document.createTextNode(" " + value));
    const filLab = document.createElement("label");
    filLab.className = "pick-filter";
    filLab.title = "Mostrar en filtros de biblioteca";
    const filCb = document.createElement("input");
    filCb.type = "checkbox";
    filCb.name = filterName;
    filCb.value = value;
    filCb.dataset.chipFilter = "1";
    filCb.checked = opts?.filter ?? false;
    filLab.appendChild(filCb);
    filLab.appendChild(document.createElement("span")).textContent = "F";
    // Si quitas el mood/tag, quita el filtro
    mainCb.addEventListener("change", () => {
      if (!mainCb.checked) filCb.checked = false;
    });
    filCb.addEventListener("change", () => {
      if (filCb.checked) mainCb.checked = true;
    });
    row.appendChild(mainLab);
    row.appendChild(filLab);
    return row;
  };

  const wireChipPair = (pick: HTMLElement) => {
    pick.querySelectorAll("[data-chip-main]").forEach((el) => {
      if (!(el instanceof HTMLInputElement) || el.dataset.wired) return;
      el.dataset.wired = "1";
      const val = el.value;
      const fil = pick.querySelector(
        `[data-chip-filter][value="${CSS.escape(val)}"]`,
      ) as HTMLInputElement | null;
      el.addEventListener("change", () => {
        if (!el.checked && fil) fil.checked = false;
      });
      fil?.addEventListener("change", () => {
        if (fil.checked) el.checked = true;
      });
    });
  };

  const addCustomChip = (
    pickSel: string,
    inputSel: string,
    name: "moodPick" | "tagPick",
    filterName: "moodFilter" | "tagFilter",
  ) => {
    const pick = document.querySelector(pickSel);
    const input = document.querySelector(inputSel);
    if (!(pick instanceof HTMLElement) || !(input instanceof HTMLInputElement)) return;
    wireChipPair(pick);
    const add = () => {
      const v = input.value.trim().toLowerCase().slice(0, 40);
      if (!v) return;
      const exists = pick.querySelector(`[data-chip-main][value="${CSS.escape(v)}"]`);
      if (exists instanceof HTMLInputElement) {
        exists.checked = true;
        input.value = "";
        return;
      }
      pick.appendChild(makeChipRow(name, filterName, v, { main: true, filter: false }));
      wireChipPair(pick);
      input.value = "";
    };
    document
      .querySelector(inputSel === "[data-mood-custom]" ? "[data-mood-add]" : "[data-tag-add]")
      ?.addEventListener("click", add);
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        add();
      }
    });
  };
  addCustomChip("[data-mood-pick]", "[data-mood-custom]", "moodPick", "moodFilter");
  addCustomChip("[data-tag-pick]", "[data-tag-custom]", "tagPick", "tagFilter");

  const setChannel = (ch: "video" | "stems") => {
    channel = ch;
    document.querySelectorAll("[data-channel]").forEach((b) => {
      b.classList.toggle("is-active", (b as HTMLElement).dataset.channel === ch);
    });
    const vf = document.querySelector("[data-video-fields]");
    const sf = document.querySelector("[data-stems-fields]");
    if (vf instanceof HTMLElement) vf.hidden = ch !== "video";
    if (sf instanceof HTMLElement) sf.hidden = ch !== "stems";
    const videoInput = document.querySelector("[data-video-file]");
    if (videoInput instanceof HTMLInputElement) {
      videoInput.required = ch === "video" && !editingSlug;
    }
  };

  const setMediaBanner = (
    sel: string,
    ok: boolean,
    html: string,
    show: boolean,
  ) => {
    const el = document.querySelector(sel);
    if (!(el instanceof HTMLElement)) return;
    if (!show) {
      el.hidden = true;
      el.textContent = "";
      el.classList.remove("is-ok", "is-bad");
      return;
    }
    el.hidden = false;
    el.classList.toggle("is-ok", ok);
    el.classList.toggle("is-bad", !ok);
    el.innerHTML = html;
  };

  /** Avisos verdes/rojos junto a cada zona de archivos al editar. */
  const paintMediaStatus = (item: Record<string, unknown> | null) => {
    if (!item) {
      setMediaBanner("[data-status-video]", true, "", false);
      setMediaBanner("[data-status-stems]", true, "", false);
      setMediaBanner("[data-status-stems-visual]", true, "", false);
      return;
    }

    const videoUrl = item.video ? String(item.video) : "";
    const coverUrl = item.cover ? String(item.cover) : "";
    const stems = Array.isArray(item.stems) ? item.stems : [];
    const videoName = videoUrl ? decodeURIComponent(videoUrl.split("/").pop() || videoUrl) : "";
    const coverName = coverUrl ? decodeURIComponent(coverUrl.split("/").pop() || coverUrl) : "";
    const stemNames = stems
      .map((s: { label?: string; src?: string }) =>
        String(s.label || (s.src || "").split("/").pop() || "?"),
      )
      .filter(Boolean);

    // Canal vídeo
    if (videoUrl) {
      setMediaBanner(
        "[data-status-video]",
        true,
        `<strong>✓ Vídeo en servidor</strong><br/><span>${videoName}</span>` +
          (coverName
            ? `<br/><span>Cover: ${coverName}</span>`
            : "") +
          `<br/><span class="media-status__note">No hace falta re-subir para guardar tags. Solo elige archivo si quieres reemplazarlo.</span>`,
        true,
      );
    } else {
      setMediaBanner(
        "[data-status-video]",
        false,
        `<strong>✗ No hay vídeo en servidor</strong><br/><span>Elige un archivo mp4/webm o la ficha no tendrá vídeo.</span>`,
        true,
      );
    }

    // Canal stems — visual
    if (videoUrl || coverName) {
      setMediaBanner(
        "[data-status-stems-visual]",
        true,
        `<strong>✓ Visual en servidor</strong><br/><span>${
          videoName ? `Vídeo: ${videoName}` : ""
        }${videoName && coverName ? " · " : ""}${coverName ? `Cover: ${coverName}` : ""}</span>`,
        true,
      );
    } else {
      setMediaBanner(
        "[data-status-stems-visual]",
        false,
        `<strong>Sin vídeo/cover en servidor</strong><br/><span>Opcional: puedes subir visual ahora o dejarlo vacío.</span>`,
        true,
      );
    }

    // Canal stems — audio
    if (stemNames.length) {
      setMediaBanner(
        "[data-status-stems]",
        true,
        `<strong>✓ ${stemNames.length} stem(s) en servidor</strong><br/><span>${stemNames.join(" · ")}</span>` +
          `<br/><span class="media-status__note">Se conservan al guardar. Solo arrastra archivos nuevos si quieres reemplazarlos (con ruido).</span>`,
        true,
      );
    } else {
      setMediaBanner(
        "[data-status-stems]",
        false,
        `<strong>✗ No hay stems en servidor</strong><br/><span>Arrastra al menos un audio o no se podrá publicar esta ficha stems.</span>`,
        true,
      );
    }
  };

  const setEditMode = (item: Record<string, unknown> | null) => {
    editingItem = item;
    editingSlug = item ? String(item.slug || "") : null;
    const bar = document.querySelector("[data-edit-bar]");
    const label = document.querySelector("[data-edit-label]");
    const hint = document.querySelector("[data-edit-hint]");
    const pubBtn = document.querySelector("[data-publish]");
    const slugInput = document.querySelector<HTMLInputElement>("[data-slug]");
    if (bar instanceof HTMLElement) bar.hidden = !item;
    if (hint instanceof HTMLElement) hint.hidden = !item;
    if (label) label.textContent = item ? `Editando «${item.title || item.slug}»` : "";
    if (pubBtn) pubBtn.textContent = item ? "Guardar cambios" : "Publicar en la web";
    if (slugInput) {
      slugInput.readOnly = !!item;
      slugInput.style.opacity = item ? "0.7" : "1";
    }
    // En edición el vídeo no es obligatorio en el input
    const videoInput = document.querySelector("[data-video-file]");
    if (videoInput instanceof HTMLInputElement) {
      videoInput.required = !item && channel === "video";
    }
    if (!item) {
      const form = document.querySelector("[data-admin-form]");
      if (form instanceof HTMLFormElement) form.reset();
      stemRows = [];
      renderStems();
      paintMediaStatus(null);
      setChannel("video");
      return;
    }

    const form = document.querySelector("[data-admin-form]");
    if (!(form instanceof HTMLFormElement)) return;
    const titleEl = form.querySelector("[data-title]") as HTMLInputElement | null;
    if (titleEl) titleEl.value = String(item.title || "");
    if (slugInput) slugInput.value = String(item.slug || "");
    const aspect = form.querySelector("[name=aspect]") as HTMLSelectElement | null;
    if (aspect) aspect.value = String(item.aspect || "1:1");
    const desc = form.querySelector("[name=description]") as HTMLTextAreaElement | null;
    if (desc) desc.value = String(item.description || "");
    const notes = form.querySelector("[name=notes]") as HTMLTextAreaElement | null;
    if (notes) notes.value = String(item.notes || "");
    const year = form.querySelector("[name=year]") as HTMLInputElement | null;
    if (year) year.value = String(item.year || new Date().getFullYear());
    const lic = form.querySelector("[name=licenseEnabled]") as HTMLInputElement | null;
    if (lic) lic.checked = item.licenseEnabled !== false;
    const prov = form.querySelector("[name=provisional]") as HTMLInputElement | null;
    if (prov) prov.checked = Boolean(item.provisional);

    const kind = item.kind === "stems" || (Array.isArray(item.stems) && item.stems.length)
      ? "stems"
      : "video";
    setChannel(kind);

    const ensureChip = (
      pickSel: string,
      name: "moodPick" | "tagPick",
      filterName: "moodFilter" | "tagFilter",
      value: string,
      asFilter: boolean,
    ) => {
      const pick = document.querySelector(pickSel);
      if (!(pick instanceof HTMLElement)) return;
      let main = pick.querySelector(
        `[data-chip-main][value="${CSS.escape(value)}"]`,
      ) as HTMLInputElement | null;
      if (!main) {
        pick.appendChild(
          makeChipRow(name, filterName, value, { main: true, filter: asFilter }),
        );
        wireChipPair(pick);
        main = pick.querySelector(
          `[data-chip-main][value="${CSS.escape(value)}"]`,
        ) as HTMLInputElement | null;
      }
      if (main) main.checked = true;
      const fil = pick.querySelector(
        `[data-chip-filter][value="${CSS.escape(value)}"]`,
      ) as HTMLInputElement | null;
      if (fil) fil.checked = asFilter;
    };
    document.querySelectorAll("[name=moodPick], [name=moodFilter], [name=tagPick], [name=tagFilter]").forEach((el) => {
      if (el instanceof HTMLInputElement) el.checked = false;
    });
    const fMoods = new Set((item.filterMoods as string[]) || []);
    const fTags = new Set((item.filterTags as string[]) || []);
    for (const m of (item.moods as string[]) || []) {
      ensureChip("[data-mood-pick]", "moodPick", "moodFilter", m, fMoods.has(m));
    }
    for (const t of (item.tags as string[]) || []) {
      ensureChip("[data-tag-pick]", "tagPick", "tagFilter", t, fTags.has(t));
    }

    stemRows = [];
    renderStems();
    paintMediaStatus(item);
    setStatus(
      `Editando «${item.title}». Mira los avisos verdes/rojos junto a los archivos. Guarda tags sin re-subir.`,
    );
  };

  document.querySelector("[data-edit-cancel]")?.addEventListener("click", () => {
    setEditMode(null);
    setStatus("Edición cancelada.");
  });

  const renderPubs = () => {
    const grid = document.querySelector("[data-pub-grid]");
    const pager = document.querySelector("[data-pub-pager]");
    const pageLabel = document.querySelector("[data-pub-page]");
    if (!(grid instanceof HTMLElement)) return;

    if (!publications.length) {
      grid.innerHTML = `<p class="pub-empty">No hay publicaciones.</p>`;
      if (pager instanceof HTMLElement) pager.hidden = true;
      return;
    }

    const totalPages = Math.max(1, Math.ceil(publications.length / PUB_PAGE_SIZE));
    if (pubPage >= totalPages) pubPage = totalPages - 1;
    if (pubPage < 0) pubPage = 0;
    const start = pubPage * PUB_PAGE_SIZE;
    const slice = publications.slice(start, start + PUB_PAGE_SIZE);

    if (pager instanceof HTMLElement) {
      pager.hidden = totalPages <= 1;
    }
    if (pageLabel) pageLabel.textContent = `${pubPage + 1} / ${totalPages}`;
    const prev = document.querySelector("[data-pub-prev]");
    const next = document.querySelector("[data-pub-next]");
    if (prev instanceof HTMLButtonElement) prev.disabled = pubPage <= 0;
    if (next instanceof HTMLButtonElement) next.disabled = pubPage >= totalPages - 1;

    grid.innerHTML = slice
      .map((item) => {
        const slug = String(item.slug || "");
        const title = String(item.title || slug);
        const cover = String(item.cover || "");
        const video = String(item.video || "");
        const kind = String(item.kind || "");
        const thumb = cover
          ? `<img src="${cover.replace(/"/g, "")}" alt="" loading="lazy" width="72" height="72" />`
          : video
            ? `<video src="${video.replace(/"/g, "")}" muted playsinline preload="metadata" width="72" height="72"></video>`
            : `<span class="pub-ph">${kind === "stems" ? "S" : "V"}</span>`;
        return `<article class="pub-card" data-pub-slug="${slug.replace(/"/g, "")}">
          <div class="pub-thumb" aria-hidden="true">${thumb}</div>
          <div class="pub-meta">
            <strong title="${title.replace(/"/g, "")}">${title.slice(0, 28)}${title.length > 28 ? "…" : ""}</strong>
            <span>${kind}${item.provisional ? " · demo" : ""}</span>
          </div>
          <div class="pub-actions">
            <button type="button" class="btn btn--sm" data-pub-edit="${slug.replace(/"/g, "")}">Editar</button>
            <button type="button" class="btn btn--sm btn--danger" data-pub-del="${slug.replace(/"/g, "")}">Borrar</button>
          </div>
        </article>`;
      })
      .join("");

    grid.querySelectorAll("[data-pub-edit]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const slug = (btn as HTMLElement).dataset.pubEdit || "";
        const item = publications.find((p) => p.slug === slug);
        if (item) {
          setEditMode(item);
          document.querySelector("[data-admin-form]")?.scrollIntoView({ behavior: "smooth" });
        }
      });
    });
    grid.querySelectorAll("[data-pub-del]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const slug = (btn as HTMLElement).dataset.pubDel || "";
        if (!slug) return;
        if (!confirm(`¿Borrar «${slug}» del catálogo y sus archivos en R2? No se puede deshacer.`)) {
          return;
        }
        try {
          const res = await fetch(`/admin/items?slug=${encodeURIComponent(slug)}`, {
            method: "DELETE",
            credentials: "same-origin",
          });
          const data = await res.json();
          if (!res.ok || !data.ok) throw new Error(data.error || data.message || "Error");
          setStatus(`✅ ${data.message || "Borrado"}`);
          if (editingSlug === slug) setEditMode(null);
          await loadPubs();
        } catch (e) {
          setStatus(e instanceof Error ? e.message : "Error al borrar", false);
        }
      });
    });
  };

  const loadPubs = async () => {
    const grid = document.querySelector("[data-pub-grid]");
    try {
      const res = await fetch("/admin/items", { credentials: "same-origin" });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || "No se pudo cargar");
      publications = Array.isArray(data.items) ? data.items : [];
      pubPage = 0;
      renderPubs();
    } catch (e) {
      if (grid instanceof HTMLElement) {
        grid.innerHTML = `<p class="pub-empty is-err">${e instanceof Error ? e.message : "Error"}</p>`;
      }
    }
  };

  document.querySelector("[data-pub-prev]")?.addEventListener("click", () => {
    pubPage -= 1;
    renderPubs();
  });
  document.querySelector("[data-pub-next]")?.addEventListener("click", () => {
    pubPage += 1;
    renderPubs();
  });
  document.querySelector("[data-pub-refresh]")?.addEventListener("click", () => {
    void loadPubs();
  });
  void loadPubs();

  document.querySelector("[data-admin-form]")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector("[data-publish]");
    if (btn instanceof HTMLButtonElement) btn.disabled = true;

    try {
      const fd = new FormData(form);
      const title = String(fd.get("title") || "").trim();
      const slug =
        editingSlug ||
        String(fd.get("slug") || "").trim() ||
        slugify(title);
      const moods = fd.getAll("moodPick").map(String);
      const tags = fd.getAll("tagPick").map(String);
      const filterMoods = fd.getAll("moodFilter").map(String).filter((m) => moods.includes(m));
      const filterTags = fd.getAll("tagFilter").map(String).filter((t) => tags.includes(t));

      const hasVideoFile =
        channel === "video"
          ? !!(form.querySelector("[data-video-file]") as HTMLInputElement)?.files?.[0]
          : !!(form.querySelector("[data-stems-video]") as HTMLInputElement)?.files?.[0];
      const hasCoverFile =
        channel === "video"
          ? !!(form.querySelector("[data-cover-file]") as HTMLInputElement)?.files?.[0]
          : !!(form.querySelector("[data-stems-cover]") as HTMLInputElement)?.files?.[0];
      const hasStemFiles = stemRows.some((r) => r.file);
      const hasAnyNewMedia = hasVideoFile || hasCoverFile || hasStemFiles;

      // Siempre preferir PATCH si solo cambian texto/tags (sin archivos nuevos)
      if (editingSlug && !hasAnyNewMedia) {
        setStatus("Guardando (conservando media)…");
        const res = await fetch("/admin/items", {
          method: "PATCH",
          credentials: "same-origin",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            slug,
            title,
            aspect: String(fd.get("aspect") || "1:1"),
            description: String(fd.get("description") || ""),
            notes: String(fd.get("notes") || ""),
            moods,
            tags,
            filterMoods,
            filterTags,
            year: Number(fd.get("year") || 2026),
            provisional: fd.get("provisional") === "on",
            licenseEnabled: fd.get("licenseEnabled") === "on",
          }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.message || data.error || "Error");
        setStatus(`✅ ${data.message || "Guardado"}`);
        showToast(`✅ Guardado «${title}» (media intacta)`, 14000);
        await loadPubs();
        // Seguir en edición con el ítem actualizado
        const updated = publications.find((p) => p.slug === slug) || data.item;
        if (updated) setEditMode(updated as Record<string, unknown>);
        return;
      }

      const body = new FormData();
      body.set("title", title);
      body.set("slug", slug);
      body.set("kind", channel);
      body.set("aspect", String(fd.get("aspect") || "1:1"));
      body.set("moods", JSON.stringify(moods));
      body.set("tags", JSON.stringify(tags));
      body.set("filterMoods", JSON.stringify(filterMoods));
      body.set("filterTags", JSON.stringify(filterTags));
      body.set("description", String(fd.get("description") || ""));
      body.set("notes", String(fd.get("notes") || ""));
      body.set("year", String(fd.get("year") || "2026"));
      body.set("provisional", fd.get("provisional") === "on" ? "1" : "0");
      body.set("licenseEnabled", fd.get("licenseEnabled") === "on" ? "1" : "0");

      if (channel === "video") {
        const v = (form.querySelector("[data-video-file]") as HTMLInputElement)?.files?.[0];
        if (!v && !editingSlug) throw new Error("Elige un vídeo.");
        // En edición: sin vídeo nuevo → el servidor conserva el existente
        if (v) body.set("video", v, v.name);
        const c = (form.querySelector("[data-cover-file]") as HTMLInputElement)?.files?.[0];
        if (c) body.set("cover", c, c.name);
      } else {
        const v = (form.querySelector("[data-stems-video]") as HTMLInputElement)?.files?.[0];
        if (v) body.set("video", v, v.name);
        const c = (form.querySelector("[data-stems-cover]") as HTMLInputElement)?.files?.[0];
        if (c) body.set("cover", c, c.name);
        const { music01, noise01 } = readMixGains();
        const withFile = stemRows.filter((r) => r.file);
        if (!withFile.length && !editingSlug) {
          throw new Error("Añade al menos un stem con audio.");
        }
        // En edición sin stems nuevos: servidor conserva stems
        if (withFile.length) {
          mixPreview.stop();
          setStatus(
            `Procesando mezcla (audio ${Math.round(music01 * 100)}% · ruido ${Math.round(noise01 * 100)}%) en ${withFile.length} stem(s)…`,
          );
          let n = 0;
          for (const row of withFile) {
            if (!row.file) continue;
            let file = row.file;
            try {
              file = await bakePreviewNoise(row.file, noise01, music01);
            } catch (err) {
              console.warn("[bake noise]", err);
            }
            body.set(`stem_${n}_file`, file, file.name);
            body.set(`stem_${n}_label`, row.label || row.file.name);
            n++;
          }
        }
      }

      mixPreview.stop();
      setStatus(editingSlug ? "Guardando cambios…" : "Publicando… (subida + catálogo)");
      const res = await fetch("/admin/publish", {
        method: "POST",
        body,
        credentials: "same-origin",
      });
      const data = await res.json();
      if (!res.ok || !data.ok) {
        const err = String(data.error || "");
        if (err === "bad_extension") {
          throw new Error(
            "Tipo de archivo no permitido. Vídeo: mp4/webm/mov · Audio: mp3/wav/m4a · Imagen: jpg/png/webp",
          );
        }
        if (err === "file_too_large" || err === "total_too_large") {
          throw new Error(
            err === "total_too_large"
              ? `Peso total máximo ${data.maxTotalMb || 250} MB por publicación`
              : `Archivo demasiado grande (máx ${data.maxMb || 100} MB)`,
          );
        }
        if (err === "missing_stems") {
          throw new Error("Faltan stems y no hay stems previos que conservar.");
        }
        if (err === "missing_video") {
          throw new Error("Falta vídeo y no hay vídeo previo que conservar.");
        }
        throw new Error(data.message || data.error || `Error ${res.status}`);
      }

      const msg =
        data.message ||
        `✅ ${editingSlug ? "Guardado" : "Publicado"} «${data.item?.title || title}»`;
      setStatus(`✅ ${msg}`);
      showToast(`✅ ${msg}`, 18000);
      const out = document.querySelector("[data-out]");
      if (out instanceof HTMLElement) {
        out.hidden = false;
        out.textContent = JSON.stringify(
          {
            ok: true,
            merged: data.merged,
            keptMedia: data.keptMedia,
            catalogCount: data.catalogCount,
            item: data.item,
          },
          null,
          2,
        );
      }
      await loadPubs();
      // Seguir editando el mismo ítem (cambios acumulativos)
      const updated =
        publications.find((p) => p.slug === slug) ||
        (data.item as Record<string, unknown> | undefined);
      if (updated) {
        setEditMode(updated);
        stemRows = [];
        renderStems();
        // limpiar inputs file
        form.querySelectorAll('input[type="file"]').forEach((inp) => {
          if (inp instanceof HTMLInputElement) inp.value = "";
        });
        document.querySelectorAll(".preview").forEach((p) => {
          if (p instanceof HTMLElement) {
            p.hidden = true;
            p.innerHTML = "";
          }
        });
      } else {
        setEditMode(null);
        form.reset();
        stemRows = [];
        renderStems();
      }
    } catch (err) {
      setStatus(err instanceof Error ? err.message : "Error al publicar", false);
    } finally {
      if (btn instanceof HTMLButtonElement) btn.disabled = false;
    }
  });
</script>

