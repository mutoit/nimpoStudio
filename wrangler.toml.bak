# Cloudflare Pages — proyecto nimpo-studio
name = "nimpo-studio"
compatibility_date = "2024-07-01"
pages_build_output_dir = "./dist"

# Worker de email (deploy: cd workers/nimpo-mail && npx wrangler deploy)
# Binding service (si el deploy Pages lo aplica; si no, usa MAIL_WORKER_URL + MAIL_SECRET)
[[services]]
binding = "MAIL"
service = "nimpo-mail"